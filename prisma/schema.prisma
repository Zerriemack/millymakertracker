generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Sport {
  NFL
  CFB
}

enum LineupType {
  CLASSIC
  SHOWDOWN
}

enum SlateType {
  MAIN
  SHOWDOWN
  TNF
  SUPER_BOWL
  SNF
  MNF
  OTHER
}

enum RosterSpot {
  QB
  RB
  WR
  TE
  FLEX
  DST
  CAPTAIN
}

enum GameWindow {
  EARLY
  LATE
  PRIME
  OTHER
}

enum CorrelationType {
  STACK
  BRINGBACK
}

model Season {
  id     String @id @default(cuid())
  year   Int
  sport  Sport
  slates Slate[]
  games  Game[]

  weekForms PlayerWeekForm[]

  @@unique([year, sport])
}

model Slate {
  id        String    @id @default(cuid())
  seasonId  String
  week      Int?
  slateType SlateType
  slateDate DateTime

  lineupType     LineupType
  salaryCapCents Int?
  gamesCount     Int?
  dayOfWeek      Int?
  isMain         Boolean @default(false)

  slateKey   String  @unique
  slateName  String?
  slateTag   String?
  slateGroup String?

  contests Contest[]
  season   Season @relation(fields: [seasonId], references: [id])

  @@index([seasonId])
  @@index([seasonId, week])
  @@index([seasonId, lineupType])
  @@index([slateTag])
  @@index([slateGroup])
}

model Contest {
  id            String @id @default(cuid())
  slateId       String
  site          String
  siteContestId String?
  contestName   String
  entryFeeCents Int?
  entries       Int?

  // treated as "winner payout" in your workflow
  topPrizeCents Int?

  totalOwnershipBp Int?

  winners Winner[]
  slate   Slate @relation(fields: [slateId], references: [id])

  analysis ContestAnalysis?

  @@unique([site, siteContestId])
  @@index([slateId])
  @@index([site])
}

model ContestAnalysis {
  id String @id @default(cuid())

  contestId String  @unique
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  stackSummary    String?
  uniquenessNotes String?
  stackMeta       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contestId])
}

model Winner {
  id         String @id @default(cuid())
  contestId  String
  username   String
  points     Float
  maxEntries Int?
  lineup     Lineup?

  contest Contest @relation(fields: [contestId], references: [id])

  @@unique([contestId, username])
  @@index([contestId])
  @@index([username])
}

model Team {
  id           String @id @default(cuid())
  sport        Sport
  abbreviation String
  name         String

  // stadium proxy for home games (current default)
  homeIsIndoor Boolean @default(false)

  players Player[]
  seasons TeamSeason[]

  opponentLineupItems LineupItem[] @relation("LineupItemOpponentTeam")

  homeGames Game[] @relation("HomeTeamGames")
  awayGames Game[] @relation("AwayTeamGames")

  @@unique([sport, abbreviation])
}

model TeamSeason {
  id           String  @id @default(cuid())
  teamId       String
  seasonYear   Int
  homeIsIndoor Boolean @default(false)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, seasonYear])
  @@index([seasonYear])
  @@index([teamId])
}

model Player {
  gsisId     String?
  id         String @id @default(cuid())
  sport      Sport
  name       String
  position   String
  teamId     String
  dkPlayerId Int?

  team        Team         @relation(fields: [teamId], references: [id])
  lineupItems LineupItem[]

  opponentStartingQbFor LineupItem[] @relation("LineupItemOpponentQb")

  homeStartingQbGames Game[] @relation("HomeStartingQb")
  awayStartingQbGames Game[] @relation("AwayStartingQb")

  weekForms PlayerWeekForm[]

  corrAsQb   LineupCorrelation[] @relation("CorrQB")
  corrAsMate LineupCorrelation[] @relation("CorrMate")
  corrAsOpp  LineupCorrelation[] @relation("CorrOpp")

  @@unique([sport, dkPlayerId])
  @@unique([sport, name, position, teamId])
  @@unique([sport, gsisId])
  @@index([teamId])
  @@index([sport])
}

model Game {
  id       String @id @default(cuid())
  seasonId String
  week     Int?
  sport    Sport

  kickoffTimeUtc DateTime
  window         GameWindow

  homeTeamId String
  awayTeamId String

  homeStartingQbPlayerId String?
  awayStartingQbPlayerId String?

  season Season @relation(fields: [seasonId], references: [id])

  homeTeam Team @relation("HomeTeamGames", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayTeamGames", fields: [awayTeamId], references: [id])

  homeStartingQb Player? @relation("HomeStartingQb", fields: [homeStartingQbPlayerId], references: [id])
  awayStartingQb Player? @relation("AwayStartingQb", fields: [awayStartingQbPlayerId], references: [id])

  lineupItems    LineupItem[]
  correlations   LineupCorrelation[]

  @@unique([seasonId, homeTeamId, awayTeamId, kickoffTimeUtc])
  @@index([seasonId])
  @@index([seasonId, week])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([kickoffTimeUtc])
  @@index([window])
}

model PlayerWeekForm {
  id       String @id @default(cuid())
  seasonId String
  week     Int
  playerId String

  season Season @relation(fields: [seasonId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  // flexible storage for your "steady tells"
  metrics Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seasonId, week, playerId])
  @@index([seasonId, week])
  @@index([playerId])
}

model Lineup {
  id          String    @id @default(cuid())
  winnerId    String    @unique
  lineupType  LineupType
  salaryUsed  Int?
  totalPoints Float?

  totalOwnershipBp Int?

  items        LineupItem[]
  winner       Winner        @relation(fields: [winnerId], references: [id])
  analysis     LineupAnalysis?
  correlations LineupCorrelation[]

  @@index([lineupType])
}

model LineupItem {
  id         String     @id @default(cuid())
  lineupId   String
  playerId   String
  rosterSpot RosterSpot
  slotIndex  Int        @default(0)

  salary Int?
  points Float?

  // legacy fields
  ownership   Float?
  ownershipBp Int?

  // slot-specific ownership bps
  ownershipCaptainBp Int?
  ownershipFlexBp    Int?
  ownershipClassicBp Int?

  // universal context
  gameId         String?
  opponentTeamId String?

  // QB outcome fields
  passYds Int?
  passTd  Int?
  passInt Int?
  rushYds Int?
  rushTd  Int?

  // RB outcome fields
  rushAtt   Int?
  rushYdsRb Int?
  rushTdRb  Int?
  targetsRb Int?
  recRb     Int?
  recYdsRb  Int?
  recTdRb   Int?

  // WR/TE outcome fields
  targets Int?
  rec     Int?
  recYds  Int?
  recTd   Int?

  // DST outcome fields
  opponentStartingQbPlayerId String?
  pointsAllowedBucket        Int?
  defensiveTdCount           Int?
  sacks                      Int?
  takeaways                  Int?

  lineup   Lineup  @relation(fields: [lineupId], references: [id])
  player   Player  @relation(fields: [playerId], references: [id])
  game     Game?   @relation(fields: [gameId], references: [id])

  opponentTeam       Team?   @relation("LineupItemOpponentTeam", fields: [opponentTeamId], references: [id])
  opponentStartingQb Player? @relation("LineupItemOpponentQb", fields: [opponentStartingQbPlayerId], references: [id])

  analysis LineupItemAnalysis?

  @@unique([lineupId, rosterSpot, slotIndex])
  @@index([lineupId])
  @@index([playerId])

  @@index([rosterSpot])
  @@index([ownershipClassicBp])
  @@index([ownershipCaptainBp])
  @@index([ownershipFlexBp])

  @@index([gameId])
  @@index([opponentTeamId])
  @@index([opponentStartingQbPlayerId])
  @@index([pointsAllowedBucket])
}

model LineupAnalysis {
  id       String @id @default(cuid())
  lineupId String @unique
  lineup   Lineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)

  archetypeTags Json?
  macroStory    String?

  earlyCount Int?
  lateCount  Int?
  primeCount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lineupId])
}

model LineupItemAnalysis {
  id           String @id @default(cuid())
  lineupItemId String @unique
  lineupItem   LineupItem @relation(fields: [lineupItemId], references: [id], onDelete: Cascade)

  roleTags   Json?
  microStory String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lineupItemId])
}

model LineupCorrelation {
  id       String @id @default(cuid())
  lineupId String
  gameId   String?
  type     CorrelationType

  qbPlayerId       String
  teammatePlayerId String?
  opponentPlayerId String?

  lineup   Lineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  game     Game?  @relation(fields: [gameId], references: [id])

  qb       Player  @relation("CorrQB", fields: [qbPlayerId], references: [id])
  teammate Player? @relation("CorrMate", fields: [teammatePlayerId], references: [id])
  opponent Player? @relation("CorrOpp", fields: [opponentPlayerId], references: [id])

  @@index([lineupId])
  @@index([gameId])
  @@index([type])
  @@index([qbPlayerId])
  @@index([teammatePlayerId])
  @@index([opponentPlayerId])
}