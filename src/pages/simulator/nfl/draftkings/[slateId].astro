---
import Layout from "../../../../layouts/Layout.astro";
import { mockSlates, getSlateById } from "../../../../data/simulator/mockSlates";
import { getPlayersBySlate } from "../../../../data/simulator/mockPlayers";
import { getSettingsBySlate } from "../../../../data/simulator/mockSettings";
import { getResultsBySlate } from "../../../../data/simulator/mockResults";

const { slateId } = Astro.params;
const title = `Simulator | NFL | DraftKings | ${slateId ?? "Slate"}`;

const tab = (Astro.url.searchParams.get("tab") || "slates").toLowerCase();
const subtab = (Astro.url.searchParams.get("subtab") || "ev").toLowerCase();
const validTabs = ["slates", "inputs", "settings", "results", "lineups"];
const activeTab = validTabs.includes(tab) ? tab : "slates";
const validSubtabs = ["ev", "exp", "graded"];
const activeSubtab = validSubtabs.includes(subtab) ? subtab : "ev";

const activeSlate = slateId ? getSlateById(slateId) : undefined;
const slates = mockSlates.filter((slate) => slate.sport === "nfl" && slate.site === "draftkings");
const players = slateId ? getPlayersBySlate(slateId) : [];
const settings = slateId ? getSettingsBySlate(slateId) : undefined;
const results = slateId ? getResultsBySlate(slateId) : undefined;
---

<Layout title={title} fullBleed>
  <main class="page">
    <header class="hero">
      <h1 class="title">NFL DraftKings Simulator</h1>
      <p class="sub">Slate: {activeSlate?.name ?? slateId ?? "Unknown"}</p>
    </header>

    <nav class="breadcrumbs" aria-label="Simulator navigation">
      <a href="/simulator">Simulator</a>
      <span>/</span>
      <a href="/simulator/nfl">nfl</a>
      <span>/</span>
      <a href="/simulator/nfl/draftkings">draftkings</a>
      <span>/</span>
      <span>{slateId}</span>
    </nav>

    <nav class="tabs" aria-label="Simulator tabs">
      <a class:list={["tab", { active: activeTab === "slates" }]} href={`?tab=slates`}>Slates</a>
      <a class:list={["tab", { active: activeTab === "inputs" }]} href={`?tab=inputs`}>Inputs</a>
      <a class:list={["tab", { active: activeTab === "settings" }]} href={`?tab=settings`}>Settings</a>
      <a class:list={["tab", { active: activeTab === "results" }]} href={`?tab=results&subtab=${activeSubtab}`}>Results</a>
      <a class:list={["tab", { active: activeTab === "lineups" }]} href={`?tab=lineups`}>Lineups</a>
    </nav>

    {activeTab === "slates" && (
      <section class="panel" aria-label="Available slates">
        <h2 class="panel-title">Slates</h2>
        <table class="table">
          <thead>
            <tr>
              <th>Slate</th>
              <th>Game Type</th>
              <th>Games</th>
              <th>Salary Cap</th>
              <th>Start</th>
            </tr>
          </thead>
          <tbody>
            {slates.map((slate) => (
              <tr>
                <td>
                  <a href={`/simulator/nfl/draftkings/${slate.id}?tab=slates`}>
                    {slate.name}
                  </a>
                </td>
                <td>{slate.gameType}</td>
                <td>{slate.games}</td>
                <td>${slate.salaryCap.toLocaleString()}</td>
                <td>{new Date(slate.startTime).toLocaleString()}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {activeTab === "inputs" && (
      <section class="panel" aria-label="Inputs">
        <h2 class="panel-title">Players</h2>
        <table class="table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Team</th>
              <th>Pos</th>
              <th>Salary</th>
              <th>Proj</th>
              <th>Own%</th>
            </tr>
          </thead>
          <tbody>
            {players.map((player) => (
              <tr>
                <td>{player.name}</td>
                <td>{player.team}</td>
                <td>{player.position}</td>
                <td>${player.salary.toLocaleString()}</td>
                <td>{player.projection.toFixed(1)}</td>
                <td>{player.ownership.toFixed(1)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {activeTab === "settings" && (
      <section class="panel" aria-label="Settings">
        <h2 class="panel-title">Settings</h2>
        {settings ? (
          <dl class="settings">
            <div>
              <dt>Lineups</dt>
              <dd>{settings.lineupCount}</dd>
            </div>
            <div>
              <dt>Field Size</dt>
              <dd>{settings.fieldSize.toLocaleString()}</dd>
            </div>
            <div>
              <dt>Simulations</dt>
              <dd>{settings.simulationCount.toLocaleString()}</dd>
            </div>
            <div>
              <dt>Salary Cap</dt>
              <dd>${settings.salaryCap.toLocaleString()}</dd>
            </div>
          </dl>
        ) : (
          <p class="empty">No settings found for this slate.</p>
        )}
      </section>
    )}

    {activeTab === "results" && (
      <section class="panel" aria-label="Results">
        <h2 class="panel-title">Results</h2>
        <nav class="subtabs" aria-label="Results subtabs">
          <a class:list={["subtab", { active: activeSubtab === "ev" }]} href={`?tab=results&subtab=ev`}>Plus EV</a>
          <a class:list={["subtab", { active: activeSubtab === "exp" }]} href={`?tab=results&subtab=exp`}>Exposure</a>
          <a class:list={["subtab", { active: activeSubtab === "graded" }]} href={`?tab=results&subtab=graded`}>Graded</a>
        </nav>

        {activeSubtab === "ev" && (
          <table class="table">
            <thead>
              <tr>
                <th>Player</th>
                <th>Team</th>
                <th>Pos</th>
                <th>EV</th>
              </tr>
            </thead>
            <tbody>
              {results?.plusEv.map((row) => (
                <tr>
                  <td>{row.name}</td>
                  <td>{row.team}</td>
                  <td>{row.position}</td>
                  <td>{row.ev.toFixed(1)}</td>
                </tr>
              )) ?? (
                <tr>
                  <td colSpan={4}>No results.</td>
                </tr>
              )}
            </tbody>
          </table>
        )}

        {activeSubtab === "exp" && (
          <table class="table">
            <thead>
              <tr>
                <th>Player</th>
                <th>Exposure</th>
              </tr>
            </thead>
            <tbody>
              {results?.exposures.map((row) => (
                <tr>
                  <td>{row.name}</td>
                  <td>{row.exposure}%</td>
                </tr>
              )) ?? (
                <tr>
                  <td colSpan={2}>No exposures.</td>
                </tr>
              )}
            </tbody>
          </table>
        )}

        {activeSubtab === "graded" && (
          <table class="table">
            <thead>
              <tr>
                <th>Lineup</th>
                <th>Projected</th>
                <th>Grade</th>
              </tr>
            </thead>
            <tbody>
              {results?.gradedLineups.map((row) => (
                <tr>
                  <td>{row.lineup}</td>
                  <td>{row.projected.toFixed(1)}</td>
                  <td>{row.grade}</td>
                </tr>
              )) ?? (
                <tr>
                  <td colSpan={3}>No graded lineups.</td>
                </tr>
              )}
            </tbody>
          </table>
        )}
      </section>
    )}

    {activeTab === "lineups" && (
      <section class="panel" aria-label="Lineup builder">
        <h2 class="panel-title">Lineup Builder</h2>
        {(results?.lineups ?? []).map((lineup) => (
          <div class="lineup-card">
            <div class="lineup-header">
              <strong>Lineup {lineup.lineupId}</strong>
              <span>Salary Used: ${lineup.salaryUsed.toLocaleString()}</span>
              <span>Remaining: ${(50000 - lineup.salaryUsed).toLocaleString()}</span>
              <span>Proj: {lineup.projectedPoints.toFixed(1)}</span>
            </div>
            <table class="table">
              <thead>
                <tr>
                  <th>Slot</th>
                  <th>Player</th>
                  <th>Team</th>
                  <th>Pos</th>
                  <th>Salary</th>
                  <th>Proj</th>
                </tr>
              </thead>
              <tbody>
                {lineup.slots.map((slot) => (
                  <tr>
                    <td>{slot.rosterSlot}</td>
                    <td>{slot.playerName}</td>
                    <td>{slot.team}</td>
                    <td>{slot.position}</td>
                    <td>${slot.salary.toLocaleString()}</td>
                    <td>{slot.projection.toFixed(1)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}
        {(!results?.lineups || results.lineups.length === 0) && (
          <p class="empty">No lineups available yet.</p>
        )}
      </section>
    )}
  </main>
</Layout>

<style>
.page {
  max-width: 980px;
  margin: 0 auto;
  padding: 28px 16px 64px;
}

  .hero {
    margin: 8px 0 18px;
  }

  .title {
    margin: 0;
    font-size: 42px;
    font-weight: 850;
    letter-spacing: -0.02em;
  }

.sub {
  margin: 10px 0 0;
  color: var(--muted);
  max-width: 70ch;
}

.panel {
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px;
  background: var(--surface);
  margin-top: 14px;
}

.tabs {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 14px;
}

.tab {
  text-decoration: none;
  color: var(--text-2);
  font-weight: 700;
  padding: 6px 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
}

.tab.active {
  color: var(--text);
  border-color: var(--text);
}

.subtabs {
  display: flex;
  gap: 10px;
  margin: 10px 0 12px;
}

.subtab {
  text-decoration: none;
  color: var(--text-2);
  font-weight: 700;
  font-size: 0.9rem;
}

.subtab.active {
  color: var(--text);
  text-decoration: underline;
}

.table {
  width: 100%;
  border-collapse: collapse;
}

.table th,
.table td {
  text-align: left;
  padding: 8px 10px;
  border-bottom: 1px solid var(--border);
}

.table th {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text);
}

.table td {
  font-size: 0.9rem;
  color: var(--text-2);
}

.settings {
  margin: 0;
  display: grid;
  gap: 8px;
}

.settings div {
  display: flex;
  gap: 12px;
}

.settings dt {
  min-width: 140px;
  font-weight: 700;
  color: var(--text);
}

.settings dd {
  margin: 0;
  color: var(--text-2);
}

.lineup-card {
  margin-top: 12px;
  display: grid;
  gap: 10px;
}

.lineup-header {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  font-size: 0.9rem;
  color: var(--text-2);
}

.empty {
  margin: 0;
  color: var(--text-2);
}

  .breadcrumbs {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 0.9rem;
    margin: 8px 0 10px;
  }

  .breadcrumbs a {
    color: var(--text);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

.panel-title {
  margin: 0 0 10px;
  font-size: 18px;
  font-weight: 700;
}
</style>
