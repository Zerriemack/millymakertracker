---
import Layout from "../../layouts/Layout.astro";
import { listSlatePackages } from "../../lib/simulator/listSlatePackages";
import { loadSlatePackage } from "../../lib/simulator/loadSlatePackage";
import { loadJson } from "../../lib/simulator/loadJson";
import { resolveSlatePackagePath } from "../../lib/simulator/paths";
import type { SimulatorSlatePackage } from "../../lib/simulator/types";
import path from "path";

const tab = (Astro.url.searchParams.get("tab") || "slates").toLowerCase();
const subtab = (Astro.url.searchParams.get("subtab") || "ev").toLowerCase();
const slateParam = Astro.url.searchParams.get("slate");
const gameParam = Astro.url.searchParams.get("game");
const gameTypeParam = Astro.url.searchParams.get("gameType");
const operatorParam = Astro.url.searchParams.get("operator");

const validTabs = ["slates", "inputs", "settings", "results"];
const activeTab = validTabs.includes(tab) ? tab : "slates";
const validSubtabs = ["ev", "exp", "graded"];
const activeSubtab = validSubtabs.includes(subtab) ? subtab : "ev";
const validGameTypes = ["classic", "showdown"];
const activeGameType =
  gameTypeParam && validGameTypes.includes(gameTypeParam.toLowerCase())
    ? gameTypeParam.toLowerCase()
    : null;
const validOperators = ["draftkings", "fanduel"];
const activeOperator =
  operatorParam && validOperators.includes(operatorParam.toLowerCase())
    ? operatorParam.toLowerCase()
    : null;

const slateKeys = await listSlatePackages();
const defaultSlateKey = slateKeys[0] ?? null;
const requestedSlateKey = slateParam ?? defaultSlateKey;

let selectedPackage: SimulatorSlatePackage | null = null;
let slateError: string | null = null;

if (requestedSlateKey) {
  try {
    selectedPackage = await loadSlatePackage(requestedSlateKey);
  } catch (error) {
    slateError = `Slate package not found for key "${requestedSlateKey}".`;
  }
} else {
  slateError = "No slate packages are available.";
}

const slatePackages = await Promise.all(
  slateKeys.map(async (key) => {
    try {
      const pkg = await loadSlatePackage(key);
      return { key, ...pkg };
    } catch (error) {
      return null;
    }
  })
);

const availableSlates = slatePackages.filter(Boolean) as Array<
  SimulatorSlatePackage & { key: string }
>;

const slates = availableSlates
  .map((pkg) => ({
    key: pkg.key,
    slate: pkg.slate,
    gamesCount: pkg.games.length,
  }))
  .filter((entry) => entry.slate.sport === "nfl");

const filteredSlates = slates.filter(({ slate }) => {
  const slateGameType = slate.gameType.toLowerCase();
  const matchesGameType = activeGameType ? slateGameType === activeGameType : true;
  const matchesOperator = activeOperator ? slate.site === activeOperator : true;
  return matchesGameType && matchesOperator;
});

const selectedSlate = selectedPackage?.slate ?? null;
const activeSlateKey = requestedSlateKey ?? "";
const games = selectedPackage?.games ?? [];
const teamInputs = selectedPackage?.teamInputs ?? [];
const playerInputs = selectedPackage?.playerInputs ?? [];
const settings = selectedPackage?.settings
  ? {
      ...selectedPackage.settings,
      payoutProfile:
        selectedPackage.settings.payoutProfile === "flat"
          ? "cash"
          : selectedPackage.settings.payoutProfile ?? "standard",
    }
  : null;
let results: {
  slateId: string;
  generatedAt: string;
  simulationCount: number;
  settingsSnapshot: {
    lineupCount: number;
    fieldSize: number;
    simulationCount: number;
    payoutProfile?: "topHeavy" | "standard" | "cash";
  };
  players: Array<{
    id: string;
    name: string;
    team: string;
    position: string;
    salary: number;
    projection: number;
    ownership: number;
    optimalLineupCount: number;
    optimalSimRate: number;
    optimalLeverage: number;
    averageSimScore: number;
    maxSimScore: number;
    retainedLineupCount: number;
    retainedExposureRate: number;
    plusEvScore: number;
    minusEvScore: number;
  }>;
  lineups?: Array<{
    lineupKey: string;
    players: Array<{
      id: string;
      name: string;
      team: string;
      position: string;
      salary: number;
      ownership: number;
    }>;
    salaryUsed: number;
    sumOwnership: number;
    frequencyCount: number;
    frequencyRate: number;
    averageSimTotal: number;
    maxSimTotal: number;
    averageOptimalRate: number;
    topPointOnePctRate?: number;
    topOnePctRate?: number;
    itmRate?: number;
    evScore?: number;
  }>;
  poolSummary?: {
    distinctLineupCount: number;
    retainedLineupCount: number;
  };
  gradingSummary?: {
    gradingFieldMode: "retainedOnly" | "expandedField";
    gradingFieldSize: number;
    gradingUniverseSize: number;
    retainedPoolSize: number;
    gradingFieldExtraLineupCount: number;
    payoutProfile: "topHeavy" | "standard" | "cash";
  };
} | null = null;

if (selectedPackage && activeSlateKey) {
  try {
    const resultsPath = path.join(resolveSlatePackagePath(activeSlateKey), "results.json");
    results = await loadJson(resultsPath);
  } catch (error) {
    results = null;
  }
}

const activeGameId = gameParam && games.some((game) => game.id === gameParam)
  ? gameParam
  : games[0]?.id ?? null;
const selectedGame = games.find((game) => game.id === activeGameId) ?? null;
const selectedGameTeamInputs = teamInputs.filter((input) => input.gameId === activeGameId);
const awayTeamInputs = selectedGameTeamInputs.find((input) => input.team === selectedGame?.awayTeam) ?? null;
const homeTeamInputs = selectedGameTeamInputs.find((input) => input.team === selectedGame?.homeTeam) ?? null;
const awayPlayers = playerInputs.filter(
  (player) => player.gameId === activeGameId && player.team === selectedGame?.awayTeam
);
const homePlayers = playerInputs.filter(
  (player) => player.gameId === activeGameId && player.team === selectedGame?.homeTeam
);
const siteLabel =
  selectedSlate?.site === "draftkings"
    ? "DraftKings"
    : selectedSlate?.site === "fanduel"
      ? "FanDuel"
      : selectedSlate?.site
        ? selectedSlate.site.toUpperCase()
        : "DraftKings";
const formatGameTypeLabel = (slate?: { site?: string; gameType?: string } | null) => {
  if (!slate?.gameType) return "Classic";
  const gameType = slate.gameType;
  if (slate.site === "fanduel" && gameType.toLowerCase() === "showdown") {
    return "MVP";
  }
  return gameType;
};

const formatPayoutLabel = (profile: string) => {
  if (profile === "topHeavy") return "Top Heavy";
  if (profile === "cash" || profile === "flat") return "Cash";
  return "Standard";
};

const buildSimulatorUrl = ({
  slate,
  tabParam,
  subtabParam,
  gameType,
  operator,
  game,
}: {
  slate?: string | null;
  tabParam?: string | null;
  subtabParam?: string | null;
  gameType?: string | null;
  operator?: string | null;
  game?: string | null;
}) => {
  const params = new URLSearchParams();
  if (slate) params.set("slate", slate);
  if (tabParam) params.set("tab", tabParam);
  if (subtabParam) params.set("subtab", subtabParam);
  if (gameType) params.set("gameType", gameType);
  if (operator) params.set("operator", operator);
  if (game) params.set("game", game);
  const query = params.toString();
  return query ? `/simulator?${query}` : "/simulator";
};

const weekLabel = selectedSlate ? `Week ${selectedSlate.week}` : "Week";
const startTimeLabel = selectedSlate?.startTime
  ? new Date(selectedSlate.startTime).toLocaleString()
  : "TBD";

const formatCurrencyCompact = (value: number | null | undefined) =>
  typeof value === "number" && Number.isFinite(value) ? `$${value.toLocaleString()}` : "—";
const formatNumberCompact = (value: number | null | undefined, digits = 1) =>
  typeof value === "number" && Number.isFinite(value) ? value.toFixed(digits) : "—";
const formatPct = (value: number | null | undefined, digits = 1, assumeWhole = true) => {
  if (value === null || value === undefined || Number.isNaN(value)) return "0.0%";
  if (!Number.isFinite(value)) return "0.0%";
  const normalized = !assumeWhole && value >= 0 && value <= 1 ? value * 100 : value;
  return `${normalized.toFixed(digits)}%`;
};
const formatPctFromRate = (value: number | null | undefined, digits = 1) =>
  typeof value === "number" && Number.isFinite(value) ? `${value.toFixed(digits)}%` : "0.0%";

const formatOptLevDisplay = (value: number | null | undefined) => {
  if (value === null || value === undefined || Number.isNaN(value)) return "—";
  if (!Number.isFinite(value)) return "—";
  const normalized = Math.abs(value) >= 10 ? value / 10 : value;
  return `${normalized.toFixed(1)}%`;
};

const isInjuredPlayer = (player: Record<string, unknown>) => {
  const raw =
    (player.status as string | undefined) ||
    (player.injuryStatus as string | undefined) ||
    (player.gameStatus as string | undefined);
  const inactive = player.inactive === true;
  const value = typeof raw === "string" ? raw.toLowerCase() : "";
  if (inactive) return true;
  return ["out", "questionable", "doubtful", "ir", "inactive", "suspended", "pup"].some((flag) =>
    value.includes(flag)
  );
};

const getTeamLogoSrc = (abbrev: string | null | undefined) =>
  abbrev ? `/simulator/team-logos/${abbrev.toUpperCase()}.png` : "";
const getOperatorLogoSrc = (site: string | null | undefined) =>
  site ? `/simulator/operators/${site}.png` : "";
const formatGameDateShort = (game?: { startTime?: string | null } | null) => {
  const value = game?.startTime;
  if (!value) return "TBD";
  const date = new Date(value);
  return Number.isNaN(date.getTime())
    ? "TBD"
    : date.toLocaleDateString([], { month: "numeric", day: "numeric" });
};
const formatGameTimeEt = (game?: { startTime?: string | null } | null) => {
  const value = game?.startTime;
  if (!value) return "TBD";
  const date = new Date(value);
  return Number.isNaN(date.getTime())
    ? "TBD"
    : `${date.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })} ET`;
};
---

<Layout title="Simulator | Milly Maker Tracker">
  <section class="sim-page">
    <div class="sim-run-overlay" id="sim-run-overlay" aria-hidden="true">
      <div class="sim-run-card" role="status" aria-live="polite">
        <div class="sim-run-logo">
          <span class="sim-run-logo-glow" aria-hidden="true"></span>
          <span class="sim-run-logo-text">MMT</span>
        </div>
        <div class="sim-run-title">Simulating the Slate</div>
        <div class="sim-run-subtitle">Generating lineups and grading the field.</div>
        <div class="sim-run-status" id="sim-run-status">Starting simulation...</div>
        <div class="sim-run-bar" aria-hidden="true">
          <span></span>
        </div>
      </div>
    </div>
    <div class="sim-panel">
      <div class="top-row">
        <div class="brand-row">
          <h1 class="title">
            <span class="title-accent">MMT</span> Simulator
          </h1>
          <span class="week-text">{weekLabel}</span>
        </div>

        <div class="meta-block">
          <div class="meta-line">
            <span>{siteLabel} {selectedSlate?.name ?? "Unknown Slate"}</span>
            <span class="meta-sep">•</span>
            <span>{formatGameTypeLabel(selectedSlate)}</span>
            <span class="meta-sep">•</span>
            <span>{games.length} games</span>
            <span class="meta-sep">•</span>
            <span>Start time: {startTimeLabel}</span>
          </div>
        </div>
      </div>

      <div class="action-row">
        <button type="button" class="tool-btn tool-btn-secondary" id="sim-save-btn">SAVE</button>
        <button type="button" class="tool-btn tool-btn-secondary" id="sim-reset-btn">RESET ALL</button>
        <button type="button" class="tool-btn tool-btn-secondary" id="sim-run-btn">RUN SIMS</button>
        <button type="button" class="tool-btn tool-btn-primary">UPLOAD PROJECTIONS</button>
      </div>
      <div class="sim-status" id="sim-status" aria-live="polite"></div>
      <div class="sim-status sim-status-validation" id="sim-validation-summary" aria-live="polite"></div>

    <nav class="tabs" aria-label="Simulator sections">
      <a
        class:list={["tab-btn", { active: activeTab === "slates" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "slates",
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Slates
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "inputs" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "inputs",
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Inputs
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "settings" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "settings",
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Settings
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "results" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "results",
          subtabParam: activeSubtab,
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Results
      </a>
    </nav>

    {slateError && (
      <div class="section-head">
        <p class="empty-state">{slateError}</p>
      </div>
    )}

    {activeTab === "slates" && (
      <>
        <div class="section-head">
          <h2>Available Slates</h2>
        </div>
        <div class="filters">
          <div class="filters-left">
            <span class="filter-label">GameType:</span>
          <a
            class:list={["filter-btn", { active: activeGameType === "classic" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType === "classic" ? null : "classic",
              operator: activeOperator,
            })}
          >
            Classic
          </a>
          <a
            class:list={["filter-btn", { active: activeGameType === "showdown" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType === "showdown" ? null : "showdown",
              operator: activeOperator,
            })}
          >
            Showdown/MVP
          </a>
        </div>

        <div class="filters-right">
          <span class="filter-label">Operator:</span>
          <a
            class:list={["filter-btn", { active: activeOperator === "draftkings" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType,
              operator: activeOperator === "draftkings" ? null : "draftkings",
            })}
          >
            DraftKings
          </a>
          <a
            class:list={["filter-btn", { active: activeOperator === "fanduel" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType,
              operator: activeOperator === "fanduel" ? null : "fanduel",
            })}
          >
            FanDuel
          </a>
        </div>
      </div>

        <div class="table-area">
          <table class="slates-table">
            <thead>
              <tr>
                <th>Slate</th>
                <th>Operator</th>
                <th>Game Type</th>
                <th>Games</th>
                <th>Salary Cap</th>
                <th>Start Time</th>
              </tr>
            </thead>

            <tbody>
              {filteredSlates.length === 0 && (
                <tr>
                  <td colSpan={6}>No slates match the current filters.</td>
                </tr>
              )}
              {filteredSlates.map((entry) => {
                const { slate, key, gamesCount } = entry;
                const rowHref = buildSimulatorUrl({
                  slate: key,
                  tabParam: "inputs",
                  gameType: activeGameType,
                  operator: activeOperator,
                });
                return (
                <tr class="slate-row" data-href={rowHref} onclick="window.location.href=this.dataset.href">
                  <td>
                    <a
                      href={rowHref}
                      class:list={["slate-link", { active: key === activeSlateKey }]}
                    >
                      {slate.name}
                    </a>
                  </td>
                  <td>
                    <div class="operator-cell">
                      <img
                        src={`/simulator/operators/${slate.site}.png`}
                        alt={`${slate.site} logo`}
                        class="operator-logo"
                        loading="lazy"
                        onerror="this.style.display='none';"
                      />
                      <span class="operator-name">
                        {slate.site === "draftkings" ? "DraftKings" : "FanDuel"}
                      </span>
                    </div>
                  </td>
                  <td>{formatGameTypeLabel(slate)}</td>
                  <td>{gamesCount}</td>
                  <td>${slate.salaryCap.toLocaleString()}</td>
                  <td>{new Date(slate.startTime).toLocaleString()}</td>
                </tr>
              );
              })}
            </tbody>
          </table>
        </div>
      </>
    )}

    {activeTab === "inputs" && (
      <div class="inputs-panel">
        {games.length === 0 ? (
          <p class="empty-state">No games found for this slate.</p>
        ) : (
          <>
            {selectedGame && (
              <div class="section-head inputs-game-title">
                <h2>{selectedGame.gameLabel}</h2>
              </div>
            )}

            <nav class="inputs-slate-strip" aria-label="Slate game snapshot">
              {games.map((game) => {
                const cardTeamInputs = teamInputs.filter((input) => input.gameId === game.id);
                const cardAwayTeam = cardTeamInputs.find((input) => input.team === game.awayTeam) ?? null;
                const cardHomeTeam = cardTeamInputs.find((input) => input.team === game.homeTeam) ?? null;
                return (
                  <a
                    class:list={["inputs-slate-card", { active: game.id === activeGameId }]}
                    href={buildSimulatorUrl({
                      slate: activeSlateKey,
                      tabParam: "inputs",
                      gameType: activeGameType,
                      operator: activeOperator,
                      game: game.id,
                    })}
                  >
                    <div class="inputs-slate-card-rows">
                      <div class="inputs-slate-team-row">
                        <span class="inputs-slate-logo">
                          <img
                            src={getTeamLogoSrc(game.awayTeam)}
                            alt={`${game.awayTeam} logo`}
                            loading="lazy"
                            onload="this.nextElementSibling.style.display='none';"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                          />
                          <span class="inputs-slate-logo-fallback">{game.awayTeam}</span>
                        </span>
                        <span class="inputs-slate-team-code">{game.awayTeam}</span>
                        <span class="inputs-slate-team-total">{formatNumberCompact(cardAwayTeam?.pointsScored ?? null)}</span>
                      </div>
                      <div class="inputs-slate-team-row">
                        <span class="inputs-slate-logo">
                          <img
                            src={getTeamLogoSrc(game.homeTeam)}
                            alt={`${game.homeTeam} logo`}
                            loading="lazy"
                            onload="this.nextElementSibling.style.display='none';"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                          />
                          <span class="inputs-slate-logo-fallback">{game.homeTeam}</span>
                        </span>
                        <span class="inputs-slate-team-code">{game.homeTeam}</span>
                        <span class="inputs-slate-team-total">{formatNumberCompact(cardHomeTeam?.pointsScored ?? null)}</span>
                      </div>
                    </div>
                    <div class="inputs-slate-card-meta">
                      <span>{formatGameDateShort(game)}</span>
                      <span>{formatGameTimeEt(game)}</span>
                    </div>
                  </a>
                );
              })}
            </nav>

            <div class="inputs-team-stack">
              {[
                {
                  side: "Away",
                  teamCode: selectedGame?.awayTeam ?? "Away Team",
                  teamInput: awayTeamInputs,
                  players: awayPlayers,
                },
                {
                  side: "Home",
                  teamCode: selectedGame?.homeTeam ?? "Home Team",
                  teamInput: homeTeamInputs,
                  players: homePlayers,
                },
              ].map(({ side, teamCode, teamInput, players }) => (
                <section class="inputs-team-section">
                  <div class="inputs-team-head">
                    <div class="inputs-team-head-main">
                      <span class="team-logo team-logo-large">
                        <img
                          src={getTeamLogoSrc(teamCode)}
                          alt={`${teamCode} logo`}
                          loading="lazy"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                        />
                        <span class="team-logo-placeholder">{teamCode}</span>
                      </span>
                      <div>
                        <div class="inputs-team-kicker">{side}</div>
                        <h3>{teamCode}</h3>
                      </div>
                    </div>
                  </div>

                  <div class="team-validation" data-team-key={`team:${teamInput?.gameId ?? ""}:${teamInput?.team ?? ""}`}>
                    <div class="team-validation-title">Team Checks</div>
                    <div class="team-validation-messages"></div>
                  </div>

                  {teamInput ? (
                    <>
                      <div class="readonly-stat-row">
                        <div class="readonly-stat">
                          <span class="readonly-stat-label">Points Scored</span>
                          <span class="readonly-stat-value">{formatNumberCompact(teamInput.pointsScored)}</span>
                        </div>
                        <div class="readonly-stat">
                          <span class="readonly-stat-label">Pace</span>
                          <span class="readonly-stat-value">{formatNumberCompact(teamInput.pace)}</span>
                        </div>
                        <div class="readonly-stat">
                          <span class="readonly-stat-label">Rush Rate</span>
                          <span class="readonly-stat-value">{formatPct(teamInput.rushRate, 1, false)}</span>
                        </div>
                        <div class="readonly-stat">
                          <span class="readonly-stat-label">Rush TD Ratio</span>
                          <span class="readonly-stat-value">{formatPct(teamInput.rushTdRatio, 1, false)}</span>
                        </div>
                        <div class="readonly-stat">
                          <span class="readonly-stat-label">DST Salary</span>
                          <span class="readonly-stat-value">{formatCurrencyCompact(teamInput.dstSalary)}</span>
                        </div>
                        <div class="readonly-stat">
                          <span class="readonly-stat-label">Sack Rate</span>
                          <span class="readonly-stat-value">{formatPct(teamInput.sackRate, 1, false)}</span>
                        </div>
                      </div>

                      <div class="readonly-table-wrap table-area">
                        <table class="readonly-table">
                          <thead>
                            <tr class="metric-group-row">
                              <th colSpan={6}></th>
                              <th colSpan={2}>Rushing</th>
                              <th colSpan={3}>Receiving</th>
                              <th colSpan={2}>Passing</th>
                            </tr>
                            <tr>
                              <th class="injury-cell"></th>
                              <th>Pos</th>
                              <th>Player</th>
                              <th>Salary</th>
                              <th>Proj</th>
                              <th>Own</th>
                              <th>Rushing Mkt Share</th>
                              <th>Rushing TD Mkt Share</th>
                              <th>Receiving Mkt Share</th>
                              <th>Receiving TD Mkt Share</th>
                              <th>Catch Rate</th>
                              <th>Passing Mkt Share</th>
                              <th>Int Rate</th>
                            </tr>
                          </thead>
                          <tbody>
                            {players.map((player) => (
                              <tr>
                                <td class="injury-cell">
                                  {isInjuredPlayer(player) && (
                                    <span class="injury-icon" aria-label="Injury status">
                                      <svg viewBox="0 0 16 16" aria-hidden="true">
                                        <path d="M8 1.5 1.75 14h12.5L8 1.5Zm0 3.1 1.74 4.07H6.26L8 4.6Zm0 6.43a.92.92 0 1 1 0 1.84.92.92 0 0 1 0-1.84Z"></path>
                                      </svg>
                                    </span>
                                  )}
                                </td>
                                <td><span class="value-chip">{player.position || "—"}</span></td>
                                <td class="player-name-cell">{player.name || "—"}</td>
                                <td><span class="value-chip">{formatCurrencyCompact(player.salary)}</span></td>
                                <td><span class="value-chip">{formatNumberCompact(player.projection)}</span></td>
                                <td><span class="value-chip">{formatPct(player.ownership)}</span></td>
                                <td><span class="value-chip">{formatPct(player.rushMarketShare)}</span></td>
                                <td><span class="value-chip">{formatPct(player.rushTdMarketShare)}</span></td>
                                <td><span class="value-chip">{formatPct(player.receivingMarketShare)}</span></td>
                                <td><span class="value-chip">{formatPct(player.receivingTdMarketShare)}</span></td>
                                <td><span class="value-chip">{formatPct(player.catchRate)}</span></td>
                                <td><span class="value-chip">{formatPct(player.passMarketShare)}</span></td>
                                <td><span class="value-chip">{formatPct(player.intRate)}</span></td>
                              </tr>
                            ))}
                            {players.length === 0 && (
                              <tr>
                                <td colSpan={13}>No players found.</td>
                              </tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                    </>
                  ) : (
                    <p class="empty-state">No team inputs found.</p>
                  )}
                </section>
              ))}
            </div>
          </>
