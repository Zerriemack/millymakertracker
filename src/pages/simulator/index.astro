    `;

    const filterRowHtml =
      SIM_ACTIVE_SUBTAB === "ev" || SIM_ACTIVE_SUBTAB === "exp"
        ? `
      <div class="results-filter-row" data-pos-filter>
        <span class="results-filter-label">Position</span>
        <div class="results-filter-group">
          <button type="button" class="results-filter-btn active" data-pos="ALL">ALL</button>
          <button type="button" class="results-filter-btn" data-pos="QB">QB</button>
          <button type="button" class="results-filter-btn" data-pos="RB">RB</button>
          <button type="button" class="results-filter-btn" data-pos="WR">WR</button>
          <button type="button" class="results-filter-btn" data-pos="TE">TE</button>
          <button type="button" class="results-filter-btn" data-pos="DST">DST</button>
        </div>
      </div>
    `
        : "";

    const buildEvRows = () => {
      const rows = resultsPayload.players
        .slice()
        .sort(
          (a, b) =>
            b.optimalSimRate - a.optimalSimRate ||
            b.plusEvScore - a.plusEvScore ||
            b.optimalLeverage - a.optimalLeverage
        )
        .map((row) => {
          const levValue = Math.abs(row.optimalLeverage) >= 10 ? row.optimalLeverage / 10 : row.optimalLeverage;
          return `
            <tr
              data-pos="${escapeHtml(row.position)}"
              data-name="${escapeHtml(row.name)}"
              data-position="${escapeHtml(row.position)}"
              data-team="${escapeHtml(row.team)}"
