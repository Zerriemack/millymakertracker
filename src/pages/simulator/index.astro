---
import Layout from "../../layouts/Layout.astro";
import { listSlatePackages } from "../../lib/simulator/listSlatePackages";
import { loadSlatePackage } from "../../lib/simulator/loadSlatePackage";
import { loadJson } from "../../lib/simulator/loadJson";
import { resolveSlatePackagePath } from "../../lib/simulator/paths";
import type { SimulatorSlatePackage } from "../../lib/simulator/types";
import path from "path";

const tab = (Astro.url.searchParams.get("tab") || "slates").toLowerCase();
const subtab = (Astro.url.searchParams.get("subtab") || "ev").toLowerCase();
const slateParam = Astro.url.searchParams.get("slate");
const gameParam = Astro.url.searchParams.get("game");
const gameTypeParam = Astro.url.searchParams.get("gameType");
const operatorParam = Astro.url.searchParams.get("operator");

const validTabs = ["slates", "inputs", "settings", "results"];
const activeTab = validTabs.includes(tab) ? tab : "slates";
const validSubtabs = ["ev", "exp", "graded"];
const activeSubtab = validSubtabs.includes(subtab) ? subtab : "ev";
const validGameTypes = ["classic", "showdown"];
const activeGameType =
  gameTypeParam && validGameTypes.includes(gameTypeParam.toLowerCase())
    ? gameTypeParam.toLowerCase()
    : null;
const validOperators = ["draftkings", "fanduel"];
const activeOperator =
  operatorParam && validOperators.includes(operatorParam.toLowerCase())
    ? operatorParam.toLowerCase()
    : null;

const slateKeys = await listSlatePackages();
const defaultSlateKey = slateKeys[0] ?? null;
const requestedSlateKey = slateParam ?? defaultSlateKey;

let selectedPackage: SimulatorSlatePackage | null = null;
let slateError: string | null = null;

if (requestedSlateKey) {
  try {
    selectedPackage = await loadSlatePackage(requestedSlateKey);
  } catch (error) {
    slateError = `Slate package not found for key "${requestedSlateKey}".`;
  }
} else {
  slateError = "No slate packages are available.";
}

const slatePackages = await Promise.all(
  slateKeys.map(async (key) => {
    try {
      const pkg = await loadSlatePackage(key);
      return { key, ...pkg };
    } catch (error) {
      return null;
    }
  })
);

const availableSlates = slatePackages.filter(Boolean) as Array<
  SimulatorSlatePackage & { key: string }
>;

const slates = availableSlates
  .map((pkg) => ({
    key: pkg.key,
    slate: pkg.slate,
    gamesCount: pkg.games.length,
  }))
  .filter((entry) => entry.slate.sport === "nfl");

const filteredSlates = slates.filter(({ slate }) => {
  const slateGameType = slate.gameType.toLowerCase();
  const matchesGameType = activeGameType ? slateGameType === activeGameType : true;
  const matchesOperator = activeOperator ? slate.site === activeOperator : true;
  return matchesGameType && matchesOperator;
});

const selectedSlate = selectedPackage?.slate ?? null;
const activeSlateKey = requestedSlateKey ?? "";
const games = selectedPackage?.games ?? [];
const teamInputs = selectedPackage?.teamInputs ?? [];
const playerInputs = selectedPackage?.playerInputs ?? [];
const settings = selectedPackage?.settings
  ? {
      ...selectedPackage.settings,
      payoutProfile: selectedPackage.settings.payoutProfile ?? "standard",
      gradingFieldMode: selectedPackage.settings.gradingFieldMode ?? "expandedField",
      gradingFieldSize: selectedPackage.settings.gradingFieldSize ?? selectedPackage.settings.fieldSize,
      gradingFieldExtraLineupCount:
        selectedPackage.settings.gradingFieldExtraLineupCount ?? Math.max(selectedPackage.settings.lineupCount, 300),
    }
  : null;
let results: {
  slateId: string;
  generatedAt: string;
  simulationCount: number;
  settingsSnapshot: {
    lineupCount: number;
    fieldSize: number;
    simulationCount: number;
    salaryCap: number;
    payoutProfile?: "topHeavy" | "standard" | "flat";
    gradingFieldMode?: "retainedOnly" | "expandedField";
    gradingFieldSize?: number;
    gradingFieldExtraLineupCount?: number;
  };
  players: Array<{
    id: string;
    name: string;
    team: string;
    position: string;
    salary: number;
    projection: number;
    ownership: number;
    optimalLineupCount: number;
    optimalSimRate: number;
    optimalLeverage: number;
    averageSimScore: number;
    maxSimScore: number;
    retainedLineupCount: number;
    retainedExposureRate: number;
    filteredLineupCount: number;
    filteredExposureRate: number;
    plusEvScore: number;
    minusEvScore: number;
  }>;
  lineups?: Array<{
    lineupKey: string;
    players: Array<{
      id: string;
      name: string;
      team: string;
      position: string;
      salary: number;
      ownership: number;
    }>;
    salaryUsed: number;
    sumOwnership: number;
    frequencyCount: number;
    frequencyRate: number;
    averageSimTotal: number;
    maxSimTotal: number;
    averageOptimalRate: number;
    passedFilters: boolean;
    topPointOnePctRate?: number;
    topOnePctRate?: number;
    itmRate?: number;
    evScore?: number;
  }>;
  poolSummary?: {
    distinctLineupCount: number;
    retainedLineupCount: number;
    filteredLineupCount: number;
  };
  gradingSummary?: {
    gradingFieldMode: "retainedOnly" | "expandedField";
    gradingFieldSize: number;
    gradingUniverseSize: number;
    retainedPoolSize: number;
    filteredPoolSize: number;
    gradingFieldExtraLineupCount: number;
    payoutProfile: "topHeavy" | "standard" | "flat";
  };
} | null = null;

if (selectedPackage && activeSlateKey) {
  try {
    const resultsPath = path.join(resolveSlatePackagePath(activeSlateKey), "results.json");
    results = await loadJson(resultsPath);
  } catch (error) {
    results = null;
  }
}

const activeGameId = gameParam && games.some((game) => game.id === gameParam)
  ? gameParam
  : games[0]?.id ?? null;
const selectedGame = games.find((game) => game.id === activeGameId) ?? null;
const selectedGameTeamInputs = teamInputs.filter((input) => input.gameId === activeGameId);
const awayTeamInputs = selectedGameTeamInputs.find((input) => input.team === selectedGame?.awayTeam) ?? null;
const homeTeamInputs = selectedGameTeamInputs.find((input) => input.team === selectedGame?.homeTeam) ?? null;
const awayPlayers = playerInputs.filter(
  (player) => player.gameId === activeGameId && player.team === selectedGame?.awayTeam
);
const homePlayers = playerInputs.filter(
  (player) => player.gameId === activeGameId && player.team === selectedGame?.homeTeam
);
const siteLabel =
  selectedSlate?.site === "draftkings"
    ? "DraftKings"
    : selectedSlate?.site === "fanduel"
      ? "FanDuel"
      : selectedSlate?.site
        ? selectedSlate.site.toUpperCase()
        : "DraftKings";
const formatGameTypeLabel = (slate?: { site?: string; gameType?: string } | null) => {
  if (!slate?.gameType) return "Classic";
  const gameType = slate.gameType;
  if (slate.site === "fanduel" && gameType.toLowerCase() === "showdown") {
    return "MVP";
  }
  return gameType;
};

const buildSimulatorUrl = ({
  slate,
  tabParam,
  subtabParam,
  gameType,
  operator,
  game,
}: {
  slate?: string | null;
  tabParam?: string | null;
  subtabParam?: string | null;
  gameType?: string | null;
  operator?: string | null;
  game?: string | null;
}) => {
  const params = new URLSearchParams();
  if (slate) params.set("slate", slate);
  if (tabParam) params.set("tab", tabParam);
  if (subtabParam) params.set("subtab", subtabParam);
  if (gameType) params.set("gameType", gameType);
  if (operator) params.set("operator", operator);
  if (game) params.set("game", game);
  const query = params.toString();
  return query ? `/simulator?${query}` : "/simulator";
};

const weekLabel = selectedSlate ? `Week ${selectedSlate.week}` : "Week";
const startTimeLabel = selectedSlate?.startTime
  ? new Date(selectedSlate.startTime).toLocaleString()
  : "TBD";
---

<Layout title="Simulator | Milly Maker Tracker">
  <section class="sim-page">
    <div class="sim-panel">
      <div class="top-row">
        <div class="brand-row">
          <h1 class="title">
            <span class="title-accent">MMT</span> Simulator
          </h1>
          <span class="week-text">{weekLabel}</span>
        </div>

        <div class="meta-block">
          <div class="meta-line">
            <span>{siteLabel} {selectedSlate?.name ?? "Unknown Slate"}</span>
            <span class="meta-sep">•</span>
            <span>{formatGameTypeLabel(selectedSlate)}</span>
            <span class="meta-sep">•</span>
            <span>{games.length} games</span>
            <span class="meta-sep">•</span>
            <span>Start time: {startTimeLabel}</span>
          </div>
        </div>
      </div>

      <div class="action-row">
        <button type="button" class="tool-btn tool-btn-secondary" id="sim-save-btn">SAVE</button>
        <button type="button" class="tool-btn tool-btn-secondary" id="sim-reset-btn">RESET ALL</button>
        <button type="button" class="tool-btn tool-btn-secondary" id="sim-run-btn">RUN SIMS</button>
        <button type="button" class="tool-btn tool-btn-primary">UPLOAD PROJECTIONS</button>
      </div>
      <div class="sim-status" id="sim-status" aria-live="polite"></div>
      <div class="sim-status sim-status-validation" id="sim-validation-summary" aria-live="polite"></div>

    <nav class="tabs" aria-label="Simulator sections">
      <a
        class:list={["tab-btn", { active: activeTab === "slates" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "slates",
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Slates
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "inputs" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "inputs",
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Inputs
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "settings" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "settings",
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Settings
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "results" }]}
        href={buildSimulatorUrl({
          slate: activeSlateKey,
          tabParam: "results",
          subtabParam: activeSubtab,
          gameType: activeGameType,
          operator: activeOperator,
          game: activeGameId,
        })}
      >
        Results
      </a>
    </nav>

    {slateError && (
      <div class="section-head">
        <p class="empty-state">{slateError}</p>
      </div>
    )}

    <div class="section-head">
      <h2>Available Slates</h2>
    </div>

    {activeTab === "slates" && (
      <>
        <div class="filters">
          <div class="filters-left">
            <span class="filter-label">GameType:</span>
          <a
            class:list={["filter-btn", { active: activeGameType === "classic" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType === "classic" ? null : "classic",
              operator: activeOperator,
            })}
          >
            Classic
          </a>
          <a
            class:list={["filter-btn", { active: activeGameType === "showdown" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType === "showdown" ? null : "showdown",
              operator: activeOperator,
            })}
          >
            Showdown/MVP
          </a>
        </div>

        <div class="filters-right">
          <span class="filter-label">Operator:</span>
          <a
            class:list={["filter-btn", { active: activeOperator === "draftkings" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType,
              operator: activeOperator === "draftkings" ? null : "draftkings",
            })}
          >
            DraftKings
          </a>
          <a
            class:list={["filter-btn", { active: activeOperator === "fanduel" }]}
            href={buildSimulatorUrl({
              slate: activeSlateKey,
              tabParam: "slates",
              gameType: activeGameType,
              operator: activeOperator === "fanduel" ? null : "fanduel",
            })}
          >
            FanDuel
          </a>
        </div>
      </div>

        <div class="table-area">
          <table class="slates-table">
            <thead>
              <tr>
                <th>Slate</th>
                <th>Operator</th>
                <th>Game Type</th>
                <th>Games</th>
                <th>Salary Cap</th>
                <th>Start Time</th>
              </tr>
            </thead>

            <tbody>
              {filteredSlates.length === 0 && (
                <tr>
                  <td colSpan={6}>No slates match the current filters.</td>
                </tr>
              )}
              {filteredSlates.map((entry) => {
                const { slate, key, gamesCount } = entry;
                const rowHref = buildSimulatorUrl({
                  slate: key,
                  tabParam: "inputs",
                  gameType: activeGameType,
                  operator: activeOperator,
                });
                return (
                <tr class="slate-row" data-href={rowHref} onclick="window.location.href=this.dataset.href">
                  <td>
                    <a
                      href={rowHref}
                      class:list={["slate-link", { active: key === activeSlateKey }]}
                    >
                      {slate.name}
                    </a>
                  </td>
                  <td>
                    <div class="operator-cell">
                      <img
                        src={`/simulator/operators/${slate.site}.png`}
                        alt={`${slate.site} logo`}
                        class="operator-logo"
                        loading="lazy"
                        onerror="this.style.display='none';"
                      />
                      <span class="operator-name">
                        {slate.site === "draftkings" ? "DraftKings" : "FanDuel"}
                      </span>
                    </div>
                  </td>
                  <td>{formatGameTypeLabel(slate)}</td>
                  <td>{gamesCount}</td>
                  <td>${slate.salaryCap.toLocaleString()}</td>
                  <td>{new Date(slate.startTime).toLocaleString()}</td>
                </tr>
              );
              })}
            </tbody>
          </table>
        </div>
      </>
    )}

    {activeTab === "inputs" && (
      <div class="inputs-panel">
        {games.length === 0 ? (
          <p class="empty-state">No games found for this slate.</p>
        ) : (
          <>
            <nav class="subtabs" aria-label="Slate games">
              {games.map((game) => (
                <a
                  class:list={["subtab", { active: game.id === activeGameId }]}
                  href={buildSimulatorUrl({
                    slate: activeSlateKey,
                    tabParam: "inputs",
                    gameType: activeGameType,
                    operator: activeOperator,
                    game: game.id,
                  })}
                >
                  {game.gameLabel}
                </a>
              ))}
            </nav>

            {selectedGame && (
              <div class="section-head">
                <h2>{selectedGame.gameLabel}</h2>
              </div>
            )}

            <div class="inputs-team-grid">
              <div class="settings-panel">
                <h3>{selectedGame?.awayTeam ?? "Away Team"}</h3>
                <div class="team-validation" data-team-key={`team:${awayTeamInputs?.gameId ?? ""}:${awayTeamInputs?.team ?? ""}`}>
                  <div class="team-validation-title">Team Checks</div>
                  <div class="team-validation-messages"></div>
                </div>
                {awayTeamInputs ? (
                  <dl class="settings-list">
                    <div>
                      <dt>Points</dt>
                      <dd>
                        <input
                          type="number"
                          step="0.1"
                          value={awayTeamInputs.pointsScored}
                          data-kind="team"
                          data-game-id={awayTeamInputs.gameId}
                          data-team={awayTeamInputs.team}
                          data-field="pointsScored"
                          data-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:pointsScored`}
                        />
                        <span class="field-error" data-error-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:pointsScored`}></span>
                      </dd>
                    </div>
                    <div>
                      <dt>Pace</dt>
                      <dd>
                        <input
                          type="number"
                          step="0.1"
                          value={awayTeamInputs.pace}
                          data-kind="team"
                          data-game-id={awayTeamInputs.gameId}
                          data-team={awayTeamInputs.team}
                          data-field="pace"
                          data-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:pace`}
                        />
                        <span class="field-error" data-error-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:pace`}></span>
                      </dd>
                    </div>
                    <div>
                      <dt>Rush Rate</dt>
                      <dd>
                        <input
                          type="number"
                          step="0.1"
                          value={(awayTeamInputs.rushRate * 100).toFixed(1)}
                          data-kind="team"
                          data-game-id={awayTeamInputs.gameId}
                          data-team={awayTeamInputs.team}
                          data-field="rushRate"
                          data-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:rushRate`}
                        />
                        <span class="field-error" data-error-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:rushRate`}></span>
                      </dd>
                    </div>
                    <div>
                      <dt>Rush TD Ratio</dt>
                      <dd>
                        <input
                          type="number"
                          step="0.1"
                          value={(awayTeamInputs.rushTdRatio * 100).toFixed(1)}
                          data-kind="team"
                          data-game-id={awayTeamInputs.gameId}
                          data-team={awayTeamInputs.team}
                          data-field="rushTdRatio"
                          data-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:rushTdRatio`}
                        />
                        <span class="field-error" data-error-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:rushTdRatio`}></span>
                      </dd>
                    </div>
                    <div>
                      <dt>DST Salary</dt>
                      <dd>
                        <input
                          type="number"
                          step="1"
                          value={awayTeamInputs.dstSalary}
                          data-kind="team"
                          data-game-id={awayTeamInputs.gameId}
                          data-team={awayTeamInputs.team}
                          data-field="dstSalary"
                          data-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:dstSalary`}
                        />
                        <span class="field-error" data-error-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:dstSalary`}></span>
                      </dd>
                    </div>
                    <div>
                      <dt>Sack Rate</dt>
                      <dd>
                        <input
                          type="number"
                          step="0.1"
                          value={(awayTeamInputs.sackRate * 100).toFixed(1)}
                          data-kind="team"
                          data-game-id={awayTeamInputs.gameId}
                          data-team={awayTeamInputs.team}
                          data-field="sackRate"
                          data-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:sackRate`}
                        />
                        <span class="field-error" data-error-key={`team:${awayTeamInputs.gameId}:${awayTeamInputs.team}:sackRate`}></span>
                      </dd>
                    </div>
                  </dl>
                ) : (
                  <p class="empty-state">No team inputs found.</p>
                )}

                <div class="table-area">
                  <table class="slates-table">
                    <thead>
                      <tr>
                        <th>Name</th>
                        <th>Team</th>
                        <th>Pos</th>
                        <th>Salary</th>
                        <th>Proj</th>
                        <th>Own%</th>
                        <th>Rush MS</th>
                        <th>Rush TD MS</th>
                        <th>Rec MS</th>
                        <th>Rec TD MS</th>
                        <th>Catch%</th>
                        <th>Pass MS</th>
                        <th>INT%</th>
                      </tr>
                    </thead>
                    <tbody>
                      {awayPlayers.map((player) => (
                        <tr>
                          <td>{player.name}</td>
                          <td>{player.team}</td>
                          <td>{player.position}</td>
                          <td>${player.salary.toLocaleString()}</td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.projection}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="projection"
                              data-key={`player:${player.id}:projection`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:projection`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.ownership}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="ownership"
                              data-key={`player:${player.id}:ownership`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:ownership`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.rushMarketShare}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="rushMarketShare"
                              data-key={`player:${player.id}:rushMarketShare`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:rushMarketShare`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.rushTdMarketShare}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="rushTdMarketShare"
                              data-key={`player:${player.id}:rushTdMarketShare`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:rushTdMarketShare`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.receivingMarketShare}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="receivingMarketShare"
                              data-key={`player:${player.id}:receivingMarketShare`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:receivingMarketShare`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.receivingTdMarketShare}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="receivingTdMarketShare"
                              data-key={`player:${player.id}:receivingTdMarketShare`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:receivingTdMarketShare`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.catchRate}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="catchRate"
                              data-key={`player:${player.id}:catchRate`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:catchRate`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.passMarketShare}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="passMarketShare"
                              data-key={`player:${player.id}:passMarketShare`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:passMarketShare`}></span>
                          </td>
                          <td>
                            <input
                              type="number"
                              step="0.1"
                              value={player.intRate}
                              data-kind="player"
                              data-player-id={player.id}
                              data-field="intRate"
                              data-key={`player:${player.id}:intRate`}
                            />
                            <span class="field-error" data-error-key={`player:${player.id}:intRate`}></span>
                          </td>
                        </tr>
                      ))}
                      {awayPlayers.length === 0 && (
                        <tr>
                          <td colSpan={13}>No players found.</td>
                        </tr>
                      )}
                    </tbody>
