---
import Layout from "../../layouts/Layout.astro";
import { mockSlates, getSlateById } from "../../data/simulator/mockSlates";
import { getPlayersBySlate } from "../../data/simulator/mockPlayers";
import { getSettingsBySlate } from "../../data/simulator/mockSettings";
import { getResultsBySlate } from "../../data/simulator/mockResults";

const weekLabel = "Week 2";

const tab = (Astro.url.searchParams.get("tab") || "slates").toLowerCase();
const subtab = (Astro.url.searchParams.get("subtab") || "ev").toLowerCase();
const slateParam = Astro.url.searchParams.get("slate") || "3-game-main";
const gameTypeParam = Astro.url.searchParams.get("gameType");
const operatorParam = Astro.url.searchParams.get("operator");

const validTabs = ["slates", "inputs", "settings", "results"];
const activeTab = validTabs.includes(tab) ? tab : "slates";
const validSubtabs = ["ev", "exp", "graded"];
const activeSubtab = validSubtabs.includes(subtab) ? subtab : "ev";
const validGameTypes = ["classic", "showdown"];
const activeGameType =
  gameTypeParam && validGameTypes.includes(gameTypeParam.toLowerCase())
    ? gameTypeParam.toLowerCase()
    : null;
const validOperators = ["draftkings", "fanduel"];
const activeOperator =
  operatorParam && validOperators.includes(operatorParam.toLowerCase())
    ? operatorParam.toLowerCase()
    : null;

const slates = mockSlates.filter((slate) => slate.sport === "nfl");
const filteredSlates = slates.filter((slate) => {
  const slateGameType = slate.gameType.toLowerCase();
  const matchesGameType = activeGameType ? slateGameType === activeGameType : true;
  const matchesOperator = activeOperator ? slate.site === activeOperator : true;
  return matchesGameType && matchesOperator;
});
const selectedSlate = getSlateById(slateParam) ?? getSlateById("3-game-main");
const activeSlateId = selectedSlate?.id ?? "3-game-main";
const players = getPlayersBySlate(activeSlateId);
const settings = getSettingsBySlate(activeSlateId);
const results = getResultsBySlate(activeSlateId);
const siteLabel =
  selectedSlate?.site === "draftkings"
    ? "DraftKings"
    : selectedSlate?.site === "fanduel"
      ? "FanDuel"
      : selectedSlate?.site
        ? selectedSlate.site.toUpperCase()
        : "DraftKings";
const formatGameTypeLabel = (slate?: { site?: string; gameType?: string } | null) => {
  if (!slate?.gameType) return "Classic";
  const gameType = slate.gameType;
  if (slate.site === "fanduel" && gameType.toLowerCase() === "showdown") {
    return "MVP";
  }
  return gameType;
};

const buildSimulatorUrl = ({
  slate,
  tabParam,
  subtabParam,
  gameType,
  operator,
}: {
  slate?: string | null;
  tabParam?: string | null;
  subtabParam?: string | null;
  gameType?: string | null;
  operator?: string | null;
}) => {
  const params = new URLSearchParams();
  if (slate) params.set("slate", slate);
  if (tabParam) params.set("tab", tabParam);
  if (subtabParam) params.set("subtab", subtabParam);
  if (gameType) params.set("gameType", gameType);
  if (operator) params.set("operator", operator);
  const query = params.toString();
  return query ? `/simulator?${query}` : "/simulator";
};

const topTabs = [
  "Slates",
  "Inputs",
  "Settings",
  "Optimal Results",
  "Your Custom Lineups",
  "Your Projections",
];

const activeTopTab = activeTab === "results" ? "Results" : activeTab.charAt(0).toUpperCase() + activeTab.slice(1);
---

<Layout title="Simulator | Milly Maker Tracker">
  <section class="sim-page">
    <div class="sim-panel">
      <div class="top-row">
        <div class="brand-row">
          <h1 class="title">
            <span class="title-accent">MMT</span> Simulator
          </h1>
          <span class="week-text">{weekLabel}</span>
        </div>

        <div class="meta-block">
          <div class="meta-line">
            <span>{siteLabel} {selectedSlate?.name ?? "3 Game Main"}</span>
            <span class="meta-sep">•</span>
            <span>{formatGameTypeLabel(selectedSlate)}</span>
            <span class="meta-sep">•</span>
            <span>{selectedSlate?.games ?? 3} games</span>
            <span class="meta-sep">•</span>
            <span>Start time: {selectedSlate?.startTime ?? "TBD"}</span>
          </div>
        </div>
      </div>

      <div class="action-row">
        <button type="button" class="tool-btn tool-btn-secondary">SAVE</button>
        <a class="tool-btn tool-btn-secondary" href="/simulator?slate=3-game-main&tab=slates">RESET ALL</a>
        <button type="button" class="tool-btn tool-btn-primary">UPLOAD PROJECTIONS</button>
      </div>

    <nav class="tabs" aria-label="Simulator sections">
      <a
        class:list={["tab-btn", { active: activeTab === "slates" }]}
        href={buildSimulatorUrl({
          slate: activeSlateId,
          tabParam: "slates",
          gameType: activeGameType,
          operator: activeOperator,
        })}
      >
        Slates
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "inputs" }]}
        href={buildSimulatorUrl({
          slate: activeSlateId,
          tabParam: "inputs",
          gameType: activeGameType,
          operator: activeOperator,
        })}
      >
        Inputs
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "settings" }]}
        href={buildSimulatorUrl({
          slate: activeSlateId,
          tabParam: "settings",
          gameType: activeGameType,
          operator: activeOperator,
        })}
      >
        Settings
      </a>
      <a
        class:list={["tab-btn", { active: activeTab === "results" }]}
        href={buildSimulatorUrl({
          slate: activeSlateId,
          tabParam: "results",
          subtabParam: activeSubtab,
          gameType: activeGameType,
          operator: activeOperator,
        })}
      >
        Results
      </a>
    </nav>

    <div class="section-head">
      <h2>Available Slates</h2>
    </div>

    {activeTab === "slates" && (
      <>
        <div class="filters">
          <div class="filters-left">
            <span class="filter-label">GameType:</span>
          <a
            class:list={["filter-btn", { active: activeGameType === "classic" }]}
            href={buildSimulatorUrl({
              slate: activeSlateId,
              tabParam: "slates",
              gameType: activeGameType === "classic" ? null : "classic",
              operator: activeOperator,
            })}
          >
            Classic
          </a>
          <a
            class:list={["filter-btn", { active: activeGameType === "showdown" }]}
            href={buildSimulatorUrl({
              slate: activeSlateId,
              tabParam: "slates",
              gameType: activeGameType === "showdown" ? null : "showdown",
              operator: activeOperator,
            })}
          >
            Showdown/MVP
          </a>
        </div>

        <div class="filters-right">
          <span class="filter-label">Operator:</span>
          <a
            class:list={["filter-btn", { active: activeOperator === "draftkings" }]}
            href={buildSimulatorUrl({
              slate: activeSlateId,
              tabParam: "slates",
              gameType: activeGameType,
              operator: activeOperator === "draftkings" ? null : "draftkings",
            })}
          >
            DraftKings
          </a>
          <a
            class:list={["filter-btn", { active: activeOperator === "fanduel" }]}
            href={buildSimulatorUrl({
              slate: activeSlateId,
              tabParam: "slates",
              gameType: activeGameType,
              operator: activeOperator === "fanduel" ? null : "fanduel",
            })}
          >
            FanDuel
          </a>
        </div>
      </div>

        <div class="table-area">
          <table class="slates-table">
            <thead>
              <tr>
                <th>Slate</th>
                <th>Operator</th>
                <th>Game Type</th>
                <th>Games</th>
                <th>Salary Cap</th>
                <th>Start Time</th>
              </tr>
            </thead>

            <tbody>
              {filteredSlates.length === 0 && (
                <tr>
                  <td colSpan={6}>No slates match the current filters.</td>
                </tr>
              )}
              {filteredSlates.map((slate) => {
                const rowHref = buildSimulatorUrl({
                  slate: slate.id,
                  tabParam: "inputs",
                  gameType: activeGameType,
                  operator: activeOperator,
                });
                return (
                <tr class="slate-row" data-href={rowHref} onclick="window.location.href=this.dataset.href">
                  <td>
                    <a
                      href={rowHref}
                      class:list={["slate-link", { active: slate.id === activeSlateId }]}
                    >
                      {slate.name}
                    </a>
                  </td>
                  <td>
                    <div class="operator-cell">
                      <img
                        src={`/simulator/operators/${slate.site}.png`}
                        alt={`${slate.site} logo`}
                        class="operator-logo"
                        loading="lazy"
                        onerror="this.style.display='none';"
                      />
                      <span class="operator-name">
                        {slate.site === "draftkings" ? "DraftKings" : "FanDuel"}
                      </span>
                    </div>
                  </td>
                  <td>{formatGameTypeLabel(slate)}</td>
                  <td>{slate.games}</td>
                  <td>${slate.salaryCap.toLocaleString()}</td>
                  <td>{new Date(slate.startTime).toLocaleString()}</td>
                </tr>
              );
              })}
            </tbody>
          </table>
        </div>
      </>
    )}

    {activeTab === "inputs" && (
      <div class="table-area">
        <table class="slates-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Team</th>
              <th>Pos</th>
              <th>Salary</th>
              <th>Proj</th>
              <th>Own%</th>
            </tr>
          </thead>
          <tbody>
            {players.map((player) => (
              <tr>
                <td>{player.name}</td>
                <td>{player.team}</td>
                <td>{player.position}</td>
                <td>${player.salary.toLocaleString()}</td>
                <td>{player.projection.toFixed(1)}</td>
                <td>{player.ownership.toFixed(1)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {activeTab === "settings" && (
      <div class="settings-panel">
        {settings ? (
          <dl class="settings-list">
            <div>
              <dt>Lineups</dt>
              <dd>{settings.lineupCount}</dd>
            </div>
            <div>
              <dt>Field Size</dt>
              <dd>{settings.fieldSize.toLocaleString()}</dd>
            </div>
            <div>
              <dt>Simulations</dt>
              <dd>{settings.simulationCount.toLocaleString()}</dd>
            </div>
            <div>
              <dt>Salary Cap</dt>
              <dd>${settings.salaryCap.toLocaleString()}</dd>
            </div>
          </dl>
        ) : (
          <p class="empty-state">No settings found for this slate.</p>
        )}
      </div>
    )}

    {activeTab === "results" && (
      <div class="results-panel">
        <nav class="subtabs" aria-label="Results subtabs">
          <a
            class:list={["subtab", { active: activeSubtab === "ev" }]}
            href={buildSimulatorUrl({
              slate: activeSlateId,
              tabParam: "results",
              subtabParam: "ev",
              gameType: activeGameType,
              operator: activeOperator,
            })}
          >
            Plus EV
          </a>
          <a
            class:list={["subtab", { active: activeSubtab === "exp" }]}
            href={buildSimulatorUrl({
              slate: activeSlateId,
              tabParam: "results",
              subtabParam: "exp",
              gameType: activeGameType,
              operator: activeOperator,
            })}
          >
            Exposure
          </a>
          <a
            class:list={["subtab", { active: activeSubtab === "graded" }]}
            href={buildSimulatorUrl({
              slate: activeSlateId,
              tabParam: "results",
              subtabParam: "graded",
              gameType: activeGameType,
              operator: activeOperator,
            })}
          >
            Graded
          </a>
        </nav>

        {activeSubtab === "ev" && (
          <div class="table-area">
            <table class="slates-table">
              <thead>
                <tr>
                  <th>Player</th>
                  <th>Team</th>
                  <th>Pos</th>
                  <th>EV</th>
                </tr>
              </thead>
              <tbody>
                {results?.plusEv.map((row) => (
                  <tr>
                    <td>{row.name}</td>
                    <td>{row.team}</td>
                    <td>{row.position}</td>
                    <td>{row.ev.toFixed(1)}</td>
                  </tr>
                )) ?? (
                  <tr>
                    <td colSpan={4}>No results.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        )}

        {activeSubtab === "exp" && (
          <div class="table-area">
            <table class="slates-table">
              <thead>
                <tr>
                  <th>Player</th>
                  <th>Exposure</th>
                </tr>
              </thead>
              <tbody>
                {results?.exposures.map((row) => (
                  <tr>
                    <td>{row.name}</td>
                    <td>{row.exposure}%</td>
                  </tr>
                )) ?? (
                  <tr>
                    <td colSpan={2}>No exposures.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        )}

        {activeSubtab === "graded" && (
          <div class="table-area">
            <table class="slates-table">
              <thead>
                <tr>
                  <th>Lineup</th>
                  <th>Projected</th>
                  <th>Grade</th>
                </tr>
              </thead>
              <tbody>
                {results?.gradedLineups.map((row) => (
                  <tr>
                    <td>{row.lineup}</td>
                    <td>{row.projected.toFixed(1)}</td>
                    <td>{row.grade}</td>
                  </tr>
                )) ?? (
                  <tr>
                    <td colSpan={3}>No graded lineups.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        )}
      </div>
    )}
    </div>
  </section>
</Layout>

<style>
  :global(body) {
    background:
      radial-gradient(circle at 12% 10%, rgba(28, 86, 232, 0.08), transparent 22%),
      radial-gradient(circle at 88% 14%, rgba(18, 58, 153, 0.08), transparent 24%),
      #000;
    color: #f3f3f3;
  }

  :global(main.shell) {
    --sim-blue: #11348a;
    --sim-blue-deep: #0a1f57;
    --sim-blue-soft: rgba(17, 52, 138, 0.18);
    --sim-gold: #b8922f;
    --sim-line: rgba(255, 255, 255, 0.08);
    --sim-line-strong: rgba(255, 255, 255, 0.14);
    --sim-surface: #050505;
    --sim-surface-2: #0b0d12;
    --sim-surface-3: #10141d;
    --sim-electric-blue: #1c56e8;
    --sim-electric-blue-2: #2563eb;
    --sim-electric-blue-3: #123a99;
    --sim-electric-blue-glow: rgba(37, 99, 235, 0.26);
    --sim-header-blue-top: #1f4fcf;
    --sim-header-blue-mid: #123a99;
    --sim-header-blue-bottom: #071a4d;
    padding: 0.7rem 0 1.75rem;
  }

  .sim-page,
  .sim-page * {
    border-radius: 0 !important;
    box-shadow: none !important;
  }

  .sim-page {
    width: min(100%, 1520px);
    margin: 0 auto;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
  }

.sim-panel {
  width: 100%;
  box-sizing: border-box;
  padding: 1rem 1.35rem 1.2rem;
  margin-top: 0.85rem;
  position: relative;
  background: transparent !important;
  background-color: transparent !important;
  background-image: none !important;
    border: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
  }

  .sim-panel::before {
    content: none !important;
  }

  .sim-page::before,
  .sim-page::after,
  .sim-panel::after {
    content: none !important;
    display: none !important;
  }

  .sim-page,
  .sim-panel,
  .table-area,
  .slates-table {
    border-left: 0 !important;
    border-right: 0 !important;
  }

  .top-row {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 0.9rem 1.2rem;
    margin-bottom: 0.55rem;
  }

  .brand-row {
    position: relative;
    display: flex;
    align-items: flex-end;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .brand-row::before {
    content: "";
    position: absolute;
    inset: -2.4rem -3.5rem;
    background:
      radial-gradient(circle at 45% 40%, rgba(18, 58, 154, 0.12), transparent 62%),
      radial-gradient(circle at 60% 20%, rgba(18, 58, 154, 0.08), transparent 55%);
    opacity: 0.32;
    pointer-events: none;
    filter: blur(1.2px);
    z-index: 0;
  }

  .title {
    position: relative;
    z-index: 1;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.28rem;
    font-size: clamp(2.4rem, 3.4vw, 4rem);
    line-height: 0.92;
    font-weight: 900;
    letter-spacing: -0.07em;
    color: #f7f7fb;
    text-transform: none;
    text-shadow: 0 10px 26px rgba(0, 0, 0, 0.55);
  }

  .title-accent {
    color: var(--sim-electric-blue);
    text-shadow:
      0 0 16px rgba(28, 86, 232, 0.14),
      0 0 28px rgba(28, 86, 232, 0.08);
  }

  .week-text {
    position: relative;
    top: -0.18rem;
    font-size: 1.02rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.74);
  }

  .title::after {
    content: "";
    display: block;
    width: 56px;
    height: 2px;
    margin-left: 0.35rem;
    background: linear-gradient(
      90deg,
      rgba(28, 86, 232, 0.96) 0%,
      rgba(37, 99, 235, 0.82) 100%
    );
    box-shadow: 0 0 12px rgba(28, 86, 232, 0.14);
    align-self: center;
    transform: translateY(-0.12rem);
  }

  .meta-block {
    margin-left: auto;
    text-align: right;
  }

  .meta-line {
    font-size: 0.98rem;
    line-height: 1.35;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.94);
    white-space: nowrap;
  }

  .meta-sep {
    display: inline-block;
    margin: 0 0.42rem;
    color: var(--sim-gold);
  }

  .action-row {
    display: flex;
    justify-content: flex-end;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin-bottom: 0.65rem;
  }

  .tool-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 1rem;
    border: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.04) 55%),
      linear-gradient(180deg, rgba(8, 14, 28, 0.92) 0%, rgba(7, 10, 18, 0.96) 100%);
    color: #f4f4f4;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    text-decoration: none;
    border-radius: 12px !important;
    transition:
      border-color 140ms ease,
      background 140ms ease,
      color 140ms ease,
      transform 140ms ease,
      box-shadow 140ms ease;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 8px 18px rgba(255, 255, 255, 0.04),
      inset 0 -10px 20px rgba(0, 0, 0, 0.45),
      0 10px 22px rgba(0, 0, 0, 0.35);
  }

  .tool-btn:hover,
  .tool-btn:focus-visible {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.28) 0%, rgba(255, 255, 255, 0.06) 55%),
      linear-gradient(180deg, rgba(14, 26, 56, 0.92) 0%, rgba(8, 12, 22, 0.97) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.26),
      inset 0 10px 18px rgba(255, 255, 255, 0.06),
      inset 0 -12px 24px rgba(0, 0, 0, 0.5),
      0 14px 28px rgba(0, 0, 0, 0.48);
    outline: none;
    transform: translateY(-1px);
  }

  .tool-btn:active {
    transform: translateY(1px);
    box-shadow:
      inset 0 2px 10px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 6px 14px rgba(0, 0, 0, 0.35);
  }

  .tool-btn-secondary {
    color: rgba(255, 255, 255, 0.94);
  }

  .tool-btn-primary {
    border: 0;
    background:
      linear-gradient(
        180deg,
        #3a74ff 0%,
        #1f4fcf 46%,
        #123a99 100%
      );
    color: #f5f8ff;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      inset 0 -1px 0 rgba(0, 0, 0, 0.26),
      0 10px 22px rgba(7, 26, 77, 0.28),
      0 0 18px rgba(18, 58, 153, 0.14);
  }

  .tool-btn-primary:hover,
  .tool-btn-primary:focus-visible {
    background:
      linear-gradient(
        180deg,
        #4a7eff 0%,
        #2563eb 42%,
        #1848bf 100%
      );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 -1px 0 rgba(0, 0, 0, 0.22),
      0 14px 28px rgba(7, 26, 77, 0.32),
      0 0 22px rgba(28, 86, 232, 0.18);
  }

  .tool-btn-primary:active {
    transform: translateY(1px);
    background:
      linear-gradient(
        180deg,
        #2563eb 0%,
        #1f4fcf 44%,
        #10348a 100%
      );
    box-shadow:
      inset 0 2px 5px rgba(0, 0, 0, 0.2),
      0 6px 12px rgba(7, 26, 77, 0.22);
  }

  .tabs {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 0.42rem;
    border-bottom: 1px solid var(--sim-line);
    margin-bottom: 0.45rem;
  }

  .tab-btn {
    position: relative;
    padding: 0;
    border: 0;
    background: transparent;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.805rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
  }

  .tab-btn.active {
    color: #ffffff;
  }

  .tab-btn.active::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.44rem;
    width: 100%;
    height: 1px;
    background: var(--sim-blue);
  }

  .section-head {
    margin-bottom: 0.32rem;
  }

  .section-head h2 {
    margin: 0;
    font-size: clamp(1.35rem, 1.8vw, 1.9rem);
    line-height: 1.02;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #f5f5f5;
  }

  .filters {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
