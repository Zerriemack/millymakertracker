                    />
                  </span>
                  <span class="team-code">${escapeHtml(row.team)}</span>
                </span>
              </td>
              <td class="num-cell salary-cell">$${formatInteger(row.salary)}</td>
              <td class="num-cell own-cell">${formatNumber(row.ownership, 1)}%</td>
              <td class="num-cell optimal-rate-value-cell">${formatNumber(row.optimalSimRate, 1)}%</td>
              <td class="num-cell opt-lev-cell">${formatOptLevDisplay(row.optimalLeverage)}</td>
              <td class="num-cell plus-ev-cell">${formatNumber(row.plusEvScore, 2)}</td>
              <td class="bar-lane-cell" data-bar-value="${row.optimalSimRate}">
                <div class="bar-lane-shell">
                  <span class="bar-lane-track">
                    <span class="bar-lane-fill"></span>
                  </span>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
      const emptyFilterRow =
        resultsPayload.players.length > 0
          ? `<tr class="results-empty-row" data-empty-row="filter" style="display:none"><td colSpan="9">No players match this position filter.</td></tr>`
          : "";
      const emptyDataRow =
        resultsPayload.players.length === 0 ? `<tr><td colSpan="9">No results.</td></tr>` : "";
      return `${rows}${emptyFilterRow}${emptyDataRow}`;
    };

    const buildExpRows = () => {
      const rows = resultsPayload.players
        .slice()
        .sort(
          (a, b) =>
            b.retainedExposureRate - a.retainedExposureRate ||
            b.optimalLeverage - a.optimalLeverage
        )
        .map((row) => {
          const levValue = Math.abs(row.optimalLeverage) >= 10 ? row.optimalLeverage / 10 : row.optimalLeverage;
          return `
            <tr
              data-pos="${escapeHtml(row.position)}"
              data-name="${escapeHtml(row.name)}"
              data-position="${escapeHtml(row.position)}"
              data-team="${escapeHtml(row.team)}"
              data-salary="${row.salary}"
              data-own="${row.ownership}"
              data-optimal="${row.optimalSimRate}"
              data-lev="${levValue}"
              data-retainedexp="${row.retainedExposureRate}"
            >
              <td class="player-name-cell">${escapeHtml(row.name)}</td>
              <td class="pos-cell">${escapeHtml(row.position)}</td>
              <td class="team-cell">
                <span class="team-cell-inner">
                  <span class="results-team-logo">
                    <img
                      src="/simulator/team-logos/${escapeHtml(row.team)}.png"
                      alt="${escapeHtml(row.team)} logo"
                      loading="lazy"
                      onerror="this.style.display='none';"
                    />
                  </span>
                  <span class="team-code">${escapeHtml(row.team)}</span>
                </span>
              </td>
              <td class="num-cell salary-cell">$${formatInteger(row.salary)}</td>
              <td class="num-cell own-cell">${formatNumber(row.ownership, 1)}%</td>
              <td class="num-cell optimal-rate-value-cell">${formatNumber(row.optimalSimRate, 1)}%</td>
              <td class="num-cell opt-lev-cell">${formatOptLevDisplay(row.optimalLeverage)}</td>
              <td class="num-cell retained-exp-value-cell">${formatNumber(row.retainedExposureRate, 1)}%</td>
              <td class="bar-lane-cell" data-bar-value="${row.retainedExposureRate}">
                <div class="bar-lane-shell">
                  <span class="bar-lane-track">
                    <span class="bar-lane-fill"></span>
                  </span>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
      const emptyFilterRow =
        resultsPayload.players.length > 0
          ? `<tr class="results-empty-row" data-empty-row="filter" style="display:none"><td colSpan="9">No players match this position filter.</td></tr>`
          : "";
      const emptyDataRow =
        resultsPayload.players.length === 0 ? `<tr><td colSpan="9">No exposures.</td></tr>` : "";
      return `${rows}${emptyFilterRow}${emptyDataRow}`;
    };

    const buildGradedRows = () => {
      const lineups = Array.isArray(resultsPayload.lineups) ? resultsPayload.lineups : [];
      const rows = lineups
        .slice()
        .sort(
          (a, b) =>
            (b.evScore ?? 0) - (a.evScore ?? 0) ||
            (b.topPointOnePctRate ?? 0) - (a.topPointOnePctRate ?? 0) ||
            (b.topOnePctRate ?? 0) - (a.topOnePctRate ?? 0) ||
            (b.itmRate ?? 0) - (a.itmRate ?? 0)
        )
        .slice(0, 20)
        .map((row) => {
          const lineupText = Array.isArray(row.players)
            ? row.players.map((player) => `${player.position} ${player.name}`).join(" / ")
            : "";
          return `
            <tr>
              <td class="num-cell">${formatNumber(row.evScore ?? 0, 2)}</td>
              <td class="num-cell">${formatNumber(row.topPointOnePctRate ?? 0, 2)}%</td>
              <td class="num-cell">${formatNumber(row.topOnePctRate ?? 0, 2)}%</td>
              <td class="num-cell">${formatNumber(row.itmRate ?? 0, 2)}%</td>
              <td class="num-cell">$${formatInteger(row.salaryUsed)}</td>
              <td class="num-cell">${formatNumber(row.averageSimTotal, 1)}</td>
              <td class="num-cell">${formatNumber(row.sumOwnership, 1)}%</td>
              <td class="bar-cell num-cell" data-bar-value="${row.frequencyRate ?? 0}">
                <div class="bar-track" aria-hidden="true">
                  <div class="bar-fill"></div>
                </div>
                <span class="bar-label">${formatNumber(row.frequencyRate, 1)}%</span>
              </td>
              <td class="lineup-cell">${escapeHtml(lineupText)}</td>
            </tr>
          `;
        })
        .join("");
      if (!rows) {
        return `<tr><td colSpan="9">No lineup aggregates available.</td></tr>`;
      }
      return rows;
    };

    let tableHtml = "";
    if (SIM_ACTIVE_SUBTAB === "ev") {
      tableHtml = `
        <div class="results-table-shell">
          <div class="results-table-head-wrap">
            <table class="slates-table results-table results-table-head results-table-optimal-head">
              <colgroup>
                <col class="col-player" />
                <col class="col-pos" />
                <col class="col-team" />
                <col class="col-salary" />
                <col class="col-own" />
                <col class="col-optimal-rate-value" />
                <col class="col-opt-lev" />
                <col class="col-plus-ev" />
                <col class="col-bar-lane" />
              </colgroup>
              <thead>
                <tr>
                  <th class="th-player"><button type="button" class="results-header-filter-btn" data-filter-trigger="name">Player</button></th>
                  <th class="th-pos"><button type="button" class="results-header-filter-btn" data-filter-trigger="position">Pos</button></th>
                  <th class="th-team"><button type="button" class="results-header-filter-btn" data-filter-trigger="team">Team</button></th>
                  <th class="th-num"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="salary">Salary</button></th>
                  <th class="th-num"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="own">Own%</button></th>
                  <th class="th-num th-optimal-value"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="optimal">Optimal Rate %</button></th>
                  <th class="th-num th-opt-lev"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="lev">Opt Lev</button></th>
                  <th class="th-num"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="plusEv">Plus EV</button></th>
                  <th class="th-bar-lane"></th>
                </tr>
              </thead>
            </table>
          </div>
          <div class="results-table-wrap">
            <table class="slates-table results-table results-table-body results-table-optimal" data-results-table data-bar-metric="optimalSimRate" data-results-kind="ev">
              <colgroup>
                <col class="col-player" />
                <col class="col-pos" />
                <col class="col-team" />
                <col class="col-salary" />
                <col class="col-own" />
                <col class="col-optimal-rate-value" />
                <col class="col-opt-lev" />
                <col class="col-plus-ev" />
                <col class="col-bar-lane" />
              </colgroup>
              <tbody>
                ${buildEvRows()}
              </tbody>
            </table>
            <div class="results-header-filter-popover" data-header-filter-popover hidden></div>
          </div>
        </div>
      `;
    }

    if (SIM_ACTIVE_SUBTAB === "exp") {
      tableHtml = `
        <div class="results-table-shell">
          <div class="results-table-head-wrap">
            <table class="slates-table results-table results-table-head">
              <colgroup>
                <col class="col-player" />
                <col class="col-pos" />
                <col class="col-team" />
                <col class="col-salary" />
                <col class="col-own" />
                <col class="col-optimal-rate-value" />
                <col class="col-opt-lev" />
                <col class="col-retained-exp" />
                <col class="col-bar-lane" />
              </colgroup>
              <thead>
                <tr>
                  <th class="th-player"><button type="button" class="results-header-filter-btn" data-filter-trigger="name">Player</button></th>
                  <th class="th-pos"><button type="button" class="results-header-filter-btn" data-filter-trigger="position">Pos</button></th>
                  <th class="th-team"><button type="button" class="results-header-filter-btn" data-filter-trigger="team">Team</button></th>
                  <th class="th-num"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="salary">Salary</button></th>
                  <th class="th-num"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="own">Own%</button></th>
                  <th class="th-num th-optimal-value"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="optimal">Optimal Rate %</button></th>
                  <th class="th-num th-opt-lev"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="lev">Opt Lev</button></th>
                  <th class="th-num"><button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="retainedExp">Retained Exp</button></th>
                  <th class="th-bar-lane"></th>
                </tr>
              </thead>
            </table>
          </div>
          <div class="results-table-wrap">
            <table class="slates-table results-table results-table-body" data-results-table data-bar-metric="retainedExposureRate" data-results-kind="exp">
              <colgroup>
                <col class="col-player" />
                <col class="col-pos" />
                <col class="col-team" />
                <col class="col-salary" />
                <col class="col-own" />
                <col class="col-optimal-rate-value" />
                <col class="col-opt-lev" />
                <col class="col-retained-exp" />
                <col class="col-bar-lane" />
              </colgroup>
              <tbody>
                ${buildExpRows()}
              </tbody>
            </table>
            <div class="results-header-filter-popover" data-header-filter-popover hidden></div>
          </div>
        </div>
      `;
    }

    if (SIM_ACTIVE_SUBTAB === "graded") {
      tableHtml = `
        <div class="results-table-wrap">
          <table class="slates-table results-table" data-results-table data-bar-metric="frequencyRate">
            <thead>
              <tr>
                <th>EV</th>
                <th>Top 0.1%</th>
                <th>Top 1%</th>
                <th>ITM</th>
                <th>Salary Used</th>
                <th>Avg Sim Total</th>
                <th>Sum Own%</th>
                <th>Frequency%</th>
                <th>Lineup</th>
              </tr>
            </thead>
            <tbody>
              ${buildGradedRows()}
            </tbody>
          </table>
        </div>
      `;
    }

    resultsContent.dataset.hasResults = "true";
    resultsContent.innerHTML = `${summaryHtml}${filterRowHtml}${tableHtml}`;
    initResultsTools();
    return true;
  };

  const runSimulation = async (context) => {
    if (runInProgress) return;
    const { statusTarget } = context || {};
    if (!SIM_SLATE_KEY) {
      setStatus("No slate selected. Unable to run sims.", "error");
      setSettingsStatus("No slate selected. Unable to run sims.", "error");
      return;
    }
    if (settingsInvalid) {
      const message = "Fix settings errors before running this simulation.";
      if (statusTarget === "settings") {
        setSettingsStatus(message, "error");
      } else {
        setStatus(message, "error");
      }
      return;
    }
    if (settingsDirty) {
      const message = "Save your settings to run this simulation.";
      if (statusTarget === "settings") {
        setSettingsStatus(message, "error");
      } else {
        setStatus(message, "error");
      }
      return;
    }
    runInProgress = true;
    if (runBtn) runBtn.disabled = true;
    if (runSettingsBtn) runSettingsBtn.disabled = true;
    showRunOverlay();
    if (statusTarget === "settings") {
      setSettingsStatus("Simulation in progress...", "info");
    } else {
      setStatus("Simulation in progress...", "info");
    }
    try {
      if (runStatusEl) runStatusEl.textContent = "Sending request...";
      const runUrl = `${window.location.origin}/api/simulator/run-sims`;
      console.log("[sim] fetch start", runUrl);
      const fetchPromise = fetch(runUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slate: SIM_SLATE_KEY }),
      });
      if (runStatusEl && settingsState?.simulationCount) {
        runStatusEl.textContent = `Request sent. Running ${settingsState.simulationCount.toLocaleString()} simulations...`;
      } else if (runStatusEl) {
        runStatusEl.textContent = "Request sent. Simulator running...";
      }
      console.log("[sim] fetch promise created");
      const response = await fetchPromise;
      if (runStatusEl) runStatusEl.textContent = "Processing results...";
      console.log("[sim] fetch response received", response.status);
      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        const message = data?.error || "Simulation run failed. Check settings and try again.";
        const details = Array.isArray(data?.details) ? data.details.join(" ") : data?.details;
        throw new Error(`${message}${details ? " " + details : ""}`);
      }
      if (!data?.results) {
        throw new Error("Simulation completed but results are missing.");
      }
      latestResults = data.results;
      persistResults(data.results);
      if (runStatusEl) runStatusEl.textContent = "Loading results...";
      console.log("[sim] response ok");
      if (SIM_ACTIVE_TAB === "results") {
        renderResultsFromPayload(latestResults);
        hideRunOverlay();
        if (runBtn) runBtn.disabled = false;
        if (runSettingsBtn) runSettingsBtn.disabled = false;
        runInProgress = false;
        setStatus("Simulation complete.", "success");
        return;
      }
      const targetUrl = `/simulator?slate=${encodeURIComponent(SIM_SLATE_KEY)}&tab=results&subtab=ev`;
      if (runStatusEl) runStatusEl.textContent = "Simulation complete. Opening results...";
      console.log("[sim] redirecting", targetUrl);
      window.location.assign(targetUrl);
    } catch (error) {
      if (runStatusEl) runStatusEl.textContent = "Simulation failed.";
      console.log("[sim] run error", error);
      hideRunOverlay();
      const message = error.message || "Simulation run failed. Check settings and try again.";
      if (statusTarget === "settings") {
        setSettingsStatus(message, "error");
      } else {
        setStatus(message, "error");
      }
      if (runBtn) runBtn.disabled = false;
      if (runSettingsBtn) runSettingsBtn.disabled = false;
      runInProgress = false;
    }
  };

  const updateValidationSummary = () => {
    if (!validationEl) return;
    if (invalidCount > 0 || teamBlockingCount > 0) {
      const parts = [];
      if (invalidCount > 0) {
        parts.push(`${invalidCount} field error${invalidCount === 1 ? "" : "s"}`);
      }
      if (teamBlockingCount > 0) {
        parts.push(`${teamBlockingCount} team logic error${teamBlockingCount === 1 ? "" : "s"}`);
      }
      validationEl.textContent = `Fix ${parts.join(" and ")} before saving.`;
      validationEl.dataset.tone = "error";
      return;
    }
    if (teamWarningCount > 0) {
      validationEl.textContent = `${teamWarningCount} team warning${teamWarningCount === 1 ? "" : "s"} (save allowed).`;
      validationEl.dataset.tone = "info";
      return;
    }
    validationEl.textContent = "";
    validationEl.dataset.tone = "";
  };

  const setDirty = (value) => {
    dirty = value;
    if (saveBtn) saveBtn.disabled = !dirty || invalidCount > 0 || teamBlockingCount > 0;
  };

  const updateSaveState = () => {
    if (saveBtn) saveBtn.disabled = !dirty || invalidCount > 0 || teamBlockingCount > 0;
  };

  const updateSettingsSaveState = () => {
    if (saveSettingsBtn) saveSettingsBtn.disabled = !settingsDirty || settingsInvalid;
    if (runSettingsBtn) runSettingsBtn.disabled = false;
  };

  const validateSettingsInputs = () => {
    const requiredFields = ["lineupCount", "fieldSize", "simulationCount"];
    const inputs = Array.from(document.querySelectorAll("[data-setting-field]"));
    let invalid = false;
    inputs.forEach((input) => {
      const field = input.dataset.settingField;
      if (!field) return;
      if (input.tagName === "SELECT" || input.type === "radio") {
        input.classList.remove("input-error");
        return;
      }
      const raw = input.value.trim();
      if (requiredFields.includes(field) && !raw) {
        invalid = true;
        input.classList.add("input-error");
        return;
      }
      if (!raw) {
        input.classList.remove("input-error");
        return;
      }
      const num = Number(raw);
      if (!Number.isFinite(num)) {
        invalid = true;
        input.classList.add("input-error");
      } else {
        input.classList.remove("input-error");
      }
    });

    if (settingsState) {
      if (settingsState.fieldSize > 500000) invalid = true;
    }
    settingsInvalid = invalid;
    updateSettingsSaveState();
  };

  const handleSettingsInput = (event) => {
    const input = event.target;
    if (!input || !input.dataset.settingField) return;
    if (!settingsState) return;
    const field = input.dataset.settingField;
    if (input.tagName === "SELECT" || input.type === "radio") {
      settingsState[field] = input.value;
      if (field === "payoutProfile") syncPayoutProfileUI();
    } else {
      const raw = input.value.trim();
      if (!raw) {
        settingsState[field] = null;
      } else {
        const parsed = Number(raw);
        settingsState[field] = Number.isFinite(parsed) ? parsed : null;
      }
    }
    settingsDirty = true;
    validateSettingsInputs();
    syncSliderValues();
    setSettingsStatus("", "");
  };

  const payoutInputs = Array.from(document.querySelectorAll("input[name='payoutProfile']"));
  payoutInputs.forEach((input) => {
    input.addEventListener("change", (event) => {
      const target = event.currentTarget;
      if (!(target instanceof HTMLInputElement)) return;
      if (!settingsState) return;
      settingsState.payoutProfile = target.value;
      settingsDirty = true;
      syncPayoutProfileUI();
      validateSettingsInputs();
      syncSliderValues();
      setSettingsStatus("", "");
    });
  });

  const setFieldError = (input, message) => {
    const key = input.dataset.key;
    if (!key) return;
    const errorEl = document.querySelector(`[data-error-key="${key}"]`);
    if (message) {
      fieldErrors.set(key, message);
      input.classList.add("input-error");
      if (errorEl) errorEl.textContent = message;
    } else {
      fieldErrors.delete(key);
      input.classList.remove("input-error");
      if (errorEl) errorEl.textContent = "";
    }
    invalidCount = fieldErrors.size;
    updateValidationSummary();
    updateSaveState();
  };

  const sumBy = (players, positions, field) =>
    players
      .filter((player) => positions.has(player.position))
      .reduce((total, player) => total + (Number(player[field]) || 0), 0);

  const teamValidationRules = [
    {
      key: "rushMarketShare",
      label: "Rush share",
      positions: new Set(["QB", "RB", "WR", "TE"]),
    },
    {
      key: "rushTdMarketShare",
      label: "Rush TD share",
      positions: new Set(["QB", "RB", "WR", "TE"]),
    },
    {
      key: "receivingMarketShare",
      label: "Receiving share",
      positions: new Set(["RB", "WR", "TE"]),
    },
    {
      key: "receivingTdMarketShare",
      label: "Receiving TD share",
      positions: new Set(["RB", "WR", "TE"]),
    },
  ];

  const classifyShare = (total) => {
    if (total < 80 || total > 120) return "error";
    if ((total >= 80 && total < 90) || (total > 110 && total <= 120)) return "warning";
    return "ok";
  };

  const computeTeamValidation = () => {
    const teamNodes = Array.from(document.querySelectorAll(".team-validation[data-team-key]"));
    const validationMap = new Map();
    teamBlockingCount = 0;
    teamWarningCount = 0;

    teamNodes.forEach((node) => {
      const key = node.dataset.teamKey;
      if (!key) return;
      const [, gameId, team] = key.split(":");
      if (!gameId || !team) return;
      const players = state.playerInputs.filter(
        (player) => player.gameId === gameId && player.team === team
      );

      const errors = [];
      const warnings = [];

      teamValidationRules.forEach((rule) => {
        const total = sumBy(players, rule.positions, rule.key);
        const status = classifyShare(total);
        if (status === "error") {
          errors.push(`${rule.label} total is ${total.toFixed(1)}. Keep it closer to 100.`);
        } else if (status === "warning") {
          warnings.push(`${rule.label} total is ${total.toFixed(1)}. This looks off.`);
        }
      });

      const qbTotal = sumBy(players, new Set(["QB"]), "passMarketShare");
      if (players.filter((player) => player.position === "QB").length === 0) {
        warnings.push("No QB found for this team.");
      } else if (qbTotal <= 0) {
        errors.push(`QB pass share total is ${qbTotal.toFixed(1)}. Must be greater than 0.`);
      } else if (qbTotal < 95 || qbTotal > 105) {
        warnings.push(`QB pass share totals ${qbTotal.toFixed(1)}. Keep it closer to 100.`);
      }

      if (errors.length > 0) teamBlockingCount += 1;
      if (warnings.length > 0) teamWarningCount += 1;
      validationMap.set(key, { errors, warnings });
    });

    teamNodes.forEach((node) => {
      const key = node.dataset.teamKey;
      const messagesEl = node.querySelector(".team-validation-messages");
      if (!key || !messagesEl) return;
      const result = validationMap.get(key);
      messagesEl.innerHTML = "";
      if (!result) return;
      if (result.errors.length === 0 && result.warnings.length === 0) {
        messagesEl.innerHTML = "<div class=\"team-validation-ok\">No issues detected.</div>";
        return;
      }
      result.errors.forEach((message) => {
        const div = document.createElement("div");
        div.className = "team-validation-msg error";
        div.textContent = message;
        messagesEl.appendChild(div);
      });
      result.warnings.forEach((message) => {
        const div = document.createElement("div");
        div.className = "team-validation-msg warning";
        div.textContent = message;
        messagesEl.appendChild(div);
      });
    });

    updateValidationSummary();
    updateSaveState();
  };

  const validateInput = (input) => {
    const raw = input.value.trim();
    const field = input.dataset.field;
    if (!field) return;
    if (!raw) {
      setFieldError(input, "Required");
      return;
    }
    const num = Number(raw);
    if (!Number.isFinite(num)) {
      setFieldError(input, "Must be a number");
      return;
    }
    const rule = rangeRules[field];
    if (rule?.min !== undefined && num < rule.min) {
      setFieldError(input, "Must be 0 or greater");
      return;
    }
    if (rule?.max !== undefined && num > rule.max) {
      setFieldError(input, "Must be between 0 and 100");
      return;
    }
    setFieldError(input, "");
  };

  const updateInputsFromState = () => {
    document.querySelectorAll('input[data-kind="team"]').forEach((input) => {
      const field = input.dataset.field;
      const gameId = input.dataset.gameId;
      const team = input.dataset.team;
      const row = teamIndex.get(`${gameId}-${team}`);
      if (!row || !field) return;
      const value = row[field];
      if (percentFields.has(field)) {
        input.value = Number(value * 100).toFixed(1);
      } else {
        input.value = value;
      }
      validateInput(input);
    });

    document.querySelectorAll('input[data-kind="player"]').forEach((input) => {
      const field = input.dataset.field;
      const playerId = input.dataset.playerId;
      const row = playerIndex.get(playerId);
      if (!row || !field) return;
      input.value = row[field];
      validateInput(input);
    });
    computeTeamValidation();
  };

  const handleTeamInput = (event) => {
    const input = event.target;
    if (!input || input.dataset.kind !== "team") return;
    const field = input.dataset.field;
    const gameId = input.dataset.gameId;
    const team = input.dataset.team;
    const row = teamIndex.get(`${gameId}-${team}`);
    if (!row || !field) return;
    const parsed = Number(input.value);
    if (Number.isFinite(parsed)) {
      row[field] = percentFields.has(field) ? parsed / 100 : parsed;
    } else {
      row[field] = null;
    }
    validateInput(input);
    computeTeamValidation();
    setDirty(true);
    setStatus("", "");
  };

  const handlePlayerInput = (event) => {
    const input = event.target;
    if (!input || input.dataset.kind !== "player") return;
    const field = input.dataset.field;
    const playerId = input.dataset.playerId;
    const row = playerIndex.get(playerId);
    if (!row || !field) return;
    const parsed = Number(input.value);
    if (Number.isFinite(parsed)) {
      row[field] = parsed;
    } else {
      row[field] = null;
    }
    validateInput(input);
    computeTeamValidation();
    setDirty(true);
    setStatus("", "");
  };

  document.addEventListener("input", (event) => {
    handleTeamInput(event);
    handlePlayerInput(event);
    handleSettingsInput(event);
  });

  if (resetBtn) {
    console.log("[sim] reset listener attached");
    resetBtn.addEventListener("click", () => {
      console.log("[sim] reset clicked");
      state.teamInputs = clone(baseline.teamInputs);
      state.playerInputs = clone(baseline.playerInputs);
      teamIndex.clear();
      state.teamInputs.forEach((row) => teamIndex.set(`${row.gameId}-${row.team}`, row));
      playerIndex.clear();
      state.playerInputs.forEach((row) => playerIndex.set(row.id, row));
      fieldErrors.clear();
      invalidCount = 0;
      teamBlockingCount = 0;
      teamWarningCount = 0;
      if (settingsBaseline) {
        settingsState = clone(settingsBaseline);
        settingsDirty = false;
        applySettingsStateToInputs();
        validateSettingsInputs();
        updateSettingsSaveState();
      }
      updateInputsFromState();
      setDirty(false);
      setStatus("Inputs reset to last saved values.", "info");
    });
  }

  const savePayload = async (url, payload) => {
    const response = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) {
      const message = data?.error || "Save failed.";
      const details = Array.isArray(data?.details) ? data.details.join(" ") : "";
      throw new Error(`${message}${details ? " " + details : ""}`);
    }
    return data;
  };

  if (saveBtn) {
    console.log("[sim] save inputs listener attached");
    saveBtn.addEventListener("click", async () => {
      console.log("[sim] save clicked");
      if (!SIM_SLATE_KEY) {
        setStatus("No slate selected. Unable to save.", "error");
        return;
      }
      if (teamBlockingCount > 0) {
        setStatus(`Fix ${teamBlockingCount} team logic error${teamBlockingCount === 1 ? "" : "s"} before saving.`, "error");
        return;
      }
      if (invalidCount > 0) {
        setStatus(`Fix ${invalidCount} invalid value${invalidCount === 1 ? "" : "s"} before saving.`, "error");
        return;
      }
      if (!dirty) {
        setStatus("No changes to save.", "info");
        return;
      }
      saveBtn.disabled = true;
      setStatus("Saving inputs...", "info");
      try {
        await savePayload("/api/simulator/save-team-inputs", {
          slate: SIM_SLATE_KEY,
          teamInputs: state.teamInputs,
        });
        await savePayload("/api/simulator/save-player-inputs", {
          slate: SIM_SLATE_KEY,
          playerInputs: state.playerInputs,
        });
        baseline = {
          teamInputs: clone(state.teamInputs),
          playerInputs: clone(state.playerInputs),
        };
        fieldErrors.clear();
        invalidCount = 0;
        teamBlockingCount = 0;
        teamWarningCount = 0;
        updateInputsFromState();
        setDirty(false);
        setStatus("Inputs saved successfully.", "success");
      } catch (error) {
        setStatus(error.message || "Save failed.", "error");
        saveBtn.disabled = false;
      }
    });
  }

  if (runBtn) {
    console.log("[sim] run listener attached");
    runBtn.addEventListener("click", async () => {
      console.log("[sim] run clicked");
      await runSimulation({ statusTarget: "main" });
    });
  }

  if (runSettingsBtn) {
    console.log("[sim] settings run listener attached");
    runSettingsBtn.addEventListener("click", async () => {
      console.log("[sim] settings run clicked");
      await runSimulation({ statusTarget: "settings" });
    });
  }

  if (saveSettingsBtn) {
    console.log("[sim] save settings listener attached");
    saveSettingsBtn.addEventListener("click", async () => {
      console.log("[sim] save settings clicked");
      if (!SIM_SLATE_KEY || !settingsState) {
        setSettingsStatus("No settings loaded.", "error");
        return;
      }
      if (settingsInvalid) {
        setSettingsStatus("Fix settings errors before saving.", "error");
        return;
      }
      if (!settingsDirty) {
        setSettingsStatus("No settings changes to save.", "info");
        return;
      }
      saveSettingsBtn.disabled = true;
      setSettingsStatus("Saving settings...", "info");
      try {
        persistSettings();
        const response = await fetch("/api/simulator/save-settings", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ slate: SIM_SLATE_KEY, settings: settingsState }),
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          const message = data?.error || "Save failed.";
          const details = Array.isArray(data?.details) ? data.details.join(" ") : data?.details;
          throw new Error(`${message}${details ? " " + details : ""}`);
        }
        settingsBaseline = clone(settingsState);
        settingsDirty = false;
        updateSettingsSaveState();
        setSettingsStatus("Settings saved.", "success");
      } catch (error) {
        setSettingsStatus(error.message || "Save failed.", "error");
        saveSettingsBtn.disabled = false;
      }
    });
  }

  const initResultsTools = () => {
    const panel = document.querySelector(".results-panel");
    if (!panel) return;

    const filterRow = panel.querySelector("[data-pos-filter]");
    const tables = Array.from(panel.querySelectorAll("table[data-results-table]"));
    if (!tables.length) return;

    const updateBars = (table) => {
      const cells = Array.from(table.querySelectorAll("[data-bar-value]"));
      const visibleValues = cells
        .filter((cell) => {
          const row = cell.closest("tr");
          return row && row.style.display !== "none";
        })
        .map((cell) => Number(cell.dataset.barValue || 0))
        .filter((value) => Number.isFinite(value));

      const maxValue = visibleValues.length ? Math.max(...visibleValues) : 0;

      cells.forEach((cell) => {
        const value = Number(cell.dataset.barValue || 0);
        const pct = maxValue > 0 ? Math.max(0, (value / maxValue) * 100) : 0;
        cell.style.setProperty("--metric-bar-width", `${pct}%`);
      });
    };

    const tableStates = new WeakMap();

    const getInitialTableState = () => ({
      posSet: new Set(["ALL"]),
      columnFilters: {
        name: "",
        position: "",
        team: ""
      },
      sort: {
        key: "",
        direction: ""
      }
    });

    tables.forEach((table) => {
      tableStates.set(table, getInitialTableState());
    });

    const getTableShell = (table) => table.closest(".results-table-shell") || table.parentElement;
    const getTableWrap = (table) => table.closest(".results-table-wrap") || table.parentElement;
    const getTablePopover = (table) => getTableWrap(table)?.querySelector("[data-header-filter-popover]");
    const getTableHeaderButtons = (table) => getTableShell(table)?.querySelectorAll(".results-header-filter-btn") || [];

    panel.querySelectorAll(".results-table-shell").forEach((shell) => {
      const headWrap = shell.querySelector(".results-table-head-wrap");
      const bodyWrap = shell.querySelector(".results-table-wrap");
      if (!headWrap || !bodyWrap) return;
      bodyWrap.addEventListener("scroll", () => {
        headWrap.scrollLeft = bodyWrap.scrollLeft;
      });
    });

    const rowMatchesColumnFilters = (row, filters) => {
      const name = (row.dataset.name || "").toLowerCase();
      const position = (row.dataset.position || "").toUpperCase();
      const team = (row.dataset.team || "").toLowerCase();

      if (filters.name && !name.includes(filters.name.toLowerCase())) return false;
      if (filters.position && position !== filters.position.toUpperCase()) return false;
      if (filters.team && !team.includes(filters.team.toLowerCase())) return false;

      return true;
    };

    const sortRows = (table, state) => {
      const { key, direction } = state.sort;
      if (!key || !direction) return;
      const tbody = table.querySelector("tbody");
      if (!tbody) return;
      const rows = Array.from(tbody.querySelectorAll("tr[data-pos]"));
      const visibleRows = rows.filter((row) => row.style.display !== "none");
      const hiddenRows = rows.filter((row) => row.style.display === "none");
      const getDatasetValue = (row, sortKey) => {
        if (sortKey === "plusEv") return row.dataset.plusev;
        if (sortKey === "retainedExp") return row.dataset.retainedexp;
        return row.dataset[sortKey];
      };
      const compare = (a, b) => {
        if (key === "name" || key === "position" || key === "team") {
          const aVal = (getDatasetValue(a, key) || "").toLowerCase();
          const bVal = (getDatasetValue(b, key) || "").toLowerCase();
          return direction === "asc"
            ? aVal.localeCompare(bVal)
            : bVal.localeCompare(aVal);
        }
        const aNum = Number(getDatasetValue(a, key) || 0);
        const bNum = Number(getDatasetValue(b, key) || 0);
        return direction === "asc" ? aNum - bNum : bNum - aNum;
      };
      visibleRows.sort(compare);
      visibleRows.forEach((row) => tbody.appendChild(row));
      hiddenRows.forEach((row) => tbody.appendChild(row));
    };

    const applyFilterToTable = (table) => {
      const state = tableStates.get(table) || getInitialTableState();
      const rows = Array.from(table.querySelectorAll("tbody tr[data-pos]"));
      let visibleCount = 0;

      rows.forEach((row) => {
        const rowPos = (row.dataset.pos || "ALL").toUpperCase();
        const matchesPills =
          state.posSet.has("ALL") || state.posSet.has(rowPos);
        const matchesColumns = rowMatchesColumnFilters(row, state.columnFilters);
        const show = matchesPills && matchesColumns;
        row.style.display = show ? "" : "none";
        if (show) visibleCount += 1;
      });

      sortRows(table, state);

      const emptyRow = table.querySelector("[data-empty-row='filter']");
      if (emptyRow) {
        emptyRow.style.display = visibleCount === 0 ? "" : "none";
      }

      updateBars(table);
    };

    const syncAllButtons = () => {
      if (!filterRow) return;
      const activeTable = tables[0];
      if (!activeTable) return;
      const state = tableStates.get(activeTable) || getInitialTableState();

      filterRow.querySelectorAll("button[data-pos]").forEach((node) => {
        const value = (node.dataset.pos || "").toUpperCase();
        const active = state.posSet.has("ALL")
          ? value === "ALL"
          : state.posSet.has(value);
        node.classList.toggle("active", active);
        node.setAttribute("aria-pressed", active ? "true" : "false");
      });
    };

    const openPopover = (table, trigger, key) => {
      const popover = getTablePopover(table);
      if (!popover) return;

      const state = tableStates.get(table) || getInitialTableState();
      const filters = state.columnFilters;

      const buildText = (label, field) => `
        <div class="results-header-filter-stack">
          <div class="results-header-filter-label">${label}</div>
          <input type="text" class="results-header-filter-input" data-filter-field="${field}" value="${filters[field] || ""}" />
          <div class="results-header-filter-actions">
            <button type="button" class="results-header-filter-action" data-filter-clear="${field}">Clear</button>
            <button type="button" class="results-header-filter-action" data-filter-clear-all>Clear All</button>
            <button type="button" class="results-header-filter-action results-header-filter-action--primary" data-filter-apply>Apply</button>
          </div>
        </div>
      `;

      const buildSelect = (label, field) => `
        <div class="results-header-filter-stack">
          <div class="results-header-filter-label">${label}</div>
          <select class="results-header-filter-select" data-filter-field="${field}">
            <option value="">All</option>
            <option value="QB" ${filters[field] === "QB" ? "selected" : ""}>QB</option>
            <option value="RB" ${filters[field] === "RB" ? "selected" : ""}>RB</option>
            <option value="WR" ${filters[field] === "WR" ? "selected" : ""}>WR</option>
            <option value="TE" ${filters[field] === "TE" ? "selected" : ""}>TE</option>
            <option value="DST" ${filters[field] === "DST" ? "selected" : ""}>DST</option>
          </select>
          <div class="results-header-filter-actions">
            <button type="button" class="results-header-filter-action" data-filter-clear="${field}">Clear</button>
            <button type="button" class="results-header-filter-action" data-filter-clear-all>Clear All</button>
            <button type="button" class="results-header-filter-action results-header-filter-action--primary" data-filter-apply>Apply</button>
          </div>
        </div>
      `;

      const buildSort = (label, sortKey) => `
        <div class="results-header-filter-stack">
          <div class="results-header-filter-label">${label}</div>
          <div class="results-header-filter-actions">
            <button type="button" class="results-header-filter-action ${state.sort.key === sortKey && state.sort.direction === "asc" ? "is-active-sort" : ""}" data-sort-key="${sortKey}" data-sort-direction="asc">Low \u2192 High</button>
            <button type="button" class="results-header-filter-action ${state.sort.key === sortKey && state.sort.direction === "desc" ? "is-active-sort" : ""}" data-sort-key="${sortKey}" data-sort-direction="desc">High \u2192 Low</button>
            <button type="button" class="results-header-filter-action" data-sort-clear>Clear sort</button>
          </div>
        </div>
      `;

      let html = "";
      if (key === "name") html = buildText("Player", "name");
      if (key === "position") html = buildSelect("Position", "position");
      if (key === "team") html = buildText("Team", "team");
      if (key === "salary") html = buildSort("Salary", "salary");
      if (key === "own") html = buildSort("Ownership %", "own");
      if (key === "optimal") html = buildSort("Optimal Rate %", "optimal");
      if (key === "lev") html = buildSort("Opt Lev %", "lev");
      if (key === "plusEv") html = buildSort("Plus EV", "plusEv");
      if (key === "retainedExp") html = buildSort("Retained Exp", "retainedExp");

      popover.innerHTML = html;
      popover.hidden = false;
      popover.dataset.filterKey = key;
      popover.dataset.tableMetric = table.dataset.barMetric || "";

      const wrapRect = getTableWrap(table).getBoundingClientRect();
      const triggerRect = trigger.getBoundingClientRect();
      popover.style.left = `${Math.max(0, triggerRect.left - wrapRect.left - 6)}px`;
      popover.style.top = `${triggerRect.bottom - wrapRect.top + 4}px`;

      getTableHeaderButtons(table).forEach((btn) => {
        btn.classList.toggle("is-active", btn === trigger);
      });

      const applyFromPopover = () => {
        const nextState = tableStates.get(table) || getInitialTableState();
        popover.querySelectorAll("[data-filter-field]").forEach((input) => {
          const field = input.getAttribute("data-filter-field");
          if (!field) return;
          nextState.columnFilters[field] = input.value.trim();
        });
        tableStates.set(table, nextState);
        applyFilterToTable(table);
      };

      popover.oninput = (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (!target.hasAttribute("data-filter-field")) return;
        applyFromPopover();
      };

      popover.onchange = (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (!target.hasAttribute("data-filter-field")) return;
        applyFromPopover();
      };

      popover.onclick = (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        if (target.hasAttribute("data-filter-clear")) {
          const field = target.getAttribute("data-filter-clear");
          const nextState = tableStates.get(table) || getInitialTableState();
          nextState.columnFilters[field] = "";
          tableStates.set(table, nextState);
          openPopover(table, trigger, key);
          applyFilterToTable(table);
          return;
        }

        if (target.hasAttribute("data-filter-clear-all")) {
          const nextState = tableStates.get(table) || getInitialTableState();
          Object.keys(nextState.columnFilters).forEach((field) => {
            nextState.columnFilters[field] = "";
          });
          tableStates.set(table, nextState);
          openPopover(table, trigger, key);
          applyFilterToTable(table);
          return;
        }

        if (target.hasAttribute("data-sort-key")) {
          const sortKey = target.getAttribute("data-sort-key") || "";
          const sortDirection = target.getAttribute("data-sort-direction") || "";
          const nextState = tableStates.get(table) || getInitialTableState();
          nextState.sort.key = sortKey;
          nextState.sort.direction = sortDirection;
          tableStates.set(table, nextState);
          popover.hidden = true;
          getTableHeaderButtons(table).forEach((btn) => {
            btn.classList.remove("is-active");
          });
          applyFilterToTable(table);
          return;
        }

        if (target.hasAttribute("data-sort-clear")) {
          const nextState = tableStates.get(table) || getInitialTableState();
          nextState.sort.key = "";
          nextState.sort.direction = "";
          tableStates.set(table, nextState);
          popover.hidden = true;
          getTableHeaderButtons(table).forEach((btn) => {
            btn.classList.remove("is-active");
          });
          applyFilterToTable(table);
          return;
        }

        if (target.hasAttribute("data-filter-apply")) {
          applyFromPopover();
          popover.hidden = true;
          getTableHeaderButtons(table).forEach((btn) => {
            btn.classList.remove("is-active");
          });
        }
      };
    };

    const closeAllPopovers = () => {
      panel.querySelectorAll("[data-header-filter-popover]").forEach((node) => {
        node.hidden = true;
      });
      panel.querySelectorAll(".results-header-filter-btn").forEach((btn) => {
        btn.classList.remove("is-active");
      });
    };

    if (filterRow) {
      filterRow.addEventListener("click", (event) => {
        const target = event.target;
        const btn = target instanceof HTMLElement ? target.closest("button[data-pos]") : null;
        if (!btn) return;

        const value = (btn.dataset.pos || "ALL").toUpperCase();

        tables.forEach((table) => {
          const state = tableStates.get(table) || getInitialTableState();

          if (value === "ALL") {
            state.posSet = new Set(["ALL"]);
          } else {
            state.posSet.delete("ALL");
            if (state.posSet.has(value)) {
              state.posSet.delete(value);
            } else {
              state.posSet.add(value);
            }
            if (!state.posSet.size) {
              state.posSet = new Set(["ALL"]);
            }
          }

          tableStates.set(table, state);
          applyFilterToTable(table);
        });

        syncAllButtons();
      });

      syncAllButtons();
    }

    tables.forEach((table) => {
      getTableHeaderButtons(table).forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.stopPropagation();
          const key = trigger.getAttribute("data-filter-trigger");
          if (!key) return;
          const popover = getTablePopover(table);
          const alreadyOpen = popover && !popover.hidden && trigger.classList.contains("is-active");
          closeAllPopovers();
          if (!alreadyOpen) {
            openPopover(table, trigger, key);
          }
        });
      });

      applyFilterToTable(table);
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.closest(".results-header-filter-popover")) return;
      if (target.closest(".results-header-filter-btn")) return;
      closeAllPopovers();
    });
  };

  updateInputsFromState();
  setDirty(false);
  validateSettingsInputs();
  updateSettingsSaveState();
  const storedResults = loadStoredResults();
  const didRenderStoredResults =
    storedResults && storedResults.slateId === SIM_SLATE_KEY
      ? renderResultsFromPayload(storedResults)
      : false;
  if (!didRenderStoredResults) {
    initResultsTools();
  }
  console.log("[sim] init complete");
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSimulator);
  } else {
    initSimulator();
  }
</script>

