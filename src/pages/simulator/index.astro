                      <button type="button" class="results-header-filter-btn" data-filter-trigger="position">Pos</button>
                    </th>
                    <th class="th-team">
                      <button type="button" class="results-header-filter-btn" data-filter-trigger="team">Team</button>
                    </th>
                    <th class="th-num">
                      <button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="salary">Salary</button>
                    </th>
                    <th class="th-num">
                      <button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="own">Own%</button>
                    </th>
                    <th class="th-num th-optimal-value">
                      <button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="optimal">Optimal Rate %</button>
                    </th>
                    <th class="th-num th-opt-lev">
                      <button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="lev">Opt Lev</button>
                    </th>
                    <th class="th-num">
                      <button type="button" class="results-header-filter-btn results-header-filter-btn--num" data-filter-trigger="retainedExp">Retained Exp</button>
                    </th>
                    <th class="th-bar-lane"></th>
                  </tr>
                </thead>
              </table>
            </div>

            <div class="results-table-wrap">
            <table
              class="slates-table results-table results-table-body"
              data-results-table
              data-bar-metric="retainedExposureRate"
              data-results-kind="exp"
            >
              <colgroup>
                <col class="col-player" />
                <col class="col-pos" />
                <col class="col-team" />
                <col class="col-salary" />
                <col class="col-own" />
                <col class="col-optimal-rate-value" />
                <col class="col-opt-lev" />
                <col class="col-retained-exp" />
                <col class="col-bar-lane" />
              </colgroup>
              <tbody>
                {results.players
                  .slice()
                  .sort(
                    (a, b) =>
                      b.retainedExposureRate - a.retainedExposureRate ||
                      b.optimalLeverage - a.optimalLeverage
                  )
                  .map((row) => (
                  <tr
                    data-pos={row.position}
                    data-name={row.name}
                    data-position={row.position}
                    data-team={row.team}
                    data-salary={row.salary}
                    data-own={row.ownership}
                    data-optimal={row.optimalSimRate}
                    data-lev={Math.abs(row.optimalLeverage) >= 10 ? row.optimalLeverage / 10 : row.optimalLeverage}
                    data-retainedexp={row.retainedExposureRate}
                  >
                    <td class="player-name-cell">{row.name}</td>
                    <td class="pos-cell">{row.position}</td>
                    <td class="team-cell">
                      <span class="team-cell-inner">
                        <span class="results-team-logo">
                          <img
                            src={`/simulator/team-logos/${row.team}.png`}
                            alt={`${row.team} logo`}
                            loading="lazy"
                            onerror="this.style.display='none';"
                          />
                        </span>
                        <span class="team-code">{row.team}</span>
                      </span>
                    </td>
                    <td class="num-cell salary-cell">${row.salary.toLocaleString()}</td>
                    <td class="num-cell own-cell">{row.ownership.toFixed(1)}%</td>
                    <td class="num-cell optimal-rate-value-cell">{row.optimalSimRate.toFixed(1)}%</td>
                    <td class="num-cell opt-lev-cell">{formatOptLevDisplay(row.optimalLeverage)}</td>
                    <td class="num-cell retained-exp-value-cell">{row.retainedExposureRate.toFixed(1)}%</td>
                    <td class="bar-lane-cell" data-bar-value={row.retainedExposureRate}>
                      <div class="bar-lane-shell">
                        <span class="bar-lane-track">
                          <span class="bar-lane-fill"></span>
                        </span>
                      </div>
                    </td>
                  </tr>
                ))}
                {results.players.length > 0 && (
                  <tr class="results-empty-row" data-empty-row="filter" style="display:none">
                    <td colSpan={9}>No players match this position filter.</td>
                  </tr>
                )}
                {results.players.length === 0 && (
                  <tr>
                    <td colSpan={9}>No exposures.</td>
                  </tr>
                )}
              </tbody>
            </table>
            <div class="results-header-filter-popover" data-header-filter-popover hidden></div>
            </div>
          </div>
        )}

        {results && activeSubtab === "graded" && (
          <div class="results-table-wrap">
            <table
              class="slates-table results-table"
              data-results-table
              data-bar-metric="frequencyRate"
            >
              <thead>
                <tr>
                  <th>EV</th>
                  <th>Top 0.1%</th>
                  <th>Top 1%</th>
                  <th>ITM</th>
                  <th>Salary Used</th>
                  <th>Avg Sim Total</th>
                  <th>Sum Own%</th>
                  <th>Frequency%</th>
                  <th>Lineup</th>
                </tr>
              </thead>
              <tbody>
                {(results.lineups ?? [])
                  .slice()
                  .sort(
                    (a, b) =>
                      (b.evScore ?? 0) - (a.evScore ?? 0) ||
                      (b.topPointOnePctRate ?? 0) - (a.topPointOnePctRate ?? 0) ||
                      (b.topOnePctRate ?? 0) - (a.topOnePctRate ?? 0) ||
                      (b.itmRate ?? 0) - (a.itmRate ?? 0)
                  )
                  .slice(0, 20)
                  .map((row) => (
                  <tr>
                    <td class="num-cell">{(row.evScore ?? 0).toFixed(2)}</td>
                    <td class="num-cell">{(row.topPointOnePctRate ?? 0).toFixed(2)}%</td>
                    <td class="num-cell">{(row.topOnePctRate ?? 0).toFixed(2)}%</td>
                    <td class="num-cell">{(row.itmRate ?? 0).toFixed(2)}%</td>
                    <td class="num-cell">${row.salaryUsed.toLocaleString()}</td>
                    <td class="num-cell">{row.averageSimTotal.toFixed(1)}</td>
                    <td class="num-cell">{row.sumOwnership.toFixed(1)}%</td>
                    <td class="bar-cell num-cell" data-bar-value={row.frequencyRate ?? 0}>
                      <div class="bar-track" aria-hidden="true">
                        <div class="bar-fill"></div>
                      </div>
                      <span class="bar-label">{row.frequencyRate.toFixed(1)}%</span>
                    </td>
                    <td class="lineup-cell">
                      {row.players.map((player) => `${player.position} ${player.name}`).join(" / ")}
                    </td>
                  </tr>
                ))}
                {(results.lineups ?? []).length === 0 && (
                  <tr>
                    <td colSpan={9}>No lineup aggregates available.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        )}
        </div>
      </div>
    )}
    </div>
  </section>
</Layout>

<script
  type="application/json"
  id="sim-data"
  set:html={JSON.stringify({
    slateKey: activeSlateKey,
    teamInputs,
    playerInputs,
    settings,
    activeTab,
    activeSubtab,
  })}
></script>
<script is:inline>
  const initSimulator = () => {
  console.log("[sim] boot");
  const simDataEl = document.getElementById("sim-data");
  const simData = simDataEl ? JSON.parse(simDataEl.textContent || "{}") : {};
  const SIM_SLATE_KEY = simData.slateKey || "";
  const SIM_TEAM_INPUTS = Array.isArray(simData.teamInputs) ? simData.teamInputs : [];
  const SIM_PLAYER_INPUTS = Array.isArray(simData.playerInputs) ? simData.playerInputs : [];
  const SIM_SETTINGS = simData.settings || null;
  const SIM_ACTIVE_TAB = simData.activeTab || "slates";
  const SIM_ACTIVE_SUBTAB = simData.activeSubtab || "ev";
  console.log("[sim] active tab", SIM_ACTIVE_TAB);
  console.log("[sim] active subtab", SIM_ACTIVE_SUBTAB);
  const SETTINGS_STORAGE_KEY = SIM_SLATE_KEY ? `sim-settings:${SIM_SLATE_KEY}` : "";
  const RESULTS_STORAGE_KEY = SIM_SLATE_KEY ? `sim-results:${SIM_SLATE_KEY}` : "";
  const statusEl = document.getElementById("sim-status");
  const validationEl = document.getElementById("sim-validation-summary");
  const saveBtn = document.getElementById("sim-save-btn");
  const resetBtn = document.getElementById("sim-reset-btn");
  const runBtn = document.getElementById("sim-run-btn");
  const saveSettingsBtn = document.getElementById("sim-save-settings");
  const runSettingsBtn = document.getElementById("sim-run-settings-btn");
  const settingsStatusEl = document.getElementById("sim-settings-status");
  const runOverlay = document.getElementById("sim-run-overlay");
  const runStatusEl = document.getElementById("sim-run-status");
  let runInProgress = false;
  let latestResults = null;
  const clone = (value) => {
    if (typeof structuredClone === "function") {
      return structuredClone(value);
    }
    if (value === undefined) return undefined;
    return JSON.parse(JSON.stringify(value));
  };

  const percentFields = new Set(["rushRate", "rushTdRatio", "sackRate"]);
  const rangeRules = {
    pointsScored: { min: 0 },
    pace: { min: 0 },
    rushRate: { min: 0, max: 100 },
    rushTdRatio: { min: 0, max: 100 },
    dstSalary: { min: 0 },
    sackRate: { min: 0, max: 100 },
    projection: { min: 0 },
    ownership: { min: 0, max: 100 },
    rushMarketShare: { min: 0, max: 100 },
    rushTdMarketShare: { min: 0, max: 100 },
    receivingMarketShare: { min: 0, max: 100 },
    receivingTdMarketShare: { min: 0, max: 100 },
    catchRate: { min: 0, max: 100 },
    passMarketShare: { min: 0, max: 100 },
    intRate: { min: 0, max: 100 },
  };
  const state = {
    teamInputs: clone(SIM_TEAM_INPUTS || []),
    playerInputs: clone(SIM_PLAYER_INPUTS || []),
  };
  let settingsState = clone(SIM_SETTINGS || null);
  let settingsBaseline = settingsState ? clone(settingsState) : null;
  let settingsDirty = false;
  let settingsInvalid = false;

  const safeJsonParse = (value) => {
    if (!value) return null;
    try {
      return JSON.parse(value);
    } catch {
      return null;
    }
  };

  const loadStoredSettings = () => {
    if (!SETTINGS_STORAGE_KEY) return null;
    const raw = safeJsonParse(localStorage.getItem(SETTINGS_STORAGE_KEY));
    if (!raw || typeof raw !== "object") return null;
    return raw;
  };

  const persistSettings = () => {
    if (!SETTINGS_STORAGE_KEY || !settingsState) return;
    try {
      localStorage.setItem(SETTINGS_STORAGE_KEY, JSON.stringify(settingsState));
    } catch {
      // Ignore storage errors (private mode / quota)
    }
  };

  const persistResults = (resultsPayload) => {
    if (!RESULTS_STORAGE_KEY || !resultsPayload) return;
    try {
      sessionStorage.setItem(RESULTS_STORAGE_KEY, JSON.stringify(resultsPayload));
    } catch {
      // Ignore storage errors (private mode / quota)
    }
  };

  const loadStoredResults = () => {
    if (!RESULTS_STORAGE_KEY) return null;
    const raw = safeJsonParse(sessionStorage.getItem(RESULTS_STORAGE_KEY));
    if (!raw || typeof raw !== "object") return null;
    return raw;
  };

  const mergeSettings = (base, overrides) => {
    if (!base) return base;
    if (!overrides || typeof overrides !== "object") return base;
    const normalizedProfile =
      overrides.payoutProfile === "flat" ? "cash" : overrides.payoutProfile ?? base.payoutProfile;
    return {
      ...base,
      ...overrides,
      slateId: base.slateId,
      payoutProfile: normalizedProfile ?? "standard",
    };
  };

  const storedSettings = loadStoredSettings();
  if (storedSettings && settingsState) {
    settingsState = mergeSettings(settingsState, storedSettings);
    settingsBaseline = settingsState ? clone(settingsState) : null;
  }

  const formatSettingValue = (field, value) => {
    if (value === null || value === undefined || !Number.isFinite(value)) return "";
    return Number(value).toLocaleString();
  };

  const syncSliderValues = () => {
    if (!settingsState) return;
    document.querySelectorAll("[data-setting-value]").forEach((node) => {
      const field = node.dataset.settingValue;
      if (!field || !(field in settingsState)) return;
      const value = settingsState[field];
      node.textContent = formatSettingValue(field, value);
    });
    document.querySelectorAll("input[data-setting-field]").forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;
      if (!settingsState) return;
      const field = input.dataset.settingField;
      if (!field || !(field in settingsState)) return;
      if (input.type === "range") {
        const value = settingsState[field];
        if (Number.isFinite(value)) input.value = String(value);
      }
    });
  };

  const syncPayoutProfileUI = () => {
    if (!settingsState) return;
    const current = settingsState.payoutProfile ?? "standard";
    document.querySelectorAll("input[name='payoutProfile']").forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;
      input.checked = input.value === current;
      input.closest(".sim-payout-option")?.classList.toggle("is-selected", input.checked);
    });
  };

  const applySettingsStateToInputs = () => {
    if (!settingsState) return;
    document.querySelectorAll("input[data-setting-field]").forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;
      const field = input.dataset.settingField;
      if (!field || !(field in settingsState)) return;
      const value = settingsState[field];
      if (input.type === "radio") {
        input.checked = value === input.value;
      } else {
        input.value = value === null || value === undefined ? "" : value;
      }
      input.classList.remove("input-error");
    });
    syncPayoutProfileUI();
    syncSliderValues();
  };

  applySettingsStateToInputs();
  let baseline = {
    teamInputs: clone(state.teamInputs),
    playerInputs: clone(state.playerInputs),
  };
  let dirty = false;
  let invalidCount = 0;
  let teamBlockingCount = 0;
  let teamWarningCount = 0;
  const fieldErrors = new Map();

  const teamIndex = new Map(state.teamInputs.map((row) => [`${row.gameId}-${row.team}`, row]));
  const playerIndex = new Map(state.playerInputs.map((row) => [row.id, row]));

  const setStatus = (message, tone) => {
    if (!statusEl) return;
    statusEl.textContent = message || "";
    statusEl.dataset.tone = tone || "";
  };

  const setSettingsStatus = (message, tone) => {
    if (!settingsStatusEl) return;
    settingsStatusEl.textContent = message || "";
    settingsStatusEl.dataset.tone = tone || "";
  };

  const showRunOverlay = () => {
    if (!runOverlay) return;
    console.log("[sim] overlay shown");
    if (runStatusEl) runStatusEl.textContent = "Starting simulation...";
    runOverlay.classList.add("is-visible");
    runOverlay.setAttribute("aria-hidden", "false");
    document.body.classList.add("sim-running");
  };

  const hideRunOverlay = () => {
    if (!runOverlay) return;
    runOverlay.classList.remove("is-visible");
    runOverlay.setAttribute("aria-hidden", "true");
    document.body.classList.remove("sim-running");
  };

  const escapeHtml = (value) =>
    String(value)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/\"/g, "&quot;")
      .replace(/'/g, "&#39;");

  const formatPayoutLabel = (profile) => {
    if (profile === "topHeavy") return "Top Heavy";
    if (profile === "cash" || profile === "flat") return "Cash";
    return "Standard";
  };

  const formatOptLevDisplay = (value) => {
    if (value === null || value === undefined || Number.isNaN(value)) return "—";
    if (!Number.isFinite(value)) return "—";
    const normalized = Math.abs(value) >= 10 ? value / 10 : value;
    return `${normalized.toFixed(1)}%`;
  };

  const formatNumber = (value, digits, fallback = "0.0") =>
    Number.isFinite(value) ? value.toFixed(digits) : fallback;
  const formatInteger = (value, fallback = "0") =>
    Number.isFinite(value) ? Number(value).toLocaleString() : fallback;

  const renderResultsFromPayload = (resultsPayload) => {
    if (SIM_ACTIVE_TAB !== "results") return false;
    const resultsContent = document.getElementById("sim-results-content");
    if (!resultsContent) return false;
    if (!resultsPayload || !Array.isArray(resultsPayload.players)) {
      resultsContent.dataset.hasResults = "false";
      resultsContent.innerHTML = `<p class="empty-state">No results yet. Run sims to generate results.</p>`;
      return false;
    }

    const summaryHtml = `
      <div class="results-summary-strip">
        <div class="summary-item">
          <span class="summary-label">Field</span>
          <span class="summary-value">${formatInteger(resultsPayload.settingsSnapshot?.fieldSize)}</span>
