---
import Layout from "../../../../layouts/Layout.astro";

const { sport, site, slateId } = Astro.params;
const sportSlug = (sport ?? "nfl").toLowerCase();
const siteSlug = (site ?? "draftkings").toLowerCase();
const title = `Simulator | ${sport ?? "Sport"} | ${site ?? "Site"} | ${slateId ?? "Slate"}`;
---

<Layout title={title} fullBleed>
  <main class="page">
    <header class="hero">
      <h1 class="title">Simulator: {sport ?? "Sport"} · {site ?? "Site"}</h1>
      <p class="sub">Slate detail view for {slateId ?? "slate"}.</p>
    </header>

    <nav class="breadcrumbs" aria-label="Simulator navigation">
      <a href="/simulator">Simulator</a>
      <span>/</span>
      <a href={`/simulator/${sportSlug}`}>{sportSlug}</a>
      <span>/</span>
      <a href={`/simulator/${sportSlug}/${siteSlug}`}>{siteSlug}</a>
      <span>/</span>
      <span>{slateId}</span>
    </nav>

    <section class="panel" aria-label="Slate detail">
      <h2 class="panel-title">Slate</h2>
      <p class="slate-id">{slateId}</p>
    </section>

    <section class="panel" aria-label="Placeholder simulator shell">
      <h2 class="panel-title">Simulator Shell</h2>
      <p class="sub">Inputs, settings, and results panels will render here.</p>
    </section>
  </main>
</Layout>

<style>
  .page {
    max-width: 980px;
    margin: 0 auto;
    padding: 28px 16px 64px;
  }

  .hero {
    margin: 8px 0 18px;
  }

  .title {
    margin: 0;
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .sub {
    margin: 10px 0 0;
    color: var(--muted);
  }

  .panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    background: var(--surface);
  }

  .breadcrumbs {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 0.9rem;
    margin-bottom: 14px;
  }

  .breadcrumbs a {
    color: var(--text);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .slate-id {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
  }

  .panel-title {
    margin: 0 0 10px;
    font-size: 18px;
    font-weight: 700;
  }

  .params {
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .params div {
    display: flex;
    gap: 12px;
  }

  dt {
    min-width: 80px;
    font-weight: 700;
    color: var(--text);
  }

  dd {
    margin: 0;
    color: var(--text-2);
  }
</style>
