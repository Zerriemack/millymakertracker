---

const __slateKey = String(Astro.params.slateKey ?? "").trim();
if (/^[0-9]{4}$/.test(__slateKey)) {
  return Astro.redirect(`/nfl/${__slateKey}?view=LIST`, 307);
}

import Layout from "../../layouts/Layout.astro";
import { prisma } from "../../lib/db";

const slateKey = Astro.params.slateKey;

const slate = await prisma.slate.findUnique({
  where: { slateKey },
  include: {
    season: true,
    contests: {
      orderBy: [{ topPrizeCents: "desc" }],
      include: {
        analysis: true,
        winners: {
          take: 1,
          orderBy: { points: "desc" },
        },
      },
    },
  },
});

const contest = slate?.contests?.[0] ?? null;
const winner = contest?.winners?.[0] ?? null;
const analysis = contest?.analysis ?? null;
---

<Layout title="Slate | MillyMakerTracker">
  <main class="container">
    {!slate ? (
      <>
        <h1>Slate not found</h1>
        <p>slateKey: {slateKey}</p>
      </>
    ) : (
      <>
        <a href="/nfl" style="text-decoration:none;">Back</a>

        <h1 style="margin-top:10px;">
          {slate.season.year} Week {slate.week} · {slate.slateType}
        </h1>

        <p>{new Date(slate.slateDate).toLocaleDateString()}</p>

        <div style="margin-top:14px; padding:14px; border:1px solid #eaeaea; border-radius:10px; max-width:900px;">
          <div><strong>Contest</strong>: {contest?.contestName ?? "TBD"}</div>

          <div style="margin-top:6px;">
            <strong>Winner</strong>: {winner?.username ?? "TBD"} ({winner?.points ?? "—"} pts)
          </div>

          <div style="margin-top:6px; color:#555;">
            <strong>Site Contest Id</strong>: {contest?.siteContestId ?? "—"}
          </div>

          {analysis?.stackSummary ? (
            <div style="margin-top:12px;">
              <div><strong>Stack</strong>: {analysis.stackSummary}</div>
            </div>
          ) : null}

          {analysis?.uniquenessNotes ? (
            <div style="margin-top:12px;">
              <div style="font-weight:600;">Why it won</div>
              <pre style="white-space:pre-wrap; margin:6px 0 0; color:#555; font-family:inherit;">
{analysis.uniquenessNotes}
              </pre>
            </div>
          ) : null}
        </div>
      </>
    )}
  </main>
</Layout>
