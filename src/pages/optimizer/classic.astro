  :global(.fake-check),
  :global(.blue-check) {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 0;
    border: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    outline: 0 !important;
    vertical-align: middle;
  }

  :global(.fake-check)::before,
  :global(.blue-check)::before {
    content: "×";
    display: block;
    font-size: 16px;
    line-height: 1;
    font-weight: 700;
    color: rgba(150, 170, 198, 0.72);
    transform: translateY(-1px);
  }

  :global(.fake-check)::after,
  :global(.blue-check)::after {
    content: none;
    display: none;
  }

  :global(.fake-check.checked)::before,
  :global(.blue-check.checked)::before {
    content: none;
    display: none;
  }

  :global(.fake-check.checked)::after,
  :global(.blue-check.checked)::after {
    content: "";
    display: block;
    width: 11px;
    height: 6px;
    border-left: 3px solid rgba(245, 250, 255, 0.98);
    border-bottom: 3px solid rgba(245, 250, 255, 0.98);
    transform: rotate(-45deg);
    transform-origin: center;
