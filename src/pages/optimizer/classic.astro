  <script
    type="application/json"
    id="classic-optimizer-data"
    set:html={JSON.stringify({
      selectedKey,
      topTabs,
      packages: packages.map((pack) => ({
        key: pack.key,
        slate: pack.slate,
        games: pack.games,
        teamInputs: pack.teamInputs,
        playerInputs: pack.playerInputs,
        settings: pack.settings,
      })),
      builderSlots,
      settingsToggles,
      defaultLineupCount: 1,
      defaultResultsLineups: 10,
      operatorMeta,
    })}
  />

  <script is:inline data-astro-rerun>
    const initClassicOptimizerPage = () => {
      const root = document.querySelector(".optimizer-page");
      if (!root) return;
      if (root.dataset.optimizerInitialized === "true") return;

      const markInitFailed = (error) => {
        console.error("[optimizer-init-failed]", error);
        root.dataset.optimizerInitialized = "false";

        const statusEl = document.querySelector("[data-results-status]");
        if (statusEl) {
          statusEl.textContent = `• ${error?.message || "Optimizer failed to initialize."}`;
          statusEl.style.display = "";
        }

        const poolStatusEl = document.querySelector("[data-pool-status]");
        if (poolStatusEl) {
          poolStatusEl.textContent = `• ${error?.message || "Optimizer failed to initialize."}`;
          poolStatusEl.style.display = "";
        }
      };

      const dataEl = document.getElementById("classic-optimizer-data");
      const data = dataEl ? JSON.parse(dataEl.textContent || "{}") : { packages: [] };
      const topTabs = Array.isArray(data.topTabs) ? data.topTabs : [];

    const state = {
      packages: data.packages || [],
      selectedKey: data.selectedKey || (data.packages?.[0]?.key ?? ""),
      weekValue: "",
      siteValue: "",
      positionFilter: "ALL",
      search: "",
      hideUnder: 0.1,
      hideUnderEnabled: false,
      includePlayers: new Set(),
      includeInitialized: false,
      lockedPlayers: new Set(),
      keyPlayers: new Set(),
      boostUnits: new Map(),
      manualProjection: new Map(),
      manualOwnership: new Map(),
      manualCeiling: new Map(),
      manualFloor: new Map(),
      minExposure: new Map(),
      maxExposure: new Map(),
      teamInclude: new Map(),
      teamInitialized: false,
      projectionMode: "default",
      varianceMode: "default",
      poolScope: "all",
      settings: Object.fromEntries((data.settingsToggles || []).map((s) => [s.id, s.checked])),
      excludeLockedGames: false,
      advanced: {
        randomness: 0,
        teamLimit: 0,
        maxRepeating: 0,
        minSalary: 0,
        maxSalary: 0,
        minProjection: 0,
        maxOwnership: 0,
      },
      advancedPanelOpen: false,
      focusedKeyPlayerId: null,
      advancedOpenSection: "roster",
      advancedRules: [],
      advancedDraftRule: null,
      optimizeBy: "projection",
      lineupCount: data.defaultLineupCount || 1,
      resultsLineups: data.defaultResultsLineups || 10,
      results: [],
      resultTags: new Map(),
      selectedLineups: new Set(),
      activeTag: null,
      resultsSort: "projection",
      ownMode: "sum",
      sidebarSearch: "",
      sidebarFlex: false,
      activeSidebarPanel: "",
      activeTopTab: "optimizer",
      builderTag: "",
      builderMessage: "",
      statusMessage: "",
      simResults: null,
      savedLineups: [],
      uploadedEntries: [],
      uploadedEntriesFile: null,
      entriesStatus: "",
      lateSwapResult: "",
      uploadedProjections: [],
      uploadedProjectionsMap: new Map(),
      uploadedProjectionsFile: null,
      projectionsStatus: "",
      useUploadedProjections: false,
    };

    const STORAGE_KEYS = {
      builder: "classic-optimizer-builder",
      builderTag: "classic-optimizer-builder-tag",
      results: "classic-optimizer-results",
      simResults: "classic-optimizer-sim-results",
      activeTopTab: "classic-optimizer-active-top-tab",
      savedLineups: "classic-optimizer-saved-lineups",
      uploadedEntries: "classic-optimizer-uploaded-entries",
      uploadedProjections: "classic-optimizer-uploaded-projections",
      useUploadedProjections: "classic-optimizer-use-uploaded-projections",
    };

    const safeStorageGet = (key) => {
      try {
        return localStorage.getItem(key);
      } catch (error) {
        console.warn("[optimizer-storage-get-failed]", key, error);
        return null;
      }
    };

    const safeStorageSet = (key, value) => {
      try {
        localStorage.setItem(key, value);
        return true;
      } catch (error) {
        console.warn("[optimizer-storage-set-failed]", key, error);
        return false;
      }
    };

    try {
      const saved = JSON.parse(safeStorageGet(STORAGE_KEYS.builder) || "null");
      if (saved) {
        if (Array.isArray(saved.locked)) state.lockedPlayers = new Set(saved.locked);
        if (Array.isArray(saved.include)) {
          state.includePlayers = new Set(saved.include);
          state.includeInitialized = true;
        }
        if (saved.settings && typeof saved.settings === "object") {
          state.settings = { ...state.settings, ...saved.settings };
        }
        if (saved.tag) state.builderTag = String(saved.tag);
      }
    } catch (error) {
      console.warn("Failed to load saved builder state", error);
    }

    const savedBuilderTag = safeStorageGet(STORAGE_KEYS.builderTag);
    if (savedBuilderTag) state.builderTag = savedBuilderTag;

    try {
      const savedTopTab = safeStorageGet(STORAGE_KEYS.activeTopTab);
      if (savedTopTab && topTabs.some((tab) => tab.id === savedTopTab)) {
        state.activeTopTab = savedTopTab;
      }
    } catch (error) {
      console.warn("Failed to load active top tab", error);
    }

    try {
      const savedResults = JSON.parse(safeStorageGet(STORAGE_KEYS.results) || "null");
      if (savedResults && Array.isArray(savedResults.results)) {
        state.savedLineups = savedResults.results;
        if (savedResults.resultTags && typeof savedResults.resultTags === "object") {
          state.resultTags = new Map(Object.entries(savedResults.resultTags));
        }
      }
    } catch (error) {
      console.warn("Failed to load saved optimizer results", error);
    }

    try {
      const savedDedicatedLineups = JSON.parse(safeStorageGet(STORAGE_KEYS.savedLineups) || "null");
      if (Array.isArray(savedDedicatedLineups)) {
        state.savedLineups = savedDedicatedLineups;
      }
    } catch (error) {
      console.warn("Failed to load saved lineups", error);
    }

    try {
      const savedEntries = JSON.parse(safeStorageGet(STORAGE_KEYS.uploadedEntries) || "null");
      if (Array.isArray(savedEntries)) {
        state.uploadedEntries = savedEntries;
        state.entriesStatus = savedEntries.length ? `Loaded ${savedEntries.length} parsed entries.` : "";
      }
    } catch (error) {
      console.warn("Failed to load uploaded entries", error);
    }

    try {
      const savedProjectionState = JSON.parse(safeStorageGet(STORAGE_KEYS.uploadedProjections) || "null");
      if (savedProjectionState && Array.isArray(savedProjectionState.rows)) {
        state.uploadedProjections = savedProjectionState.rows;
      }
    } catch (error) {
      console.warn("Failed to load uploaded projections", error);
    }

    state.useUploadedProjections = safeStorageGet(STORAGE_KEYS.useUploadedProjections) === "true";

    const qs = (sel) => document.querySelector(sel);
    const qsa = (sel) => Array.from(document.querySelectorAll(sel));

    const elements = {
      week: qs("[data-control=week]"),
      site: qs("[data-control=site]"),
      siteSelectedLogo: qs("[data-site-selected-logo]"),
      slate: qs("[data-control=slate]"),
      gamesStrip: qs("[data-games-strip]"),
      gamesLinks: qsa("[data-games-action]"),
      posTabs: qsa("[data-pos-tab]"),
      search: qs("[data-control=search]"),
      hideUnder: qs("[data-control=hide-under]"),
      hideUnderToggle: qs("[data-control=hide-under-toggle]"),
      hideUnderWrap: qs(".under-proj-toggle"),
      projections: qs("[data-control=projections]"),
      variance: qs("[data-control=variance]"),
      resetColumns: qs("[data-control=reset-columns]"),
      poolScope: qs("[data-control=pool-scope]"),
      playerRows: qs("[data-player-rows]"),
      playerCount: qs("[data-player-count]"),
      poolStatus: qs("[data-pool-status]"),
      settingsItems: qsa("[data-setting-id]"),
      settingsCard: qs(".optimizer-settings-card"),
      excludeLockedToggle: qs("[data-control=exclude-locked-games]"),
      excludeLockedWrap: qs(".exclude-toggle"),
      advancedOpen: qsa("[data-control=advanced-open]"),
      advancedPanel: qs("[data-advanced-panel]"),
      advancedSectionButtons: qsa("[data-advanced-section-btn]"),
      advancedSectionPanes: qsa("[data-advanced-section-pane]"),
      advancedPlayerGroups: qs("[data-advanced-player-groups]"),
      advancedCount: qs("[data-advanced-count]"),
      advancedFields: qsa("[data-advanced]"),
      builderSummary: qs("[data-builder-summary]"),
      builderCard: qs(".builder-card"),
      builderSlotsWrap: qs("[data-builder-slots]"),
      builderSlots: qsa("[data-builder-slots] .builder-slot"),
      resultsShell: qs(".optimizer-results-shell"),
      optimizeButtons: qsa("[data-action=optimize]"),
      lineupCount: qsa("[data-control=lineup-count]"),
      optimizeBy: qsa("[data-control=optimize-by]"),
      resultsLineups: qs("[data-control=results-lineups]"),
      resultsCount: qs("[data-results-count]"),
      resultsFiltered: qs("[data-results-filtered]"),
      resultsStatus: qs("[data-results-status]"),
      resultsSubtitle: qs("[data-results-subtitle]"),
      resultsSort: qs("[data-control=results-sort]"),
      resultsJump: qs("[data-control=results-jump]"),
      resultsOwnMode: qs("[data-control=results-own-mode]"),
      resultsFilterTag: qs("[data-action=results-filter-tag]"),
      lineupsGrid: qs("[data-lineups-grid]"),
      sidebarPlayers: qs("[data-sidebar-players]"),
      sidebarPlayerStacks: qs("[data-sidebar-player-stacks]"),
      sidebarGameStacks: qs("[data-sidebar-game-stacks]"),
      sidebarTeamStacks: qs("[data-sidebar-team-stacks]"),
      sidebarSearch: qs("[data-control=sidebar-search]"),
      sidebarFlex: qs("[data-control=sidebar-flex]"),
      sidebarTabs: qsa("[data-sidebar-tabs] .sidebar-tab"),
      sidebarPanels: qsa("[data-panel-view]"),
      topTabs: qsa("[data-top-tab]"),
      topPanels: qsa("[data-top-panel]"),
      resultsActions: qsa("[data-action^=results-]"),
      builderActions: qsa("[data-action^=builder-]"),
      savedLineups: qs("[data-saved-lineups]"),
      entriesUpload: qs("[data-control=entries-upload]"),
      entriesStatus: qs("[data-entries-status]"),
      entriesPreviewHead: qs("[data-entries-preview-head]"),
      entriesPreviewBody: qs("[data-entries-preview-body]"),
      lateSwapSummary: qs("[data-late-swap-summary]"),
      lateSwapResult: qs("[data-late-swap-result]"),
      projectionsUpload: qs("[data-control=projections-upload]"),
      projectionsStatus: qs("[data-projections-status]"),
      projectionsPreviewBody: qs("[data-projections-preview-body]"),
      projectionsActiveIndicator: qs("[data-projections-active-indicator]"),
    };

    const formatSalary = (value) => new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
      maximumFractionDigits: 0,
    }).format(value || 0);

    const formatAbbrevMoney = (value) => `$${(value / 1000).toFixed(1)}K`;

    const formatNumber = (value, digits = 2) =>
      Number.isFinite(value) ? Number(value).toFixed(digits) : "—";

    const normalizeName = (value) => String(value || "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
    const normalizeToken = (value) => String(value || "").toLowerCase().replace(/[^a-z0-9]/g, "");

    const parseCsvLine = (line) => {
      const cells = [];
      let current = "";
      let quoted = false;
      for (let index = 0; index < line.length; index += 1) {
        const char = line[index];
        if (char === '"') {
          if (quoted && line[index + 1] === '"') {
            current += '"';
            index += 1;
          } else {
            quoted = !quoted;
          }
          continue;
        }
        if (char === "," && !quoted) {
          cells.push(current.trim());
          current = "";
          continue;
        }
        current += char;
      }
      cells.push(current.trim());
      return cells;
    };

    const parseCsv = (text) => {
      const lines = String(text || "").split(/\r?\n/).filter((line) => line.trim());
      if (!lines.length) return [];
      const headers = parseCsvLine(lines[0]).map((header, index) => header || `column_${index + 1}`);
      return lines.slice(1).map((line) => {
        const values = parseCsvLine(line);
        return headers.reduce((row, header, index) => {
          row[header] = values[index] ?? "";
          return row;
        }, {});
      });
    };

    const getRowValue = (row, keys) => {
      const entries = Object.entries(row || {});
      const lowered = entries.reduce((acc, [key, value]) => {
        acc[key.toLowerCase()] = value;
        return acc;
      }, {});
      for (const key of keys) {
        const value = lowered[key];
        if (value !== undefined && value !== null && String(value).trim() !== "") return String(value).trim();
      }
      return "";
    };

    const clampValue = (value, min, max, fallback = min) => {
      if (!Number.isFinite(value)) return fallback;
      return Math.min(Math.max(value, min), max);
    };

    const getUploadedProjectionValue = (player) => {
      if (!state.useUploadedProjections) return null;
      const nameKey = normalizeName(player.name);
      const teamKey = normalizeToken(player.team);
      const positionKey = normalizeToken(player.position);
      const exact = state.uploadedProjectionsMap.get(`${nameKey}|${teamKey}|${positionKey}`)
        || state.uploadedProjectionsMap.get(`${nameKey}|${teamKey}|`)
        || state.uploadedProjectionsMap.get(`${nameKey}||${positionKey}`)
        || state.uploadedProjectionsMap.get(`${nameKey}||`);
      return Number.isFinite(exact) ? exact : null;
    };

    const getPlayerBoostUnits = (playerId) => clampValue(Number(state.boostUnits.get(playerId) || 0), -5, 5, 0);

    const setPlayerBoostUnits = (playerId, value) => {
      state.boostUnits.set(playerId, clampValue(Number(value), -5, 5, 0));
    };

    const getEffectiveProjection = (player) => {
      const manual = Number(state.manualProjection.get(player.id));
      if (Number.isFinite(manual)) return Math.max(0, manual);
      const uploaded = getUploadedProjectionValue(player);
      if (Number.isFinite(uploaded)) return Math.max(0, uploaded);
      return Math.max(0, Number(player.projection) || 0);
    };

    const getEffectiveOwnership = (player) => {
      const manual = Number(state.manualOwnership.get(player.id));
      if (Number.isFinite(manual)) return clampValue(manual, 0, 100, 0);
      return clampValue(Number(player.ownership) || 0, 0, 100, 0);
    };

    const getEffectiveCeiling = (player) => {
      const manual = Number(state.manualCeiling.get(player.id));
      if (Number.isFinite(manual)) return Math.max(0, manual);
      return getEffectiveProjection(player) * 1.6;
    };

    const getEffectiveFloor = (player) => {
      const manual = Number(state.manualFloor.get(player.id));
      if (Number.isFinite(manual)) return Math.max(0, manual);
      return getEffectiveProjection(player) * 0.6;
    };

    const getPlayerProjection = (player) => getEffectiveProjection(player);

    const buildTeamLogoCell = (team) => `
      <span class="player-team-logo">
        <img
          src="/simulator/team-logos/${team}.png"
          class="player-team-logo-img"
          alt="${team} logo"
          loading="lazy"
          onload="this.nextElementSibling.style.display='none';"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
        />
        <span class="player-team-logo-fallback">${team}</span>
      </span>
    `;

    const createDraftRule = (playerId) => ({
      type: "if_then",
      enabled: true,
      trigger: { playerId: playerId || "" },
      operator: "require_one_of",
      targetType: "player",
      targetValue: "",
      count: 1,
    });

    const getPlayerById = (playerId) => getEffectivePlayers().find((player) => player.id === playerId) || null;

    const describeAdvancedRule = (rule) => {
      if (!rule) return "";
      const triggerPlayer = getPlayerById(rule.trigger?.playerId);
      const triggerLabel = triggerPlayer?.name || "Unknown player";
      if (rule.operator === "exclude_player") {
        const targetPlayer = getPlayerById(rule.targetValue);
        return `If lineup contains ${triggerLabel}, exclude ${targetPlayer?.name || "selected player"}.`;
      }
      const targetLabel =
        rule.targetType === "player"
          ? getPlayerById(rule.targetValue)?.name || "selected player"
          : rule.targetValue || rule.targetType;
      return `If lineup contains ${triggerLabel}, require at least ${rule.count || 1} ${targetLabel}.`;
    };

    const isValidAdvancedRule = (rule) => {
      if (!rule || !rule.enabled || rule.type !== "if_then") return false;
      if (!rule.trigger?.playerId) return false;
      if (rule.operator === "exclude_player") {
        return rule.targetType === "player" && !!rule.targetValue && rule.targetValue !== rule.trigger.playerId;
      }
      if (rule.operator === "require_one_of") {
        if (!["player", "team", "position"].includes(rule.targetType)) return false;
        if (!rule.targetValue) return false;
        return Number(rule.count) > 0;
      }
      return false;
    };

    const rebuildUploadedProjectionsMap = () => {
      state.uploadedProjectionsMap = new Map();
      state.uploadedProjections.forEach((row) => {
        const projection = Number(row.projection);
        if (!Number.isFinite(projection)) return;
        const key = `${normalizeName(row.name)}|${normalizeToken(row.team)}|${normalizeToken(row.position)}`;
        const fallbackKey = `${normalizeName(row.name)}||`;
        state.uploadedProjectionsMap.set(key, projection);
        if (!state.uploadedProjectionsMap.has(fallbackKey)) {
          state.uploadedProjectionsMap.set(fallbackKey, projection);
        }
      });
    };

    const persistSavedLineups = () => {
      safeStorageSet(STORAGE_KEYS.savedLineups, JSON.stringify(state.savedLineups));
      safeStorageSet(
        STORAGE_KEYS.results,
        JSON.stringify({
          results: state.savedLineups,
