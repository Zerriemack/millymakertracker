---
import Layout from "../layouts/Layout.astro";

const cards = [
  { title: "NFL Showdown Review", href: "/analysis/nfl/showdown" },
  { title: "NFL Classic Review (All Years)", href: "/analysis/nfl/classic" },
];
---

<Layout title="Review | Milly Maker Tracker">
  <main class="page">
    <header class="hero">
      <h1 class="title">Review</h1>
      <p class="sub">
        This section is the season wide view. It is built for scanning patterns, spotting repeats, and drilling into the slates that need a second look.
      </p>
    </header>

    <section class="grid" aria-label="Review pages">
      {cards.map((c) => (
        <a class="card" href={c.href}>
          <h2 class="card-title">{c.title}</h2>
        </a>
      ))}
    </section>
  </main>
</Layout>

<style>
  .page { max-width: 1100px; margin: 0 auto; padding: 26px 16px 60px; }

  .hero { margin: 6px 0 18px; }
  .title { margin: 0; font-size: 38px; letter-spacing: -0.02em; }
  .sub { margin: 10px 0 0; max-width: 78ch; color: #4b5563; line-height: 1.65; }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 18px;
  }

  @media (min-width: 900px) {
    .grid { grid-template-columns: 1fr 1fr; }
  }

  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 16px;
    padding: 18px;
    background: #fff;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    transition: transform 120ms ease, box-shadow 120ms ease;
  }

  .card:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 34px rgba(0,0,0,0.08);
  }

  .card-title { margin: 0; font-size: 18px; }
</style>
