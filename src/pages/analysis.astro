---
import Layout from "../layouts/Layout.astro";

const cards = [
  { title: "NFL Showdown Review", href: "/analysis/nfl/showdown" },
  { title: "NFL Classic Review", href: "/analysis/nfl/classic" },
];
---

<Layout title="Review | Milly Maker Tracker">
  <main class="page">
    <header class="hero">
      <h1 class="title">Review</h1>
      <p class="sub">
        Use this section to review slates by season and format. It is built for scanning results and opening slates for deeper review.
      </p>
    </header>

    <section class="grid" aria-label="Review pages">
      {cards.map((c) => (
        <a class="card" href={c.href}>
          <h2 class="card-title">{c.title}</h2>
        </a>
      ))}
    </section>
  </main>
</Layout>

<style>
  :root{
    --surface:#1f1f1f;
    --surface2:#181818;
    --border:rgba(255,255,255,.10);
    --border2:rgba(255,255,255,.12);
    --text:rgba(255,255,255,.92);
    --muted:rgba(255,255,255,.70);
    --shadow:0 18px 55px rgba(0,0,0,.55);
    --shadowSoft:0 12px 30px rgba(0,0,0,.40);
  }

  .page{
    max-width:1100px;
    margin:0 auto;
    padding:26px 16px 70px;
    color:var(--text);
  }

  .hero{margin:10px 0 18px}
  .title{margin:0;font-size:44px;letter-spacing:-0.02em;font-weight:950}
  .sub{margin:10px 0 0;max-width:78ch;color:var(--muted);line-height:1.65;font-weight:650}

  /* hard reset so the wrapper never looks like a "big pill" */
  main.page > section.grid{
    background: transparent;
    border: 0;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
    margin: 22px 0 0;
  }

  .grid{
    display:grid;
    grid-template-columns:1fr;
    gap:16px;
    align-items:start;
  }

  @media (min-width: 900px){
    .grid{grid-template-columns:1fr 1fr}
  }

  /* bigger pills */
  .card{
    display:block;
    text-decoration:none;
    color:var(--text);
    border:1px solid var(--border2);
    border-radius:18px;
    padding:24px;
    background:var(--surface);
    box-shadow:var(--shadowSoft);
    transition:transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease, background 120ms ease;
  }

  .card:hover{
    transform:translateY(-1px);
    border-color:rgba(255,255,255,.16);
    background:#232323;
    box-shadow:var(--shadow);
  }

  .card-title{
    margin:0;
    font-size:20px;
    font-weight:950;
    letter-spacing:-0.01em;
  }

  @media (prefers-reduced-motion: reduce){
    .card{transition:none}
  }
</style>