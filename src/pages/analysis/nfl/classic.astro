---
// src/pages/analysis/nfl/classic.astro
import Layout from "../../../layouts/Layout.astro";

const apiUrl = `${Astro.url.origin}/api/analysis/nfl/classic`;
const res = await fetch(apiUrl);

if (!res.ok) {
  throw new Error(`Analysis API failed: ${res.status} ${res.statusText} (${apiUrl})`);
}

const data = await res.json();
const rowsRaw = Array.isArray(data?.rows) ? data.rows : Array.isArray(data?.items) ? data.items : [];

function n(v: any) {
  const x = Number(v);
  return Number.isFinite(x) ? x : null;
}

function fmtDate(iso: any) {
  const s = String(iso || "");
  if (!s) return "—";
  const d = new Date(s);
  if (Number.isNaN(d.getTime())) return s;
  return new Intl.DateTimeFormat("en-US", { month: "short", day: "2-digit" }).format(d);
}

function moneyCents(v: any) {
  const x = n(v);
  if (x === null) return "—";
  return `$${(x / 100).toLocaleString("en-US")}`;
}

function median(vals: number[]) {
  if (!vals.length) return null;
  const a = [...vals].sort((x, y) => x - y);
  const mid = Math.floor(a.length / 2);
  return a.length % 2 ? a[mid] : (a[mid - 1] + a[mid]) / 2;
}

function mode(vals: number[]) {
  if (!vals.length) return null;
  const m = new Map<number, number>();
  for (const v of vals) m.set(v, (m.get(v) || 0) + 1);
  let best: number | null = null;
  let bestC = 0;
  for (const [k, c] of m.entries()) {
    if (c > bestC) {
      bestC = c;
      best = k;
    }
  }
  return best;
}

function minMax(vals: number[]) {
  if (!vals.length) return { min: null as number | null, max: null as number | null };
  let mn = vals[0];
  let mx = vals[0];
  for (const v of vals) {
    if (v < mn) mn = v;
    if (v > mx) mx = v;
  }
  return { min: mn, max: mx };
}

function countsByKey(list: any[], key: string) {
  const m = new Map<string, number>();
  for (const it of list) {
    const k = String((it as any)[key] ?? "").trim();
    if (!k) continue;
    m.set(k, (m.get(k) || 0) + 1);
  }
  return m;
}

function mostLeast(map: Map<string, number>) {
  const entries = Array.from(map.entries());
  if (!entries.length) return { most: null as any, least: null as any };
  let most = entries[0];
  let least = entries[0];
  for (const e of entries) {
    if (e[1] > most[1]) most = e;
    if (e[1] < least[1]) least = e;
  }
  return { most, least };
}

function ynFromCount(v: any) {
  const x = n(v);
  if (x === null) return "";
  return x > 0 ? "YES" : "NO";
}

function sum(nums: number[]) {
  return nums.reduce((a, b) => a + b, 0);
}

const rows = rowsRaw
  .map((r: any) => {
    const slateId = String(r.slateId ?? r.id ?? r.slate?.id ?? "");
    const week = Number(r.week ?? r.slate?.week ?? null);
    const slateType = String(r.slateType ?? r.slate?.slateType ?? "");
    const slateDate = String(r.slateDate ?? r.slate?.slateDate ?? r.date ?? "");

    const year =
      typeof r.year === "number"
        ? r.year
        : typeof r.slate?.season?.year === "number"
          ? r.slate.season.year
          : null;

    const salaryCap =
      typeof r.salaryCapCents === "number"
        ? r.salaryCapCents
        : typeof r.slate?.salaryCapCents === "number"
          ? r.slate.salaryCapCents
          : 50000;

    const salaryUsed = typeof r.salaryUsed === "number" ? r.salaryUsed : n(r.lineup?.salaryUsed);
    const salaryLeft =
      typeof r.salaryLeft === "number"
        ? r.salaryLeft
        : typeof salaryUsed === "number" && typeof salaryCap === "number"
          ? salaryCap - salaryUsed
          : null;

    const ownPct =
      typeof r.totalOwnershipPct === "number"
        ? r.totalOwnershipPct
        : typeof r.totalOwnershipBp === "number"
          ? r.totalOwnershipBp / 100
          : typeof r.contest?.totalOwnershipBp === "number"
            ? r.contest.totalOwnershipBp / 100
            : typeof r.lineup?.totalOwnershipBp === "number"
              ? r.lineup.totalOwnershipBp / 100
              : null;

    const pts =
      typeof r.points === "number"
        ? r.points
        : typeof r.winnerPoints === "number"
          ? r.winnerPoints
          : typeof r.winner?.points === "number"
            ? r.winner.points
            : typeof r.totalPoints === "number"
              ? r.totalPoints
              : typeof r.lineup?.totalPoints === "number"
                ? r.lineup.totalPoints
                : null;

    const topPrizeCents =
      typeof r.topPrizeCents === "number"
        ? r.topPrizeCents
        : typeof r.contest?.topPrizeCents === "number"
          ? r.contest.topPrizeCents
          : null;

    const qbStack = String(r.qbStack ?? r.stack ?? r.construction?.qbStack ?? "");

    const maxFromTeam = typeof r.maxFromTeam === "number" ? r.maxFromTeam : n(r.construction?.maxFromTeam);
    const maxFromGame = typeof r.maxFromGame === "number" ? r.maxFromGame : n(r.construction?.maxFromGame);

    const stackCount = typeof r.stackCount === "number" ? r.stackCount : n(r.construction?.stackCount);
    const bringbackCount = typeof r.bringbackCount === "number" ? r.bringbackCount : n(r.construction?.bringbackCount);
    const hasBringback = String(r.hasBringback ?? ynFromCount(bringbackCount));

    const earlyCount =
      typeof r.earlyCount === "number"
        ? r.earlyCount
        : typeof r.lineup?.analysis?.earlyCount === "number"
          ? r.lineup.analysis.earlyCount
          : n(r.construction?.earlyCount);

    const lateCount =
      typeof r.lateCount === "number"
        ? r.lateCount
        : typeof r.lineup?.analysis?.lateCount === "number"
          ? r.lineup.analysis.lateCount
          : n(r.construction?.lateCount);

    // ownership bucket counts for the 9-man Classic winning lineup
    // API should return these as integers, sum must be 9
    const own0_10 = typeof r.own0_10 === "number" ? r.own0_10 : n(r.ownership_0_10 ?? r.construction?.own0_10);
    const own11_19 = typeof r.own11_19 === "number" ? r.own11_19 : n(r.ownership_11_19 ?? r.construction?.own11_19);
    const own20p = typeof r.own20p === "number" ? r.own20p : n(r.ownership_20p ?? r.construction?.own20p);

    const ownBucketTotal =
      (typeof own0_10 === "number" ? own0_10 : 0) +
      (typeof own11_19 === "number" ? own11_19 : 0) +
      (typeof own20p === "number" ? own20p : 0);

    const tag = String(r.slateTag ?? r.slate?.slateTag ?? "");
    const group = String(r.slateGroup ?? r.slate?.slateGroup ?? "");

    const link =
      typeof r.link === "string" && r.link
        ? r.link
        : typeof r.url === "string" && r.url
          ? r.url
          : slateId && year
            ? `/nfl/${year}/slate/${slateId}`
            : "";

    return {
      slateId,
      year,
      week,
      slateType,
      slateDate,
      tag,
      group,
      link,

      qbStack,
      stackCount,
      bringbackCount,
      hasBringback,

      maxFromTeam,
      maxFromGame,

      earlyCount,
      lateCount,

      // new
      own0_10,
      own11_19,
      own20p,
      ownBucketTotal,

      salaryLeft,
      ownPct,
      pts,
      topPrizeCents,
    };
  })
  .filter((r: any) => r.slateId);

const salaryLeftVals = rows.map((r) => n(r.salaryLeft)).filter((v): v is number => v !== null);
const ownPctVals = rows.map((r) => n(r.ownPct)).filter((v): v is number => v !== null);
const ptsVals = rows.map((r) => n(r.pts)).filter((v): v is number => v !== null);

const maxFromTeamVals = rows.map((r) => n(r.maxFromTeam)).filter((v): v is number => v !== null);
const maxFromGameVals = rows.map((r) => n(r.maxFromGame)).filter((v): v is number => v !== null);

const stackCountVals = rows.map((r) => n(r.stackCount)).filter((v): v is number => v !== null);
const bringbackCountVals = rows.map((r) => n(r.bringbackCount)).filter((v): v is number => v !== null);

const earlyVals = rows.map((r) => n(r.earlyCount)).filter((v): v is number => v !== null);
const lateVals = rows.map((r) => n(r.lateCount)).filter((v): v is number => v !== null);

const own0Vals = rows.map((r) => n(r.own0_10)).filter((v): v is number => v !== null);
const own11Vals = rows.map((r) => n(r.own11_19)).filter((v): v is number => v !== null);
const own20Vals = rows.map((r) => n(r.own20p)).filter((v): v is number => v !== null);
const ownTotVals = rows.map((r) => n(r.ownBucketTotal)).filter((v): v is number => v !== null);

const salaryLeftMM = minMax(salaryLeftVals);
const ownPctMM = minMax(ownPctVals);
const ptsMM = minMax(ptsVals);

const maxFromTeamMM = minMax(maxFromTeamVals);
const maxFromGameMM = minMax(maxFromGameVals);

const stackCountMM = minMax(stackCountVals);
const bringbackCountMM = minMax(bringbackCountVals);

const earlyMM = minMax(earlyVals);
const lateMM = minMax(lateVals);

const own0MM = minMax(own0Vals);
const own11MM = minMax(own11Vals);
const own20MM = minMax(own20Vals);
const ownTotMM = minMax(ownTotVals);

const salaryLeftMedian = median(salaryLeftVals);
const ownMedian = median(ownPctVals);
const ptsMedian = median(ptsVals);

const maxFromTeamMedian = median(maxFromTeamVals);
const maxFromGameMedian = median(maxFromGameVals);

const stackCountMedian = median(stackCountVals);
const bringbackMedian = median(bringbackCountVals);

const earlyMedian = median(earlyVals);
const lateMedian = median(lateVals);

const own0Median = median(own0Vals);
const own11Median = median(own11Vals);
const own20Median = median(own20Vals);
const ownTotMedian = median(ownTotVals);

const salaryLeftMode = mode(salaryLeftVals);

const stackShapeCounts = countsByKey(rows, "qbStack");
const stackShapeML = mostLeast(stackShapeCounts);

const bringbackFlagCounts = countsByKey(rows, "hasBringback");
const bringbackFlagLines = Array.from(bringbackFlagCounts.entries()).length
  ? Array.from(bringbackFlagCounts.entries()).sort((a, b) => b[1] - a[1]).map(([k, v]) => ({ k, v }))
  : [];

const stackShapeLines = Array.from(stackShapeCounts.entries()).length
  ? Array.from(stackShapeCounts.entries()).sort((a, b) => b[1] - a[1]).map(([k, v]) => ({ k, v }))
  : [];

const typeCounts = countsByKey(rows, "slateType");
const typeLines = Array.from(typeCounts.entries()).length
  ? Array.from(typeCounts.entries()).sort((a, b) => b[1] - a[1]).map(([k, v]) => ({ k, v }))
  : [];

function pct(part: number, total: number) {
  if (!total) return "0.0%";
  return `${((part / total) * 100).toFixed(1)}%`;
}

const bringbackYes = bringbackFlagCounts.get("YES") || 0;
const bringbackNo = bringbackFlagCounts.get("NO") || 0;

const pageTitle = "NFL Classic Review";
---

<Layout title={pageTitle}>
  <main class="page">
    <header class="topbar">
      <div class="titleBlock">
        <h1 class="h1">{pageTitle}</h1>
        <div class="sub">
          Rows: <span id="shownCount">{rows.length}</span> / {rows.length}
        </div>
      </div>

      <div class="searchWrap">
        <label class="srOnly" for="q">Search</label>
        <input
          id="q"
          class="search"
          type="text"
          placeholder="Search: 2018, WK 2, MAIN, QB+2, YES, max 4, early 6, TAG, GROUP"
        />
        <button id="resetAllTop" class="resetAll" type="button">Reset all</button>
      </div>
    </header>

    <section class="grid">
      <aside class="sidebar">
        <div class="card">
          <div class="cardTitle">Distribution</div>
          <div class="kv">
            <div class="k">Salary left</div>
            <div class="v mono">
              <div>Median: {salaryLeftMedian === null ? "—" : salaryLeftMedian.toFixed(0)}</div>
              <div>Most: {salaryLeftMM.max === null ? "—" : salaryLeftMM.max.toFixed(0)}</div>
              <div>Least: {salaryLeftMM.min === null ? "—" : salaryLeftMM.min.toFixed(0)}</div>
              <div>Mode: {salaryLeftMode === null ? "—" : String(salaryLeftMode)}</div>
            </div>

            <div class="k">Total ownership</div>
            <div class="v mono">
              <div>Median: {ownMedian === null ? "—" : `${ownMedian.toFixed(2)}%`}</div>
              <div>Most: {ownPctMM.max === null ? "—" : `${ownPctMM.max.toFixed(2)}%`}</div>
              <div>Least: {ownPctMM.min === null ? "—" : `${ownPctMM.min.toFixed(2)}%`}</div>
            </div>

            <div class="k">Winner points</div>
            <div class="v mono">
              <div>Median: {ptsMedian === null ? "—" : ptsMedian.toFixed(2)}</div>
              <div>Most: {ptsMM.max === null ? "—" : ptsMM.max.toFixed(2)}</div>
              <div>Least: {ptsMM.min === null ? "—" : ptsMM.min.toFixed(2)}</div>
            </div>

            <div class="k">Max from one team</div>
            <div class="v mono">
              <div>Median: {maxFromTeamMedian === null ? "—" : maxFromTeamMedian.toFixed(0)}</div>
              <div>Most: {maxFromTeamMM.max === null ? "—" : maxFromTeamMM.max.toFixed(0)}</div>
              <div>Least: {maxFromTeamMM.min === null ? "—" : maxFromTeamMM.min.toFixed(0)}</div>
            </div>

            <div class="k">Max from one game</div>
            <div class="v mono">
              <div>Median: {maxFromGameMedian === null ? "—" : maxFromGameMedian.toFixed(0)}</div>
              <div>Most: {maxFromGameMM.max === null ? "—" : maxFromGameMM.max.toFixed(0)}</div>
              <div>Least: {maxFromGameMM.min === null ? "—" : maxFromGameMM.min.toFixed(0)}</div>
            </div>

            <div class="k">Windows</div>
            <div class="v mono">
              <div>Early median: {earlyMedian === null ? "—" : earlyMedian.toFixed(0)} (min {earlyMM.min ?? "—"} max {earlyMM.max ?? "—"})</div>
              <div>Late median: {lateMedian === null ? "—" : lateMedian.toFixed(0)} (min {lateMM.min ?? "—"} max {lateMM.max ?? "—"})</div>
            </div>

            <div class="k">Ownership buckets (players)</div>
            <div class="v mono">
              <div>0–10% median: {own0Median === null ? "—" : own0Median.toFixed(0)} (min {own0MM.min ?? "—"} max {own0MM.max ?? "—"})</div>
              <div>11–19% median: {own11Median === null ? "—" : own11Median.toFixed(0)} (min {own11MM.min ?? "—"} max {own11MM.max ?? "—"})</div>
              <div>20%+ median: {own20Median === null ? "—" : own20Median.toFixed(0)} (min {own20MM.min ?? "—"} max {own20MM.max ?? "—"})</div>
              <div>Total median: {ownTotMedian === null ? "—" : ownTotMedian.toFixed(0)} (min {ownTotMM.min ?? "—"} max {ownTotMM.max ?? "—"})</div>
              <div class="tinyNote">Total must be 9 for Classic. Any row not 9 is missing bucket data.</div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="cardTitle">Construction</div>
          <div class="kv">
            <div class="k">QB stack shape</div>
            <div class="v mono">
              {stackShapeLines.length ? (
                <div class="lines">
                  {stackShapeLines.map((x) => (
                    <div>{x.k}: {x.v}</div>
                  ))}
                </div>
              ) : (
                <div>—</div>
              )}
              <div class="spacer"></div>
              <div>Most: {stackShapeML.most ? `${stackShapeML.most[0]} (${stackShapeML.most[1]})` : "—"}</div>
              <div>Least: {stackShapeML.least ? `${stackShapeML.least[0]} (${stackShapeML.least[1]})` : "—"}</div>
            </div>

            <div class="k">Bringback</div>
            <div class="v mono">
              {bringbackFlagLines.length ? (
                <div class="lines">
                  {bringbackFlagLines.map((x) => (
                    <div>{x.k}: {x.v}</div>
                  ))}
                </div>
              ) : (
                <div>—</div>
              )}
              <div class="spacer"></div>
              <div>YES rate: {pct(bringbackYes, bringbackYes + bringbackNo)}</div>
              <div>NO rate: {pct(bringbackNo, bringbackYes + bringbackNo)}</div>
            </div>

            <div class="k">Stack links count</div>
            <div class="v mono">
              <div>Median: {stackCountMedian === null ? "—" : stackCountMedian.toFixed(0)}</div>
              <div>Most: {stackCountMM.max === null ? "—" : stackCountMM.max.toFixed(0)}</div>
              <div>Least: {stackCountMM.min === null ? "—" : stackCountMM.min.toFixed(0)}</div>
            </div>

            <div class="k">Bringback links count</div>
            <div class="v mono">
              <div>Median: {bringbackMedian === null ? "—" : bringbackMedian.toFixed(0)}</div>
              <div>Most: {bringbackCountMM.max === null ? "—" : bringbackCountMM.max.toFixed(0)}</div>
              <div>Least: {bringbackCountMM.min === null ? "—" : bringbackCountMM.min.toFixed(0)}</div>
            </div>

            <div class="k">Slate types</div>
            <div class="v mono">
              {typeLines.length ? (
                <div class="lines">
                  {typeLines.map((x) => (
                    <div>{x.k}: {x.v}</div>
                  ))}
                </div>
              ) : (
                <div>—</div>
              )}
            </div>
          </div>
        </div>
      </aside>

      <section class="main">
        <div class="tableWrap">
          <table id="t">
            <thead>
              <tr>
                <th class="colYear"><button class="thBtn" type="button" data-col="year">YEAR</button></th>
                <th class="colWk"><button class="thBtn" type="button" data-col="week">WEEK</button></th>
                <th class="colType"><button class="thBtn" type="button" data-col="type">TYPE</button></th>
                <th class="colDate"><button class="thBtn" type="button" data-col="date">DATE</button></th>

                <th class="colStack"><button class="thBtn" type="button" data-col="stack">STACK</button></th>
                <th class="colBring"><button class="thBtn" type="button" data-col="bring">BRING BACK</button></th>

                <th class="colMax"><button class="thBtn" type="button" data-col="maxTeam">MAX FROM TEAM</button></th>
                <th class="colMaxG"><button class="thBtn" type="button" data-col="maxGame">MAX FROM GAME</button></th>

                <th class="colEarly"><button class="thBtn" type="button" data-col="early">EARLY PLAYERS</button></th>
                <th class="colLate"><button class="thBtn" type="button" data-col="late">LATE PLAYERS</button></th>

                <th class="colLeft"><button class="thBtn" type="button" data-col="left">SALARY LEFT</button></th>
                <th class="colOwn"><button class="thBtn" type="button" data-col="own">TOTAL OWNERSHIP</button></th>

                <th class="colB0"><button class="thBtn" type="button" data-col="b0">OWN 0–10</button></th>
                <th class="colB11"><button class="thBtn" type="button" data-col="b11">OWN 11–19</button></th>
                <th class="colB20"><button class="thBtn" type="button" data-col="b20">OWN 20+</button></th>
                <th class="colBtot"><button class="thBtn" type="button" data-col="btot">BUCKET TOTAL</button></th>

                <th class="colPts"><button class="thBtn" type="button" data-col="pts">WINNER POINTS</button></th>
                <th class="colPrize"><button class="thBtn" type="button" data-col="top">TOP PRIZE</button></th>
                <th class="colTag"><button class="thBtn" type="button" data-col="tag">TAG</button></th>
                <th class="colGroup"><button class="thBtn" type="button" data-col="group">GROUP</button></th>
                <th class="colLink"></th>
              </tr>
            </thead>

            <tbody>
              {rows.map((r) => {
                const year = Number.isFinite(r.year as any) ? String(r.year) : "";
                const wk = Number.isFinite(r.week as any) ? String(r.week) : "";

                const left = n(r.salaryLeft);
                const own = n(r.ownPct);
                const pts = n(r.pts);
                const top = n(r.topPrizeCents);

                const maxTeam = n(r.maxFromTeam);
                const maxGame = n(r.maxFromGame);

                const early = n(r.earlyCount);
                const late = n(r.lateCount);

                const b0 = n(r.own0_10);
                const b11 = n(r.own11_19);
                const b20 = n(r.own20p);
                const btot = n(r.ownBucketTotal);

                const bring = String(r.hasBringback || "").trim();
                const tag = String(r.tag || "").trim();
                const group = String(r.group || "").trim();

                const badBucket = typeof btot === "number" && btot !== 9;

                return (
                  <tr
                    data-year={year}
                    data-week={wk}
                    data-type={r.slateType || ""}
                    data-dateiso={r.slateDate || ""}
                    data-date={fmtDate(r.slateDate)}
                    data-stack={r.qbStack || ""}
                    data-bring={bring}
                    data-maxteam={maxTeam === null ? "" : String(maxTeam)}
                    data-maxgame={maxGame === null ? "" : String(maxGame)}
                    data-early={early === null ? "" : String(early)}
                    data-late={late === null ? "" : String(late)}
                    data-left={left === null ? "" : String(left)}
                    data-own={own === null ? "" : String(own)}
                    data-b0={b0 === null ? "" : String(b0)}
                    data-b11={b11 === null ? "" : String(b11)}
                    data-b20={b20 === null ? "" : String(b20)}
                    data-btot={btot === null ? "" : String(btot)}
                    data-pts={pts === null ? "" : String(pts)}
                    data-top={top === null ? "" : String(top)}
                    data-tag={tag}
                    data-group={group}
                  >
                    <td class="mono">{year || "—"}</td>
                    <td class="mono">{wk || "—"}</td>
                    <td class="mono">{r.slateType || "—"}</td>
                    <td class="mono">{fmtDate(r.slateDate)}</td>

                    <td class="capCell"><div class="capMain">{r.qbStack || "—"}</div></td>
                    <td class="mono">{bring || "—"}</td>

                    <td class="mono">{maxTeam === null ? "—" : maxTeam.toFixed(0)}</td>
                    <td class="mono">{maxGame === null ? "—" : maxGame.toFixed(0)}</td>

                    <td class="mono">{early === null ? "—" : early.toFixed(0)}</td>
                    <td class="mono">{late === null ? "—" : late.toFixed(0)}</td>

                    <td class="mono">{left === null ? "—" : left.toFixed(0)}</td>
                    <td class="mono">{own === null ? "—" : `${own.toFixed(2)}%`}</td>

                    <td class={"mono " + (badBucket ? "bad" : "")}>{b0 === null ? "—" : b0.toFixed(0)}</td>
                    <td class={"mono " + (badBucket ? "bad" : "")}>{b11 === null ? "—" : b11.toFixed(0)}</td>
                    <td class={"mono " + (badBucket ? "bad" : "")}>{b20 === null ? "—" : b20.toFixed(0)}</td>
                    <td class={"mono " + (badBucket ? "bad" : "")}>{btot === null ? "—" : btot.toFixed(0)}</td>

                    <td class="mono">{pts === null ? "—" : pts.toFixed(2)}</td>
                    <td class="mono">{moneyCents(r.topPrizeCents)}</td>
                    <td class="mono">{tag || "—"}</td>
                    <td class="mono">{group || "—"}</td>
                    <td class="mono">
                      {r.link ? (
                        <a class="link" href={r.link} target="_blank" rel="noreferrer">View</a>
                      ) : (
                        "—"
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>

          <div id="colMenu" class="menu" style="display:none;">
            <div class="menuTitle" id="menuTitle">Column</div>

            <div class="menuRow">
              <button class="menuBtn" type="button" data-action="sortAsc">Sort</button>
              <button class="menuBtn" type="button" data-action="sortDesc">Sort</button>
            </div>

            <div class="menuBlock" id="menuFilterBlock"></div>

            <div class="menuRow">
              <button class="menuBtn secondary" type="button" data-action="clearCol">Clear column</button>
              <button class="menuBtn secondary" type="button" data-action="clearAll">Clear all</button>
            </div>
          </div>

          <script is:inline>
            function byId(id) { return document.getElementById(id); }
            function numOrNull(v) {
              if (v === "" || v == null) return null;
              const x = Number(v);
              return Number.isFinite(x) ? x : null;
            }
            function text(v) { return String(v == null ? "" : v).trim(); }

            const q = byId("q");
            const shownCount = byId("shownCount");
            const resetAllTop = byId("resetAllTop");

            const tbody = document.querySelector("#t tbody");
            const menu = byId("colMenu");
            const menuTitle = byId("menuTitle");
            const menuFilterBlock = byId("menuFilterBlock");

            const thButtons = Array.from(document.querySelectorAll(".thBtn"));
            const trs = tbody ? Array.from(tbody.querySelectorAll("tr")) : [];

            const state = {
              q: "",
              filters: {
                year: "",
                week: "",
                type: "",
                stack: "",
                bring: "",
                tag: "",
                group: "",
                dateStart: "",
                dateEnd: "",

                maxTeamMin: "",
                maxTeamMax: "",
                maxGameMin: "",
                maxGameMax: "",
                earlyMin: "",
                earlyMax: "",
                lateMin: "",
                lateMax: "",

                leftMin: "",
                leftMax: "",
                ownMin: "",
                ownMax: "",
                b0Min: "",
                b0Max: "",
                b11Min: "",
                b11Max: "",
                b20Min: "",
                b20Max: "",
                btotMin: "",
                btotMax: "",

                ptsMin: "",
                ptsMax: "",
                topMin: "",
                topMax: ""
              },
              sort: { col: "", dir: "" }
            };

            const colMeta = {
              year: { kind: "catNum", label: "YEAR", key: "year" },
              week: { kind: "catNum", label: "WEEK", key: "week" },
              type: { kind: "cat", label: "TYPE", key: "type" },
              date: { kind: "date", label: "DATE", key: "dateiso" },

              stack: { kind: "cat", label: "STACK", key: "stack" },
              bring: { kind: "cat", label: "BRING", key: "bring" },

              maxTeam: { kind: "num", label: "MAX FROM TEAM", key: "maxteam" },
              maxGame: { kind: "num", label: "MAX FROM GAME", key: "maxgame" },
              early: { kind: "num", label: "EARLY", key: "early" },
              late: { kind: "num", label: "LATE", key: "late" },

              left: { kind: "num", label: "LEFT", key: "left" },
              own: { kind: "num", label: "OWN", key: "own" },

              b0: { kind: "num", label: "OWN 0–10", key: "b0" },
              b11: { kind: "num", label: "OWN 11–19", key: "b11" },
              b20: { kind: "num", label: "OWN 20+", key: "b20" },
              btot: { kind: "num", label: "BUCKET TOTAL", key: "btot" },

              pts: { kind: "num", label: "PTS", key: "pts" },
              top: { kind: "num", label: "TOP", key: "top" },

              tag: { kind: "cat", label: "TAG", key: "tag" },
              group: { kind: "cat", label: "GROUP", key: "group" }
            };

            function uniqueValues(colKey) {
              const set = new Set();
              for (const tr of trs) {
                const v = text(tr.dataset[colKey]);
                if (v) set.add(v);
              }
              return Array.from(set).sort((a, b) => {
                const na = Number(a), nb = Number(b);
                if (Number.isFinite(na) && Number.isFinite(nb)) return na - nb;
                return a.localeCompare(b);
              });
            }

            function withinNum(v, minStr, maxStr) {
              const x = numOrNull(v);
              if (x == null) return false;
              const minV = numOrNull(minStr);
              const maxV = numOrNull(maxStr);
              if (minV != null && x < minV) return false;
              if (maxV != null && x > maxV) return false;
              return true;
            }

            function withinDate(iso, startStr, endStr) {
              const s = text(iso);
              if (!s) return false;
              const t = new Date(s).getTime();
              if (!Number.isFinite(t)) return false;

              if (startStr) {
                const st = new Date(startStr).getTime();
                if (Number.isFinite(st) && t < st) return false;
              }
              if (endStr) {
                const et = new Date(endStr).getTime();
                if (Number.isFinite(et) && t > et) return false;
              }
              return true;
            }

            function hay(tr) {
              const parts = [
                tr.dataset.year, tr.dataset.week, tr.dataset.type, tr.dataset.date,
                tr.dataset.stack, tr.dataset.bring,
                tr.dataset.maxteam, tr.dataset.maxgame, tr.dataset.early, tr.dataset.late,
                tr.dataset.left, tr.dataset.own,
                tr.dataset.b0, tr.dataset.b11, tr.dataset.b20, tr.dataset.btot,
                tr.dataset.pts, tr.dataset.top,
                tr.dataset.tag, tr.dataset.group
              ];
              return parts.map((x) => text(x).toLowerCase()).join(" ");
            }

            function passesFilters(tr) {
              const f = state.filters;

              if (f.year && text(tr.dataset.year) !== f.year) return false;
              if (f.week && text(tr.dataset.week) !== f.week) return false;
              if (f.type && text(tr.dataset.type) !== f.type) return false;
              if (f.stack && text(tr.dataset.stack) !== f.stack) return false;
              if (f.bring && text(tr.dataset.bring) !== f.bring) return false;
              if (f.tag && text(tr.dataset.tag) !== f.tag) return false;
              if (f.group && text(tr.dataset.group) !== f.group) return false;

              if (f.dateStart || f.dateEnd) {
                if (!withinDate(tr.dataset.dateiso, f.dateStart, f.dateEnd)) return false;
              }

              if (f.maxTeamMin || f.maxTeamMax) {
                if (!withinNum(tr.dataset.maxteam, f.maxTeamMin, f.maxTeamMax)) return false;
              }
              if (f.maxGameMin || f.maxGameMax) {
                if (!withinNum(tr.dataset.maxgame, f.maxGameMin, f.maxGameMax)) return false;
              }
              if (f.earlyMin || f.earlyMax) {
                if (!withinNum(tr.dataset.early, f.earlyMin, f.earlyMax)) return false;
              }
              if (f.lateMin || f.lateMax) {
                if (!withinNum(tr.dataset.late, f.lateMin, f.lateMax)) return false;
              }

              if (f.leftMin || f.leftMax) {
                if (!withinNum(tr.dataset.left, f.leftMin, f.leftMax)) return false;
              }
              if (f.ownMin || f.ownMax) {
                if (!withinNum(tr.dataset.own, f.ownMin, f.ownMax)) return false;
              }

              if (f.b0Min || f.b0Max) {
                if (!withinNum(tr.dataset.b0, f.b0Min, f.b0Max)) return false;
              }
              if (f.b11Min || f.b11Max) {
                if (!withinNum(tr.dataset.b11, f.b11Min, f.b11Max)) return false;
              }
              if (f.b20Min || f.b20Max) {
                if (!withinNum(tr.dataset.b20, f.b20Min, f.b20Max)) return false;
              }
              if (f.btotMin || f.btotMax) {
                if (!withinNum(tr.dataset.btot, f.btotMin, f.btotMax)) return false;
              }

              if (f.ptsMin || f.ptsMax) {
                if (!withinNum(tr.dataset.pts, f.ptsMin, f.ptsMax)) return false;
              }
              if (f.topMin || f.topMax) {
                if (!withinNum(tr.dataset.top, f.topMin, f.topMax)) return false;
              }

              return true;
            }

            function compare(trA, trB, col, dir) {
              const meta = colMeta[col];
              if (!meta) return 0;

              const a = trA.dataset[meta.key];
              const b = trB.dataset[meta.key];

              if (meta.kind === "catNum" || meta.kind === "num") {
                const av = numOrNull(a);
                const bv = numOrNull(b);
                const aa = av == null ? -Infinity : av;
                const bb = bv == null ? -Infinity : bv;
                return dir === "asc" ? aa - bb : bb - aa;
              }

              if (meta.kind === "date") {
                const at = new Date(text(a)).getTime();
                const bt = new Date(text(b)).getTime();
                const aa = Number.isFinite(at) ? at : 0;
                const bb = Number.isFinite(bt) ? bt : 0;
                return dir === "asc" ? aa - bb : bb - aa;
              }

              const as = text(a).toLowerCase();
              const bs = text(b).toLowerCase();
              if (as < bs) return dir === "asc" ? -1 : 1;
              if (as > bs) return dir === "asc" ? 1 : -1;
              return 0;
            }

            function applyAll() {
              const qv = state.q;
              let shown = 0;

              for (const tr of trs) {
                let ok = true;
                if (qv) {
                  if (!hay(tr).includes(qv)) ok = false;
                }
                if (ok && !passesFilters(tr)) ok = false;

                tr.style.display = ok ? "" : "none";
                if (ok) shown += 1;
              }

              if (shownCount) shownCount.textContent = String(shown);

              if (tbody && state.sort.col && state.sort.dir) {
                const visible = trs.filter((tr) => tr.style.display !== "none");
                visible.sort((a, b) => compare(a, b, state.sort.col, state.sort.dir));
                for (const tr of visible) tbody.appendChild(tr);
              }
            }

            let activeCol = "";

            function closeMenu() {
              if (menu) menu.style.display = "none";
              if (menuFilterBlock) menuFilterBlock.innerHTML = "";
              activeCol = "";
            }

            function positionMenu(anchorEl) {
              if (!menu) return;
              const r = anchorEl.getBoundingClientRect();
              const top = Math.round(r.bottom + 8);
              const left = Math.round(Math.min(window.innerWidth - 340, Math.max(12, r.left)));
              menu.style.top = top + "px";
              menu.style.left = left + "px";
            }

            function buildFilterUI(col) {
              const meta = colMeta[col];
              if (!meta || !menuFilterBlock) return;

              if (meta.kind === "cat" || meta.kind === "catNum") {
                const values = uniqueValues(meta.key);
                const current = state.filters[col] || "";

                menuFilterBlock.innerHTML =
                  '<div class="menuLabel">Filter</div>' +
                  '<select id="menuSelect" class="menuInput">' +
                  '<option value="">All</option>' +
                  values.map((v) => '<option value="' + v + '">' + v + "</option>").join("") +
                  "</select>";

                const sel = byId("menuSelect");
                if (sel) {
                  sel.value = current;
                  sel.addEventListener("change", () => {
                    state.filters[col] = sel.value;
                    applyAll();
                  });
                }
                return;
              }

              if (meta.kind === "date") {
                const start = state.filters.dateStart || "";
                const end = state.filters.dateEnd || "";
                menuFilterBlock.innerHTML =
                  '<div class="menuLabel">Range</div>' +
                  '<div class="menuGrid2">' +
                  '<div><div class="mini">Start</div><input id="menuDateStart" class="menuInput" type="date" value="' + start + '" /></div>' +
                  '<div><div class="mini">End</div><input id="menuDateEnd" class="menuInput" type="date" value="' + end + '" /></div>' +
                  "</div>";

                const a = byId("menuDateStart");
                const b = byId("menuDateEnd");
                if (a) a.addEventListener("change", () => { state.filters.dateStart = a.value; applyAll(); });
                if (b) b.addEventListener("change", () => { state.filters.dateEnd = b.value; applyAll(); });
                return;
              }

              if (meta.kind === "num") {
                const map = {
                  maxTeam: ["maxTeamMin", "maxTeamMax"],
                  maxGame: ["maxGameMin", "maxGameMax"],
                  early: ["earlyMin", "earlyMax"],
                  late: ["lateMin", "lateMax"],
                  left: ["leftMin", "leftMax"],
                  own: ["ownMin", "ownMax"],
                  b0: ["b0Min", "b0Max"],
                  b11: ["b11Min", "b11Max"],
                  b20: ["b20Min", "b20Max"],
                  btot: ["btotMin", "btotMax"],
                  pts: ["ptsMin", "ptsMax"],
                  top: ["topMin", "topMax"]
                };
                const pair = map[col];
                if (!pair) return;

                const minKey = pair[0];
                const maxKey = pair[1];

                const minVal = state.filters[minKey] || "";
                const maxVal = state.filters[maxKey] || "";

                menuFilterBlock.innerHTML =
                  '<div class="menuLabel">Range</div>' +
                  '<div class="menuGrid2">' +
                  '<div><div class="mini">Min</div><input id="menuNumMin" class="menuInput" type="number" step="any" value="' + minVal + '" /></div>' +
                  '<div><div class="mini">Max</div><input id="menuNumMax" class="menuInput" type="number" step="any" value="' + maxVal + '" /></div>' +
                  "</div>";

                const minEl = byId("menuNumMin");
                const maxEl = byId("menuNumMax");

                function sync() {
                  state.filters[minKey] = minEl ? minEl.value : "";
                  state.filters[maxKey] = maxEl ? maxEl.value : "";
                  applyAll();
                }

                if (minEl) minEl.addEventListener("input", sync);
                if (maxEl) maxEl.addEventListener("input", sync);
              }
            }

            function updateSortButtonLabels(col) {
              const meta = colMeta[col];
              const ascBtn = menu ? menu.querySelector('[data-action="sortAsc"]') : null;
              const descBtn = menu ? menu.querySelector('[data-action="sortDesc"]') : null;
              if (!ascBtn || !descBtn) return;

              if (meta && meta.kind === "num") {
                ascBtn.textContent = "Sort Low → High";
                descBtn.textContent = "Sort High → Low";
                return;
              }

              if (meta && meta.kind === "date") {
                ascBtn.textContent = "Sort Old → New";
                descBtn.textContent = "Sort New → Old";
                return;
              }

              ascBtn.textContent = "Sort A → Z";
              descBtn.textContent = "Sort Z → A";
            }

            function openMenuFor(col, anchorEl) {
              if (!menu || !menuTitle) return;
              activeCol = col;
              const meta = colMeta[col];
              menuTitle.textContent = meta ? meta.label : "Column";
              buildFilterUI(col);
              updateSortButtonLabels(col);
              positionMenu(anchorEl);
              menu.style.display = "block";
            }

            function clearColumn(col) {
              if (col === "year") state.filters.year = "";
              if (col === "week") state.filters.week = "";
              if (col === "type") state.filters.type = "";
              if (col === "stack") state.filters.stack = "";
              if (col === "bring") state.filters.bring = "";
              if (col === "tag") state.filters.tag = "";
              if (col === "group") state.filters.group = "";
              if (col === "date") { state.filters.dateStart = ""; state.filters.dateEnd = ""; }

              if (col === "maxTeam") { state.filters.maxTeamMin = ""; state.filters.maxTeamMax = ""; }
              if (col === "maxGame") { state.filters.maxGameMin = ""; state.filters.maxGameMax = ""; }
              if (col === "early") { state.filters.earlyMin = ""; state.filters.earlyMax = ""; }
              if (col === "late") { state.filters.lateMin = ""; state.filters.lateMax = ""; }

              if (col === "left") { state.filters.leftMin = ""; state.filters.leftMax = ""; }
              if (col === "own") { state.filters.ownMin = ""; state.filters.ownMax = ""; }

              if (col === "b0") { state.filters.b0Min = ""; state.filters.b0Max = ""; }
              if (col === "b11") { state.filters.b11Min = ""; state.filters.b11Max = ""; }
              if (col === "b20") { state.filters.b20Min = ""; state.filters.b20Max = ""; }
              if (col === "btot") { state.filters.btotMin = ""; state.filters.btotMax = ""; }

              if (col === "pts") { state.filters.ptsMin = ""; state.filters.ptsMax = ""; }
              if (col === "top") { state.filters.topMin = ""; state.filters.topMax = ""; }

              applyAll();
            }

            function clearAll() {
              state.q = "";
              for (const k in state.filters) state.filters[k] = "";
              state.sort.col = "";
              state.sort.dir = "";
              if (q) q.value = "";
              applyAll();
            }

            for (const btn of thButtons) {
              btn.addEventListener("click", (e) => {
                e.preventDefault();
                const col = btn.dataset.col;
                if (!col) return;
                openMenuFor(col, btn);
              });
            }

            if (q) {
              q.addEventListener("input", () => {
                state.q = q.value.trim().toLowerCase();
                applyAll();
              });
            }

            if (resetAllTop) {
              resetAllTop.addEventListener("click", () => {
                clearAll();
                closeMenu();
              });
            }

            if (menu) {
              menu.addEventListener("click", (e) => {
                const t = e.target;
                if (!t || !t.dataset) return;
                const action = t.dataset.action;
                if (!action) return;

                if (action === "sortAsc" && activeCol) {
                  state.sort.col = activeCol;
                  state.sort.dir = "asc";
                  applyAll();
                  closeMenu();
                  return;
                }

                if (action === "sortDesc" && activeCol) {
                  state.sort.col = activeCol;
                  state.sort.dir = "desc";
                  applyAll();
                  closeMenu();
                  return;
                }

                if (action === "clearCol" && activeCol) {
                  clearColumn(activeCol);
                  buildFilterUI(activeCol);
                  updateSortButtonLabels(activeCol);
                  return;
                }

                if (action === "clearAll") {
                  clearAll();
                  closeMenu();
                  return;
                }
              });
            }

            document.addEventListener("click", (e) => {
              const target = e.target;
              if (!target) return;
              if (menu && menu.contains(target)) return;
              if (target.classList && target.classList.contains("thBtn")) return;
              closeMenu();
            });

            applyAll();
          </script>
        </div>
      </section>
    </section>
  </main>
</Layout>

<style>
  .page { width: 100%; max-width: 100%; padding: 18px 18px; }
  .topbar { display: flex; align-items: flex-end; justify-content: space-between; gap: 14px; margin-bottom: 14px; }
