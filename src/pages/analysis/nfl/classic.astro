  tbody tr:hover td { background: #232323; }

  .bad { color: #ffb3b3; }

  .capCell .capMain { font-weight: 900; color: rgba(255,255,255,0.92); }
  .link { font-weight: 900; text-decoration: none; color: rgba(255,255,255,0.88); }
  .link:hover { color: #fff; }

  .thBtn { width: 100%; text-align: left; border: 0; background: transparent; padding: 0; font-size: 11px; color: rgba(255,255,255,0.62); font-weight: 900; letter-spacing: 0.02em; text-transform: uppercase; cursor: pointer; }

  .menu { position: fixed; width: 320px; background: #181818; border: 1px solid rgba(255,255,255,0.10); border-radius: 14px; box-shadow: 0 18px 44px rgba(0,0,0,0.55); padding: 12px; z-index: 9999; color: rgba(255,255,255,0.88); }
  .menuTitle { font-weight: 900; margin-bottom: 10px; color: rgba(255,255,255,0.92); }
  .menuRow { display: flex; gap: 8px; margin-bottom: 10px; }
  .menuBtn { flex: 1 1 auto; padding: 9px 10px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.10); background: #1f1f1f; color: rgba(255,255,255,0.88); font-weight: 900; cursor: pointer; font-size: 13px; }
  .menuBtn.secondary { background: #141414; }
  .menuBlock { margin-bottom: 10px; }
  .menuLabel { font-size: 11px; color: rgba(255,255,255,0.55); margin-bottom: 6px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.02em; }
  .menuInput { width: 100%; padding: 9px 10px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.10); background: #141414; color: rgba(255,255,255,0.92); font-size: 13px; outline: none; }
  .menuGrid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; align-items: end; }
  .mini { font-size: 11px; color: rgba(255,255,255,0.55); margin-bottom: 6px; font-weight: 900; }

  .colYear { width: 78px; }
  .colWk { width: 56px; }
  .colType { width: 90px; }
  .colDate { width: 90px; }

  .colStack { width: 140px; }
  .colBring { width: 70px; }

  .colMax { width: 90px; }
  .colMaxG { width: 90px; }

  .colEarly { width: 90px; }
  .colLate { width: 90px; }

  .colLeft { width: 80px; }
  .colOwn { width: 95px; }

  .colB0 { width: 80px; }
  .colB11 { width: 90px; }
  .colB20 { width: 80px; }
  .colBtot { width: 95px; }

  .colPts { width: 90px; }
  .colPrize { width: 110px; }
  .colTag { width: 100px; }
