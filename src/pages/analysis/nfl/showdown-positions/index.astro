---
import Layout from "../../../../layouts/Layout.astro";

const cards = [
  { title: "CAPTAIN", href: "/analysis/nfl/showdown-positions/captain" },
  { title: "FLEX", href: "/analysis/nfl/showdown-positions/flex" },
];

const pageTitle = "NFL Showdown Positions";
---

<Layout title={pageTitle}>
  <main class="page">
    <header class="hero">
      <a class="backLink" href="/analysis">Back to Review</a>
      <h1 class="title">{pageTitle}</h1>
      <p class="sub">Micro analysis for winning Showdown lineups by roster spot.</p>
    </header>

    <section class="grid" aria-label="Showdown position pages">
      {cards.map((c) => (
        <a class="card" href={c.href}>
          <h2 class="card-title">{c.title}</h2>
        </a>
      ))}
    </section>
  </main>
</Layout>

<style>
  :root{
    --surface:#1f1f1f;
    --surface2:#181818;
    --border:rgba(255,255,255,.10);
    --border2:rgba(255,255,255,.12);
    --text:rgba(255,255,255,.92);
    --muted:rgba(255,255,255,.70);
    --shadow:0 18px 55px rgba(0,0,0,.55);
    --shadowSoft:0 12px 30px rgba(0,0,0,.40);
  }

  .page{
    max-width:1100px;
    margin:0 auto;
    padding:26px 16px 70px;
    color:var(--text);
  }

  .hero{margin:10px 0 18px}
  .backLink { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 8px; padding: 8px 12px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.10); background: #1f1f1f; color: rgba(255,255,255,0.88); text-decoration: none; font-weight: 900; font-size: 12px; letter-spacing: 0.02em; box-shadow: 0 10px 30px rgba(0,0,0,0.35); }
  .backLink:hover { color: #fff; background: #232323; border-color: rgba(255,255,255,0.16); }
  .title{margin:0;font-size:44px;letter-spacing:-0.02em;font-weight:950}
  .sub{margin:10px 0 0;max-width:78ch;color:var(--muted);line-height:1.65;font-weight:650}

  main.page > section.grid{
    background: transparent;
    border: 0;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
    margin: 22px 0 0;
  }

  .grid{
    display:grid;
    grid-template-columns:1fr;
    gap:16px;
    align-items:start;
  }

  @media (min-width: 900px){
    .grid{grid-template-columns:1fr 1fr}
  }

  .card{
    display:block;
    text-decoration:none;
    color:var(--text);
    border:1px solid var(--border2);
    border-radius:18px;
    padding:24px;
    background:var(--surface);
    box-shadow:var(--shadowSoft);
    transition:transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease, background 120ms ease;
  }

  .card:hover{
    transform:translateY(-1px);
    border-color:rgba(255,255,255,.16);
    background:#232323;
    box-shadow:var(--shadow);
  }

  .card-title{
    margin:0;
    font-size:20px;
    font-weight:950;
    letter-spacing:-0.01em;
  }

  @media (prefers-reduced-motion: reduce){
    .card{transition:none}
  }
</style>
