---
import Layout from "../../../../layouts/Layout.astro";

const { year } = Astro.params;

function safeUpper(v: any) {
  return String(v || "").trim().toUpperCase();
}

function includesAny(haystack: string, needles: string[]) {
  const h = safeUpper(haystack);
  return needles.some((n) => h.includes(safeUpper(n)));
}

const view = safeUpper(Astro.url.searchParams.get("view") || "GROUPS"); // GROUPS | LIST
const lineupType = safeUpper(Astro.url.searchParams.get("lineupType") || ""); // CLASSIC | SHOWDOWN
const bucket = safeUpper(Astro.url.searchParams.get("bucket") || ""); // varies by lineupType
const q = String(Astro.url.searchParams.get("q") || "").trim();

const params = new URLSearchParams();
params.set("sport", "NFL");
params.set("year", String(year));

if (lineupType === "CLASSIC" || lineupType === "SHOWDOWN") {
  params.set("lineupType", lineupType);
}

const res = await fetch(`${Astro.url.origin}/api/slates?${params.toString()}`);
const data = await res.json();
const slatesAll = Array.isArray(data?.slates) ? data.slates : [];

function getTextBlob(s: any) {
  return [
    s?.slateName,
    s?.slateTag,
    s?.slateType,
    s?.lineupType,
    s?.slateKey,
    s?.week,
  ]
    .map((x) => String(x || ""))
    .join(" ");
}

function inClassicSundayMain(s: any) {
  const name = String(s?.slateName || "");
  const tag = String(s?.slateTag || "");
  const type = String(s?.slateType || "");
  return includesAny(name + " " + tag + " " + type, ["SUNDAY", "MAIN"]) || safeUpper(type) === "MAIN";
}

function inClassicMillyIslands(s: any) {
  const name = String(s?.slateName || "");
  const tag = String(s?.slateTag || "");
  const key = String(s?.slateKey || "");
  return includesAny(name + " " + tag + " " + key, ["2 GAME", "3 GAME", "ISLAND", "ISLANDS", "Milly Islands"]);
}

function inShowdownBucket(s: any, b: string) {
  const name = String(s?.slateName || "");
  const tag = String(s?.slateTag || "");
  const type = String(s?.slateType || "");
  const key = String(s?.slateKey || "");
  const blob = name + " " + tag + " " + type + " " + key;

  if (b === "MNF") return includesAny(blob, ["MNF", "MONDAY"]);
  if (b === "TNF") return includesAny(blob, ["TNF", "THURSDAY"]);
  if (b === "SNF") return includesAny(blob, ["SNF", "SUNDAY NIGHT"]);
  if (b === "SATURDAY") return includesAny(blob, ["SATURDAY"]);
  if (b === "PLAYOFFS" || b === "WC" || b === "DIV" || b === "CONF") return includesAny(blob, ["PLAYOFF", "WILD", "WC", "DIV", "CHAMP"]);
  if (b === "SUPER_BOWL" || b === "SUPERBOWL" || b === "SUPER BOWL") return includesAny(blob, ["SUPER", "BOWL"]);
  return true;
}

let slates = [...slatesAll];

// bucket filter (only applies in LIST view)
if (view === "LIST") {
  if (lineupType === "CLASSIC") {
    if (bucket === "SUNDAY_MAIN") slates = slates.filter(inClassicSundayMain);
    if (bucket === "MILLY_ISLANDS") slates = slates.filter(inClassicMillyIslands);
  }

  if (lineupType === "SHOWDOWN") {
    if (bucket) slates = slates.filter((s) => inShowdownBucket(s, bucket));
  }
}

// search filter
if (q) {
  const qq = safeUpper(q);
  slates = slates.filter((s) => safeUpper(getTextBlob(s)).includes(qq));
}

// simple sort: week desc then name
slates.sort((a, b) => {
  const aw = Number(a?.week ?? 0);
  const bw = Number(b?.week ?? 0);
  if (aw !== bw) return bw - aw;
  const an = String(a?.slateName || "").toUpperCase();
  const bn = String(b?.slateName || "").toUpperCase();
  return an.localeCompare(bn);
});

const sizeClass =
  slates.length <= 3 ? "few" : slates.length <= 8 ? "some" : "many";

function hrefGroups() {
  return `/nfl/${year}/slate`;
}
function hrefListClassic(bucketValue: string) {
  const sp = new URLSearchParams();
  sp.set("view", "LIST");
  sp.set("lineupType", "CLASSIC");
  if (bucketValue) sp.set("bucket", bucketValue);
  return `/nfl/${year}/slate?${sp.toString()}`;
}
function hrefListShowdown(bucketValue: string) {
  const sp = new URLSearchParams();
  sp.set("view", "LIST");
  sp.set("lineupType", "SHOWDOWN");
  if (bucketValue) sp.set("bucket", bucketValue);
  return `/nfl/${year}/slate?${sp.toString()}`;
}
function hrefAllSlates() {
  const sp = new URLSearchParams();
  sp.set("view", "LIST");
  return `/nfl/${year}/slate?${sp.toString()}`;
}

const pageTitle = `NFL ${year} | MillyMakerTracker`;
---

<Layout title={pageTitle}>
  <main class="page">
    <header class="hero">
      <h1 class="h1">NFL</h1>
      <div class="sub">Slates · {year}</div>
    </header>

    {view !== "LIST" ? (
      <section class="groupGrid">
        <a class="bigCard" href={hrefListClassic("")}>
          <div class="bigTitle">Classic</div>
          <div class="bigSub">Sunday Main and Milly Islands.</div>
        </a>

        <a class="bigCard" href={hrefListShowdown("")}>
          <div class="bigTitle">Showdown</div>
          <div class="bigSub">MNF, TNF, SNF, Saturday, Playoffs, Super Bowl.</div>
        </a>

        <a class="bigCard" href={hrefAllSlates()}>
          <div class="bigTitle">All slates</div>
          <div class="bigSub">Browse every slate type in one grid.</div>
        </a>
      </section>
    ) : (
      <>
        <section class="controls">
          <a class="pill" href={hrefGroups()}>Change format</a>

          {lineupType === "CLASSIC" ? (
            <div class="bucketRow">
              <a class={`pill ${bucket === "" ? "active" : ""}`} href={hrefListClassic("")}>All</a>
              <a class={`pill ${bucket === "SUNDAY_MAIN" ? "active" : ""}`} href={hrefListClassic("SUNDAY_MAIN")}>Sunday Main</a>
              <a class={`pill ${bucket === "MILLY_ISLANDS" ? "active" : ""}`} href={hrefListClassic("MILLY_ISLANDS")}>Milly Islands</a>
            </div>
          ) : lineupType === "SHOWDOWN" ? (
            <div class="bucketRow">
              <a class={`pill ${bucket === "" ? "active" : ""}`} href={hrefListShowdown("")}>All</a>
              <a class={`pill ${bucket === "MNF" ? "active" : ""}`} href={hrefListShowdown("MNF")}>MNF</a>
              <a class={`pill ${bucket === "TNF" ? "active" : ""}`} href={hrefListShowdown("TNF")}>TNF</a>
              <a class={`pill ${bucket === "SNF" ? "active" : ""}`} href={hrefListShowdown("SNF")}>SNF</a>
              <a class={`pill ${bucket === "SATURDAY" ? "active" : ""}`} href={hrefListShowdown("SATURDAY")}>Saturday</a>
              <a class={`pill ${bucket === "PLAYOFFS" ? "active" : ""}`} href={hrefListShowdown("PLAYOFFS")}>Playoffs</a>
              <a class={`pill ${bucket === "SUPER_BOWL" ? "active" : ""}`} href={hrefListShowdown("SUPER_BOWL")}>Super Bowl</a>
            </div>
          ) : (
            <div class="bucketRow">
              <a class="pill active" href={hrefAllSlates()}>All</a>
              <a class="pill" href={hrefListClassic("")}>Classic</a>
              <a class="pill" href={hrefListShowdown("")}>Showdown</a>
            </div>
          )}

          <form class="searchForm" method="get">
            <input type="hidden" name="view" value="LIST" />
            {lineupType ? <input type="hidden" name="lineupType" value={lineupType} /> : null}
            {bucket ? <input type="hidden" name="bucket" value={bucket} /> : null}
            <input class="search" type="text" name="q" value={q} placeholder="Search week, name, tag, or key" />
          </form>
        </section>

        <section class={`grid ${sizeClass}`}>
          {slates.map((s) => (
            <a class="card" href={`/nfl/${year}/slate/${s.id}`}>
              <div class="title">{String((s.slateName || "Slate")).trim() || "Slate"}</div>
              <div class="meta">
                Week {s.week ?? "—"} · {safeUpper(s.slateType)} · {safeUpper(s.lineupType)}
              </div>
            </a>
          ))}
        </section>

        {slates.length === 0 ? <p class="empty">No slates match this filter.</p> : null}
      </>
    )}
  </main>
</Layout>

<style>
  .page {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 22px 24px 36px;
  }

  .hero {
    text-align: center;
    margin: 14px 0 18px;
  }

  .h1 {
    margin: 0;
    font-size: 64px;
    line-height: 1.05;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .sub {
    margin-top: 10px;
    color: #666;
    font-weight: 700;
  }

  /* GROUPS (Classic / Showdown / All) */
  .groupGrid {
    display: grid;
    grid-template-columns: repeat(3, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 24px;
    align-items: stretch;
  }

  .bigCard {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
    border: 1px solid rgba(0,0,0,0.10);
    border-radius: 18px;
    background: #fff;
    text-decoration: none;
    padding: 34px 34px;
    min-height: 220px;
  }

  .bigTitle {
    font-size: 22px;
    font-weight: 900;
    color: #0b57ff;
  }

  .bigSub {
    font-size: 16px;
    color: #555;
    font-weight: 700;
    line-height: 1.35;
  }

  .bigCard:hover {
    border-color: rgba(11,87,255,0.35);
    box-shadow: 0 8px 26px rgba(0,0,0,0.06);
  }

  /* LIST CONTROLS */
  .controls {
    margin: 18px 0 18px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px 14px;
    align-items: center;
  }

  .bucketRow {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,0.14);
    background: #fff;
    color: #111;
    text-decoration: none;
    font-weight: 800;
    font-size: 13px;
    white-space: nowrap;
  }

  .pill:hover {
    border-color: rgba(11,87,255,0.35);
  }

  .pill.active {
    border-color: rgba(11,87,255,0.55);
    box-shadow: 0 6px 18px rgba(0,0,0,0.05);
  }

  .searchForm {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
  }

  .search {
    width: min(720px, 100%);
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.14);
    background: #fff;
    font-weight: 700;
  }

  /* SLATE GRID */
  .grid {
    display: grid;
    gap: 16px;
    margin-top: 14px;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    align-items: stretch;
  }

  .grid.few .card { min-height: 220px; padding: 28px 24px; }
  .grid.some .card { min-height: 180px; padding: 22px 20px; }
  .grid.many .card { min-height: 150px; padding: 18px 18px; }

  .grid.few .title { font-size: 22px; }
  .grid.some .title { font-size: 20px; }
  .grid.many .title { font-size: 18px; }

  .card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
    border: 1px solid rgba(0,0,0,0.10);
    border-radius: 16px;
    background: #fff;
    text-decoration: none;
  }

  .card:hover {
    border-color: rgba(11,87,255,0.35);
    box-shadow: 0 8px 26px rgba(0,0,0,0.06);
  }

  .title {
    font-weight: 900;
    color: #0b57ff;
    line-height: 1.15;
  }

  .meta {
    color: #555;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.01em;
  }

  .empty {
    margin-top: 14px;
    text-align: center;
    color: #777;
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .page { padding: 18px 14px 28px; }
    .h1 { font-size: 44px; }
    .groupGrid { grid-template-columns: 1fr; }
    .controls { grid-template-columns: 1fr; }
    .bucketRow { justify-content: flex-start; }
  }
</style>
