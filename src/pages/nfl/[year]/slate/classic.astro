---
import Layout from "../../../../layouts/Layout.astro";
import { prisma } from "../../../../lib/prisma";

const { year } = Astro.params;
const seasonYear = Number(year);

const group = Astro.url.searchParams.get("group"); // "main" | "islands" | null

function safeUpper(v: any) {
  return String(v ?? "").trim().toUpperCase();
}

function isIslandTag(tagRaw: any) {
  const tag = safeUpper(tagRaw);
  return (
    tag.includes("2_GAME") ||
    tag.includes("3_GAME") ||
    tag.includes("TWO_GAME") ||
    tag.includes("THREE_GAME") ||
    tag.includes("ISLAND")
  );
}

function isMainTag(tagRaw: any) {
  const tag = safeUpper(tagRaw);
  return tag === "MAIN" || tag.includes("SUNDAY_MAIN");
}

function labelForClassicSlate(s: any) {
  const tag = safeUpper(s.slateTag);
  const wk = s.week != null ? `Week ${s.week}` : "Week";
  const tagPart = tag ? tag.replaceAll("_", " ") : "CLASSIC";
  return `${wk} · ${tagPart}`;
}

const allClassic = await prisma.slate.findMany({
  where: {
    season: { sport: "NFL", year: seasonYear },
    slateType: "MAIN",
  },
  select: {
    id: true,
    week: true,
    slateKey: true,
    slateTag: true,
    slateType: true,
  },
  orderBy: [{ week: "desc" }, { id: "desc" }],
});

const mainSlates = allClassic.filter((s: any) => isMainTag(s.slateTag));
const islandSlates = allClassic.filter((s: any) => isIslandTag(s.slateTag));

const activeSlates =
  group === "main" ? mainSlates : group === "islands" ? islandSlates : [];
---

<Layout title={`NFL ${seasonYear} Classic Slates`}>
  <div class="page">
    <div class="hero">
      <h1 class="title">Classic</h1>
      <p class="sub">NFL · {seasonYear}</p>
    </div>

    {group == null ? (
      <div class="chooser">
        <a class="bigCard" href={`/nfl/${seasonYear}/slate/classic?group=main`}>
          <div class="bigTitle">Sunday Main</div>
          <div class="bigMeta">{mainSlates.length} slates</div>
          <div class="bigDesc">Full Sunday main slate winners and context.</div>
        </a>

        <a class="bigCard" href={`/nfl/${seasonYear}/slate/classic?group=islands`}>
          <div class="bigTitle">Milly Islands</div>
          <div class="bigMeta">{islandSlates.length} slates</div>
          <div class="bigDesc">Short slates such as 2 Game and 3 Game formats.</div>
        </a>

        <a class="backLink" href={`/nfl/${seasonYear}/slate`}>Back to slate formats</a>
      </div>
    ) : (
      <div class="listWrap">
        <div class="topBar">
          <a class="pill" href={`/nfl/${seasonYear}/slate/classic`}>Change bucket</a>
          <div class="pillLabel">
            {group === "main" ? "Sunday Main" : "Milly Islands"} · {activeSlates.length}
          </div>
          <input id="q" class="search" placeholder="Search week, tag, or key" autocomplete="off" />
        </div>

        <div id="grid" class="grid">
          {activeSlates.map((s: any) => (
            <a class="card" href={`/nfl/${seasonYear}/slate/${s.id}`}>
              <div class="cardTitle">{s.slateKey}</div>
              <div class="cardMeta">{labelForClassicSlate(s)}</div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  const q = document.getElementById("q");
  const grid = document.getElementById("grid");

  if (q && grid) {
    const cards = Array.from(grid.querySelectorAll("a.card"));
    q.addEventListener("input", () => {
      const term = (q.value || "").trim().toLowerCase();
      for (const c of cards) {
        const text = (c.textContent || "").toLowerCase();
        c.style.display = !term || text.includes(term) ? "" : "none";
      }
    });
  }
</script>

<style>
  .page { max-width: 1040px; margin: 0 auto; padding: 24px 16px 40px; }
  .hero { margin-bottom: 18px; }
  .title { margin: 0; font-size: 52px; letter-spacing: -0.02em; }
  .sub { margin: 6px 0 0; color: #666; font-weight: 600; }

  .chooser { display: grid; gap: 14px; max-width: 760px; }
  .bigCard {
    display: block;
    padding: 18px 18px;
    border: 1px solid #e6e6e6;
    border-radius: 14px;
    background: #fff;
    text-decoration: none;
    box-shadow: 0 1px 0 rgba(0,0,0,0.03);
  }
  .bigCard:hover { border-color: #d6d6d6; }
  .bigTitle { font-size: 18px; font-weight: 800; color: #0b57d0; margin-bottom: 6px; }
  .bigMeta { color: #444; font-weight: 700; margin-bottom: 6px; }
  .bigDesc { color: #666; line-height: 1.35; }

  .backLink { display: inline-block; margin-top: 6px; color: #666; text-decoration: none; }
  .backLink:hover { text-decoration: underline; }

  .listWrap { max-width: 980px; }
  .topBar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin: 12px 0 14px; }
  .pill {
    display: inline-block;
    padding: 8px 10px;
    border: 1px solid #e6e6e6;
    border-radius: 999px;
    background: #fff;
    color: #333;
    text-decoration: none;
    font-weight: 700;
  }
  .pill:hover { border-color: #d6d6d6; }
  .pillLabel { color: #666; font-weight: 700; }
  .search {
    margin-left: auto;
    min-width: 240px;
    padding: 10px 12px;
    border: 1px solid #e6e6e6;
    border-radius: 12px;
    background: #fff;
    font-weight: 600;
  }

  .grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
  @media (min-width: 860px) {
    .grid { grid-template-columns: 1fr 1fr; }
  }

  .card {
    display: block;
    padding: 14px 14px;
    border: 1px solid #e6e6e6;
    border-radius: 14px;
    background: #fff;
    text-decoration: none;
  }
  .card:hover { border-color: #d6d6d6; }
  .cardTitle { font-weight: 800; color: #0b57d0; margin-bottom: 6px; }
  .cardMeta { color: #666; font-weight: 700; }
</style>
