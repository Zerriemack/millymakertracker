---
import fs from "node:fs";
import path from "node:path";
import Layout from "../../../../layouts/Layout.astro";

const { id } = Astro.params;

const res = await fetch(`${Astro.url.origin}/api/slate/${id}`);
if (!res.ok) throw new Error(`Slate not found: ${id}`);

const { slate } = await res.json();
const season = slate.season;

function pad2(n: number) {
  return String(n).padStart(2, "0");
}

function safeUpper(v: any) {
  return String(v || "").trim().toUpperCase();
}

function parseSlateKey(keyRaw: string) {
  const key = String(keyRaw || "").trim();
  const parts = key.split("_");

  const wkPart = parts.find((p) => p.startsWith("WK")) || "";
  const week = wkPart ? Number(wkPart.replace("WK", "")) : null;

  const datePart = parts.find((p) => /^\d{4}-\d{2}-\d{2}$/.test(p)) || "";
  const away = parts.length >= 2 ? parts[parts.length - 2] : "";
  const home = parts.length >= 1 ? parts[parts.length - 1] : "";

  const tag =
    parts.includes("MNF")
      ? "MNF"
      : parts.includes("TNF")
        ? "TNF"
        : parts.includes("SNF")
          ? "SNF"
          : parts.includes("THANKSGIVING")
            ? "THANKSGIVING"
            : parts.includes("SUPER")
              ? "SUPER BOWL"
              : "";

  return { week, datePart, away, home, tag };
}

function formatDateHuman(isoOrDate: any) {
  if (!isoOrDate) return "";
  const d = new Date(isoOrDate);
  if (Number.isNaN(d.getTime())) return String(isoOrDate);
  return new Intl.DateTimeFormat("en-US", {
    weekday: "short",
    month: "short",
    day: "2-digit",
    year: "numeric",
  }).format(d);
}

function formatPercent(v: number | null | undefined) {
  if (v === null || v === undefined) return "—";
  return `${Number(v).toFixed(1)}%`;
}

function formatBpTotalOwnership(v: number | null | undefined) {
  if (v === null || v === undefined) return "—";
  return `${(v / 100).toFixed(2)}%`;
}

function rosterOrder(spot: string) {
  const s = safeUpper(spot);
  if (s === "CAPTAIN") return 0;
  if (s === "FLEX") return 1;
  return 9;
}

function classicRosterOrder(spot: string) {
  const s = safeUpper(spot);
  if (s === "QB") return 0;
  if (s === "RB") return 1;
  if (s === "WR") return 2;
  if (s === "TE") return 3;
  if (s === "FLEX") return 4;
  if (s === "DST") return 5;
  return 9;
}

function pickFirstExistingPublicPath(candidates: string[]) {
  const publicDir = path.join(process.cwd(), "public");
  for (const p of candidates) {
    const rel = p.startsWith("/") ? p.slice(1) : p;
    const abs = path.join(publicDir, rel);
    if (fs.existsSync(abs)) return p;
  }
  return null;
}

function toFolderTag(tag: string) {
  return safeUpper(tag).replace(/\s+/g, "_");
}

const slateKey = String(slate.slateKey || "").trim();
const slateTag = safeUpper(slate.slateTag || slate.slateType);
const slateTagFolder = toFolderTag(slateTag);
const weekNum = Number(slate.week ?? 0);

const lineupTypeUpper = safeUpper((slate as any)?.lineupType);
const slateTypeUpper = safeUpper((slate as any)?.slateType);
const isShowdown = lineupTypeUpper === "SHOWDOWN" || slateTypeUpper === "SHOWDOWN";

const parsed = parseSlateKey(slateKey);
const matchupAbbr =
  isShowdown && parsed.away && parsed.home ? `${parsed.away} vs ${parsed.home}` : "";

const slateDateIso = slate.slateDate || parsed.datePart || "";
const slateDateHuman = formatDateHuman(slateDateIso);

const contest = slate.contest || null;
const winner = contest?.winner || null;
const lineup = winner?.lineup || null;
const analysis = contest?.analysis || null;

const contestName = String(contest?.contestName || "").trim();

const headerTitleParts: string[] = [];
if (contestName) headerTitleParts.push(contestName);
if (matchupAbbr) headerTitleParts.push(matchupAbbr);
const headerTitle = headerTitleParts.join(" · ").trim() || "Slate";

const headerSubParts: string[] = [];
if (season?.sport && season?.year) headerSubParts.push(`${season.sport} ${season.year}`);
if (parsed.week) headerSubParts.push(`Week ${parsed.week}`);
if (slateDateHuman) headerSubParts.push(slateDateHuman);
if (slateTag) headerSubParts.push(slateTag);
const headerSub = headerSubParts.join(" | ");

const pageTitle = headerTitle;

const sportLower = String(season.sport).toLowerCase();

const screenshotCandidates: string[] = isShowdown
  ? [
      `/slates/${sportLower}/${season.year}/showdown/${slateTagFolder}/wk${pad2(weekNum)}.png`,
      `/slates/${sportLower}/${season.year}/showdown/${slateTagFolder}/wk${pad2(weekNum)}.jpg`,
      `/slates/${sportLower}/${season.year}/showdown/${slateTagFolder}/wk${weekNum}.png`,
      `/slates/${sportLower}/${season.year}/showdown/${slateTagFolder}/wk${weekNum}.jpg`,
      `/slates/${sportLower}/${season.year}/${slateKey}.png`,
      `/slates/${sportLower}/${season.year}/${slateKey}.jpg`,
    ]
  : [
      `/slates/${sportLower}/${season.year}/classic/week${pad2(weekNum)}.png`,
      `/slates/${sportLower}/${season.year}/classic/week${pad2(weekNum)}.jpg`,
      `/slates/${sportLower}/${season.year}/${slateKey}.png`,
      `/slates/${sportLower}/${season.year}/${slateKey}.jpg`,
    ];

const screenshotUrl = pickFirstExistingPublicPath(screenshotCandidates);

const items = Array.isArray(lineup?.items) ? [...lineup.items] : [];
items.sort((a, b) => {
  const ao = isShowdown ? rosterOrder(a.rosterSpot) : classicRosterOrder(a.rosterSpot);
  const bo = isShowdown ? rosterOrder(b.rosterSpot) : classicRosterOrder(b.rosterSpot);
  if (ao !== bo) return ao - bo;

  const ai = Number.isFinite(a.slotIndex) ? a.slotIndex : 999;
  const bi = Number.isFinite(b.slotIndex) ? b.slotIndex : 999;
  return ai - bi;
});

const classicFlex = !isShowdown ? items.find((it) => safeUpper(it.rosterSpot) === "FLEX") : null;
const classicFlexPos = classicFlex ? safeUpper(classicFlex.position) : "";
const classicFlexValue = classicFlex
  ? `${classicFlexPos} · ${classicFlex.name} · ${formatPercent(classicFlex.ownershipPercent ?? null)}`
  : "—";

const classicQBs = !isShowdown
  ? items.filter((it) => safeUpper(it.rosterSpot) === "QB" || safeUpper(it.position) === "QB")
  : [];

const classicStackSummaryFromJson =
  !isShowdown ? String((analysis as any)?.classicStackSummary || "").trim() : "";

const classicStackQuick =
  classicStackSummaryFromJson ||
  (classicQBs.length
    ? `QB: ${classicQBs.map((q) => q.name).join(", ")}`
    : "—");

const stackSummary = String(analysis?.stackSummary || "").trim();
const uniquenessNotes = String(analysis?.uniquenessNotes || "").trim();
const meta = analysis?.stackMeta || null;

const metaTeamSplit = meta?.construction?.teamSplit ? String(meta.construction.teamSplit) : "";
const metaBuildType = meta?.construction?.buildType ? String(meta.construction.buildType) : "";
const metaIncludesQBs =
  typeof meta?.construction?.includesQBs === "boolean"
    ? meta.construction.includesQBs
      ? "Yes"
      : "No"
    : "";
const metaCaptain = meta?.construction?.captain
  ? `${meta.construction.captain.team} ${meta.construction.captain.position} (${meta.construction.captain.name})`
  : "";
const metaPrimaryLever = meta?.primaryLever ? String(meta.primaryLever) : "";
const metaSecondaryLever = meta?.secondaryLever ? String(meta.secondaryLever) : "";
---

<Layout title={pageTitle}>
  <main class="page">
    <header class="hero">
      <h1 class="h1">{headerTitle}</h1>
      <p class="sub">{headerSub}</p>
    </header>

    <section class="topGrid">
      <div class="shotCard">
        <div class="shotHeader">
          <div class="shotTitle">{headerTitle}</div>
        </div>

        {screenshotUrl ? (
          <a class="shotLink" href={screenshotUrl} target="_blank" rel="noreferrer">
            <img class="shotImg" src={screenshotUrl} alt={headerTitle} loading="eager" />
          </a>
        ) : (
          <div class="shotMissing">
            <div class="shotMissingTitle">Screenshot not available</div>
            <div class="shotMissingSub">Add a PNG or JPG using your naming pattern.</div>
          </div>
        )}
      </div>

      <aside class="sideCard">
        <div class="sideTitle">At a glance</div>

        <div class="facts">
          <div class="k">Winner</div>
          <div class="v">{winner?.username ?? "—"}</div>

          <div class="k">Score</div>
          <div class="v">{winner?.points ?? "—"}</div>

          <div class="k">Salary used</div>
          <div class="v">{lineup?.salaryUsed ?? "—"}</div>

          <div class="k">Total ownership</div>
          <div class="v">{formatBpTotalOwnership(contest?.totalOwnershipBp ?? null)}</div>

          <div class="k">Matchup</div>
          <div class="v">{matchupAbbr || "—"}</div>

          <div class="k">Date</div>
          <div class="v">{slateDateHuman || "—"}</div>

          {isShowdown ? (
            <>
              <div class="k">Team split</div>
              <div class="v">{metaTeamSplit || "—"}</div>

              <div class="k">Captain</div>
              <div class="v">{metaCaptain || "—"}</div>

              <div class="k">Primary lever</div>
              <div class="v">{metaPrimaryLever || "—"}</div>

              <div class="k">Secondary lever</div>
              <div class="v">{metaSecondaryLever || "—"}</div>

              <div class="k">Build type</div>
              <div class="v">{metaBuildType || "—"}</div>

              <div class="k">Includes QBs</div>
              <div class="v">{metaIncludesQBs || "—"}</div>
            </>
          ) : (
            <>
              <div class="k">Flex</div>
              <div class="v">{classicFlexValue}</div>

              <div class="k">Stack</div>
              <div class="v">{classicStackQuick}</div>

              <div class="k">Slate</div>
              <div class="v">{slateTag || "—"}</div>
            </>
          )}
        </div>

        <div class="mini">
          <div class="miniTitle">Stack summary</div>
          <div class="miniText">{stackSummary || "—"}</div>
        </div>
      </aside>
    </section>

    <section class="block">
      <h2 class="h2">Winning lineup</h2>

      <div class="tableWrap">
        <table class="lineupTable">
          <thead>
            <tr>
              <th class="colPos">POS</th>
              <th>PLAYER</th>
              <th class="colOwn">OWN</th>
              <th class="colSal">SAL</th>
              <th class="colPts">PTS</th>
            </tr>
          </thead>
          <tbody>
            {items.map((it) => (
              <tr>
                <td class="colPos">{it.rosterSpot}</td>
                <td class="playerCell">
                  <div class="playerName">{it.name}</div>
                  <div class="playerMeta">{it.team} {it.position}</div>
                </td>
                <td class="colOwn">{formatPercent(it.ownershipPercent ?? null)}</td>
                <td class="colSal">{it.salary ?? "—"}</td>
                <td class="colPts">{it.points ?? "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="block">
      <h2 class="h2">Analysis</h2>

      {analysis ? (
        <div class="analysisGrid">
          <div class="analysisCard">
            <div class="analysisLabel">Uniqueness notes</div>
            <div class="analysisText">{uniquenessNotes || "—"}</div>
          </div>

          <div class="analysisCard">
            <div class="analysisLabel">Build details</div>
            <div class="analysisText">
              {metaTeamSplit ? `Team split: ${metaTeamSplit}\n` : ""}
              {metaBuildType ? `Build type: ${metaBuildType}\n` : ""}
              {metaIncludesQBs ? `Includes QBs: ${metaIncludesQBs}\n` : ""}
              {metaPrimaryLever ? `Primary lever: ${metaPrimaryLever}\n` : ""}
              {metaSecondaryLever ? `Secondary lever: ${metaSecondaryLever}\n` : ""}
              {!metaTeamSplit && !metaBuildType && !metaIncludesQBs && !metaPrimaryLever && !metaSecondaryLever ? "—" : ""}
            </div>
          </div>
        </div>
      ) : (
        <p class="muted">No analysis saved for this slate.</p>
      )}
    </section>
  </main>
</Layout>

<style>
  .page {
    width: 100%;
    max-width: 1700px;
    margin: 0 auto;
    padding: 18px 24px;
  }

  .hero { margin-bottom: 14px; }
  .h1 { margin: 0; font-size: 32px; line-height: 1.15; font-weight: 900; }
  .sub { margin: 8px 0 0; color: #666; line-height: 1.35; }

  /* Big left panel + tall right panel */
  .topGrid {
    display: grid;
    grid-template-columns: 3fr 1.4fr;
    gap: 18px;
    align-items: stretch;
  }

  .shotCard, .sideCard {
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 14px;
    background: #fff;
    overflow: hidden;
  }

  /* This is the key: give the left card a real height so the image can grow */
  .shotCard {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 220px);
  }

  .shotHeader { padding: 12px 14px; border-bottom: 1px solid rgba(0,0,0,0.06); }
  .shotTitle { font-weight: 900; }

  .shotLink {
  flex: 1 1 auto;
  display: flex;
  padding: 10px;
  background: rgba(0,0,0,0.02);
  cursor: zoom-in;

  /* keep layout the same, just control how the image sits */
  justify-content: center;
  align-items: flex-start;
}

/* replace your current .shotImg */
.shotImg {
  max-width: 85%;
  max-height: 85%;
  width: auto;
  height: auto;
  display: block;
  object-fit: contain;
  object-position: center top;
  background: #fff;
  border-radius: 10px;
}

/* optional: give it a max visual height so it never feels oversized */
.shotCard {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 220px);
  max-height: calc(100vh - 220px);
}

  .shotMissing { padding: 22px 14px; }
  .shotMissingTitle { font-weight: 800; }
  .shotMissingSub { margin-top: 6px; color: #666; }

  /* Right side fills the column height */
  .sideCard {
    padding: 14px;
    position: sticky;
    top: 14px;
    height: calc(100vh - 28px);
    overflow: auto;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sideTitle { font-weight: 900; margin-bottom: 0; }

  .facts {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 8px 10px;
    padding: 10px;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
    background: rgba(0,0,0,0.02);
  }

  .k { color: #666; font-size: 13px; }
  .v { font-weight: 900; }

  .mini { padding-top: 12px; border-top: 1px solid rgba(0,0,0,0.06); }
  .miniTitle { font-size: 12px; color: #666; font-weight: 900; text-transform: uppercase; letter-spacing: 0.02em; }
  .miniText { margin-top: 6px; line-height: 1.45; white-space: pre-wrap; }

  .block { margin-top: 18px; }
  .h2 { margin: 0 0 10px; font-size: 20px; font-weight: 900; }

  .tableWrap {
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
  }

  .lineupTable { width: 100%; border-collapse: collapse; }
  .lineupTable th, .lineupTable td { padding: 10px 12px; border-bottom: 1px solid rgba(0,0,0,0.06); vertical-align: top; }
  .lineupTable thead th { background: rgba(0,0,0,0.03); text-align: left; font-size: 12px; color: #555; letter-spacing: 0.02em; }

  .colPos { width: 110px; }
  .colOwn, .colSal, .colPts { width: 90px; }

  .playerName { font-weight: 900; }
  .playerMeta { font-size: 12px; color: #666; margin-top: 2px; }

  .analysisGrid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 12px;
  }

  .analysisCard {
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 14px;
    background: #fff;
    padding: 12px 14px;
  }

  .analysisLabel {
    font-size: 12px;
    color: #666;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 6px;
  }

  .analysisText { line-height: 1.5; white-space: pre-wrap; }
  .muted { color: #777; }

  @media (max-width: 980px) {
    .topGrid { grid-template-columns: 1fr; align-items: start; }
    .sideCard { position: static; height: auto; overflow: visible; }
    .shotCard { min-height: 0; }
    .shotLink { padding: 8px; }
    .shotImg { height: auto; object-fit: contain; }
    .analysisGrid { grid-template-columns: 1fr; }
    .page { padding: 16px 14px; }
  }
</style>
