---
import ClassicReviewShell from "../../../../components/nfl/classic/ClassicReviewShell.astro";
import ClassicReviewDrawer from "../../../../components/nfl/classic/ClassicReviewDrawer.astro";
import {
  fetchClassicReviewRows,
  toNumber,
  mean,
  median,
  quantile,
  groupByYear,
  pct,
} from "../../../../lib/nfl/classicReview";

const pageTitle = "NFL Classic Review | Salary";

const rows = await fetchClassicReviewRows(Astro.url.origin);
const baseSample = rows.length;
const hasData = baseSample > 0;

const salaryValues = rows.map((r) => toNumber(r.salaryLeft)).filter((v) => v !== null);

const salaryBuckets = [
  { label: "$0 to $99", min: 0, max: 99 },
  { label: "$100 to $199", min: 100, max: 199 },
  { label: "$200 to $399", min: 200, max: 399 },
  { label: "$400 to $599", min: 400, max: 599 },
  { label: "$600 to $799", min: 600, max: 799 },
  { label: "$800 to $999", min: 800, max: 999 },
  { label: "$1,000 to $1,499", min: 1000, max: 1499 },
  { label: "$1,500+", min: 1500, max: 999999 },
];

const salaryBucketCounts = salaryBuckets.map((bucket) => ({
  ...bucket,
  count: salaryValues.filter((v) => v >= bucket.min && v <= bucket.max).length,
}));

const maxCount = Math.max(...salaryBucketCounts.map((b) => b.count), 1);
const sortedBuckets = [...salaryBucketCounts].sort((a, b) => b.count - a.count);
const dominantBuckets = sortedBuckets.slice(0, 2);
const dominantMin = dominantBuckets.length ? Math.min(...dominantBuckets.map((b) => b.min)) : null;
const dominantMax = dominantBuckets.length ? Math.max(...dominantBuckets.map((b) => b.max)) : null;
const dominantRange = dominantMin == null || dominantMax == null ? "—" : `$${dominantMin} to $${dominantMax}`;

const q10 = quantile(salaryValues, 0.1);
const q90 = quantile(salaryValues, 0.9);
const medianSalary = median(salaryValues);
const trustedRange = q10 == null || q90 == null ? "—" : `$${Math.round(q10)} to $${Math.round(q90)}`;

const salaryPocketRows = salaryBucketCounts.map((row) => ({
  bucket: row.label,
  count: row.count,
  pct: pct(row.count, baseSample),
  width: Math.round((row.count / maxCount) * 100),
  state: row.count >= maxCount * 0.66 ? "core" : row.count >= maxCount * 0.33 ? "secondary" : "rare",
  tag: row.count >= maxCount * 0.66 ? "Dominant" : row.count >= maxCount * 0.33 ? "Live" : "Thin",
}));

const heroStats = [
  { label: "Sample", value: `${baseSample} winners` },
  { label: "Dominant salary-left range", value: dominantRange },
  { label: "Trusted working range", value: trustedRange },
  { label: "One season rule", value: "Live in the dominant range unless the slate gives a real reason to leave it." },
];

const verdictCards = [
  {
    label: "Primary target",
    value: dominantRange,
    note: "This is the cleanest macro range for someone trying to win once per season.",
    tone: "primary",
  },
  {
    label: "Secondary viable",
    value: trustedRange,
    note: "Still live, but less concentrated than the dominant center.",
    tone: "secondary",
  },
  {
    label: "Do not default here",
    value: q10 == null || q90 == null ? "—" : `Under $${Math.round(q10)} and over $${Math.round(q90)}`,
    note: "These buckets exist, but they are too thin to anchor a weekly baseline.",
    tone: "fade",
  },
];

const rangeCallouts = [
  { label: "Mode", value: sortedBuckets[0]?.label ?? "—" },
  { label: "Median salary left", value: medianSalary == null ? "—" : `$${Math.round(medianSalary)}` },
  { label: "Core concentration", value: dominantRange },
  { label: "Trim rule", value: q10 == null || q90 == null ? "—" : `De-emphasize under $${Math.round(q10)} and over $${Math.round(q90)}` },
];

const yearsBy = groupByYear(rows);
const seasonRows = Object.keys(yearsBy)
  .filter((key) => key !== "Unknown")
  .sort((a, b) => Number(a) - Number(b))
  .map((season) => {
    const seasonRows = yearsBy[season];
    const seasonValues = seasonRows.map((r) => toNumber(r.salaryLeft)).filter((v) => v !== null);
    const seasonMedian = median(seasonValues);
    const seasonBuckets = salaryBuckets.map((bucket) => ({
      ...bucket,
      count: seasonValues.filter((v) => v >= bucket.min && v <= bucket.max).length,
    }));
    const dominant = seasonBuckets.sort((a, b) => b.count - a.count)[0]?.label ?? "—";
    let stability = "Stable";
    let bias = "Balanced";
    let note = "Inside the same center lane.";
    if (seasonMedian != null && medianSalary != null && seasonMedian > medianSalary + 150) {
      stability = "Upper lean";
      bias = "Looser";
      note = "Salary left drifted higher than the core band.";
    } else if (seasonMedian != null && medianSalary != null && seasonMedian < medianSalary - 150) {
      stability = "Lower lean";
      bias = "Tighter";
      note = "Salary left pressed toward the lower end.";
    }
    return {
      season,
      dominant,
      median: seasonMedian == null ? "—" : `$${Math.round(seasonMedian)}`,
      note,
      stability,
      band: dominantRange,
      bias,
    };
  });

const seasonSummary = [
  { label: "Stable seasons", value: String(seasonRows.filter((row) => row.stability === "Stable").length) },
  { label: "Upper-lean seasons", value: String(seasonRows.filter((row) => row.stability === "Upper lean").length) },
  { label: "Dominant recurring band", value: dominantRange },
  { label: "Most common exact pocket", value: sortedBuckets[0]?.label ?? "—" },
];
---

<ClassicReviewShell
  title={pageTitle}
  headline="Salary"
  subtitle="Which salary-left range shows up most often in first place Classic Milly Maker lineups."
  accent="blue"
  class="with-drawer salary-compact"
  hideHero
>
  <ClassicReviewDrawer active="salary" mode="hover" />

  <section class="sectionPanel salaryHeroPanel">
    <div class="salaryHero">
      <div class="heroTitleBlock">
        <p class="eyebrow">Classic Review</p>
        <h1 class="heroHeadline">
          WINNING SALARY LEFT
        </h1>
      </div>

      <div class="heroNarrative">
        <p>This page shows which salary left ranges have appeared most often in winning NFL Classic lineups and how those ranges have looked from year to year.</p>
      </div>
    </div>

    <div class="heroStatGrid">
      {heroStats.map((item) => (
        <article class="heroStatCard">
          <span class="heroStatLabel">{item.label}</span>
          <strong class:list={["heroStatValue", item.label !== "Sample" && "heroStatValueVerbose"]}>{item.value}</strong>
        </article>
      ))}
    </div>

    <div class="activeFilterBar" id="salary-active-filter-bar">
      <div class="activeFilterSummary">
        <span class="activeFilterSummaryLabel">Live sample</span>
        <strong class="activeFilterSummaryValue"><span id="salary-live-sample-count">{baseSample}</span> winners</strong>
      </div>

      <div class="activeChipRow" id="salary-active-chip-row">
        <button class="activeChip isEmpty" type="button" data-chip="bucket">Salary range: any</button>
        <button class="activeChip isEmpty" type="button" data-chip="season">Season: any</button>
      </div>

      <button class="resetFiltersButton" type="button" id="reset-salary-filters">Reset all</button>
    </div>
  </section>

  {hasData ? (
  <>
  <section class="sectionPanel">
    <div class="sectionHeader">
      <div>
        <h2 class="sectionTitle">Salary left evidence board</h2>
        <p class="sectionSub">The dominant range should be obvious at first glance, while still letting the user isolate any pocket they want.</p>
      </div>
      <div class="sectionPill">Evidence</div>
    </div>

    <div class="salaryBoardLayout">
      <div class="salaryBoardMain">
        <div class="salaryBoardHead">
          <div>
            <h3 class="salaryBoardTitle">Pocket frequency</h3>
            <p class="salaryBoardSub">The center of gravity matters more than the tails. This is the board that should drive the page.</p>
          </div>

          <div class="salaryBoardMedian">
            <span>Median</span>
            <strong>{medianSalary == null ? "—" : `$${Math.round(medianSalary)}`}</strong>
          </div>
        </div>

        <div class="salaryBracket">
          <div class="salaryBracketLine"></div>
          <div class="salaryBracketLabel">Trusted center lane {dominantRange}</div>
        </div>

        <div class="salaryBucketList">
          {salaryPocketRows.map((row) => (
            <button
              type="button"
              class={`salaryBucketRow state-${row.state} filterControl`}
              data-filter-kind="bucket"
              data-filter-value={row.bucket}
              data-bucket={row.bucket}
              aria-pressed="false"
            >
              <div class="salaryBucketLeft">
                <div class="salaryBucketLabelLine">
                  <span class="salaryBucketLabel">{row.bucket}</span>
                  <span class={`salaryBucketTag tag-${row.tag.toLowerCase().replaceAll(" ", "-")}`}>{row.tag}</span>
                </div>
                <span class="salaryBucketCount">{row.count} winners</span>
              </div>

              <div class="salaryBucketTrack">
                <div class="salaryBucketFill" style={`width:${row.width}%`}></div>
              </div>

              <div class="salaryBucketRight">
                <strong>{row.pct}</strong>
              </div>
            </button>
          ))}
        </div>
      </div>

      <aside class="salaryBoardRail">
        <section class="salaryVerdictPanel">
          <div class="salaryVerdictHead">
            <h3 class="salaryVerdictTitle">Verdict</h3>
            <p class="salaryVerdictSub">Keep the answer direct.</p>
          </div>

          <div class="salaryVerdictGrid">
            {verdictCards.map((item) => (
              <article class={`salaryVerdictCard tone-${item.tone}`}>
                <span class="salaryVerdictLabel">{item.label}</span>
                <strong class="salaryVerdictValue">{item.value}</strong>
                <p class="salaryVerdictNote">{item.note}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="salaryRangePanel">
          <div class="salaryRangeHead">
            <h3 class="salaryRangeTitle">Range map</h3>
            <p class="salaryRangeSub">The raw answer in a tighter form.</p>
          </div>

          <div class="salaryRangeStats">
            {rangeCallouts.map((item) => (
              <article class="salaryRangeStat">
                <span class="salaryRangeStatLabel">{item.label}</span>
                <strong class="salaryRangeStatValue">{item.value}</strong>
              </article>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </section>

  <section class="sectionPanel">
    <div class="sectionHeader">
      <div>
        <h2 class="sectionTitle">Salary left by season</h2>
        <p class="sectionSub">This section only needs to answer whether the dominant range stayed stable or moved.</p>
      </div>
      <div class="sectionPill">Trend</div>
    </div>

    <div class="seasonSummaryStrip">
      {seasonSummary.map((item) => (
        <article class="seasonSummaryCard">
          <span class="seasonSummaryLabel">{item.label}</span>
          <strong class="seasonSummaryValue">{item.value}</strong>
        </article>
      ))}
    </div>

    <div class="salaryTrendLayout">
      <div class="salaryTrendBoard">
        <div class="salaryTrendHead">
          <span>Season</span>
          <span>Dominant pocket</span>
          <span>Median left</span>
          <span>Working band</span>
          <span>Stability</span>
          <span>Note</span>
        </div>

        {seasonRows.map((row) => (
          <button
            type="button"
            class="salaryTrendRow filterControl"
            data-filter-kind="season"
            data-filter-value={row.season}
            data-season={row.season}
            aria-pressed="false"
          >
            <div class="salaryTrendCell salaryTrendSeason">{row.season}</div>
            <div class="salaryTrendCell salaryTrendPocket">{row.dominant}</div>
            <div class="salaryTrendCell">{row.median}</div>
            <div class="salaryTrendCell">{row.band}</div>
            <div class="salaryTrendCell">
              <span class={`seasonStabilityBadge badge-${row.stability.toLowerCase().replaceAll(" ", "-")}`}>{row.stability}</span>
            </div>
            <div class="salaryTrendCell salaryTrendNote">{row.note}</div>
          </button>
        ))}
      </div>
    </div>
  </section>
  </>
  ) : (
    <section class="sectionPanel emptyState">No Classic review data available yet.</section>
  )}
</ClassicReviewShell>

<script is:inline>
  (() => {
    const root = document.querySelector(".salary-compact");
    if (!root) return;

    const baseSample = {baseSample};

    const bucketCounts = {
      "$0 to $99": 6,
      "$100 to $199": 11,
      "$200 to $399": 19,
      "$400 to $599": 31,
      "$600 to $799": 38,
      "$800 to $999": 13,
      "$1,000 to $1,499": 7,
      "$1,500+": 2,
    };

    const seasonSampleMap = {
      "2018": 18,
      "2019": 18,
      "2020": 18,
      "2021": 18,
      "2022": 18,
      "2023": 18,
      "2024": 19,
    };

    const state = {
      bucket: null,
      season: null,
    };

    const chips = {
      bucket: root.querySelector('[data-chip="bucket"]'),
      season: root.querySelector('[data-chip="season"]'),
    };

    const controls = Array.from(root.querySelectorAll(".filterControl"));
    const liveSampleCount = root.querySelector("#salary-live-sample-count");
    const resetButton = root.querySelector("#reset-salary-filters");
    const bucketRows = Array.from(root.querySelectorAll(".salaryBucketRow"));
    const seasonRows = Array.from(root.querySelectorAll(".salaryTrendRow"));

    const updateChips = () => {
      const labels = {
        bucket: state.bucket ? `Salary range: ${state.bucket}` : "Salary range: any",
        season: state.season ? `Season: ${state.season}` : "Season: any",
      };

      Object.entries(chips).forEach(([key, el]) => {
        if (!el) return;
        el.textContent = labels[key];
        el.classList.toggle("isEmpty", !state[key]);
      });
    };

    const updateSample = () => {
      if (state.bucket && bucketCounts[state.bucket] !== undefined) {
        liveSampleCount.textContent = String(bucketCounts[state.bucket]);
        return;
      }

      if (state.season && seasonSampleMap[state.season] !== undefined) {
        liveSampleCount.textContent = String(seasonSampleMap[state.season]);
        return;
      }

      liveSampleCount.textContent = String(baseSample);
    };

    const updateActiveStates = () => {
      controls.forEach((control) => {
        const kind = control.dataset.filterKind;
        const value = control.dataset.filterValue;
        const active = Boolean(kind && state[kind] && state[kind] === value);
        control.classList.toggle("isActive", active);
        control.setAttribute("aria-pressed", active ? "true" : "false");
      });
    };

    const updateVisibility = () => {
      bucketRows.forEach((row) => {
        const active = Boolean(state.bucket && row.dataset.bucket === state.bucket);
        row.classList.toggle("isDimmed", Boolean(state.bucket) && !active);
      });

      seasonRows.forEach((row) => {
        const active = Boolean(state.season && row.dataset.season === state.season);
        row.classList.toggle("isDimmed", Boolean(state.season) && !active);
      });
    };

    const render = () => {
      updateChips();
      updateSample();
      updateActiveStates();
      updateVisibility();
    };

    controls.forEach((control) => {
      control.addEventListener("click", () => {
        const kind = control.dataset.filterKind;
        const value = control.dataset.filterValue;
        if (!kind || !value) return;
        state[kind] = state[kind] === value ? null : value;
        render();
      });
    });

    Object.entries(chips).forEach(([kind, chip]) => {
      chip?.addEventListener("click", () => {
        state[kind] = null;
        render();
      });
    });

    resetButton?.addEventListener("click", () => {
      state.bucket = null;
      state.season = null;
      render();
    });

    render();
  })();
</script>

<style>
  :global(.classic-frame.with-drawer.salary-compact) {
    padding-left: calc(clamp(18px, 2vw, 26px) + 54px);
    padding-right: clamp(20px, 3vw, 36px);
  }

  :global(.classic-frame.with-drawer.salary-compact .content) {
    gap: 18px;
    margin-top: 4px;
    width: min(1220px, calc(100vw - 128px));
    max-width: 1240px;
    margin-left: auto;
    margin-right: auto;
    margin-inline: auto;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  :global(.classic-frame.with-drawer.salary-compact .hero) {
    display: none;
  }

  :global(.salary-compact .sectionPanel) {
    padding: 22px 22px 22px;
    border-radius: 20px;
  }

  :global(.salary-compact .sectionHeader) {
    gap: 12px;
    margin-bottom: 12px;
  }

  :global(.salary-compact .sectionTitle) {
    font-size: clamp(22px, 1.8vw, 30px);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  :global(.salary-compact .sectionSub) {
    max-width: 78ch;
    font-size: 13px;
    line-height: 1.55;
    font-weight: 560;
  }

  :global(.salary-compact .sectionPill) {
    padding: 3px 8px;
    font-size: 9px;
    letter-spacing: 0.14em;
  }

  .salaryHeroPanel {
    padding: 16px 20px 14px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(28, 28, 30, 0.92), rgba(20, 20, 22, 0.96));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.02),
      0 12px 22px rgba(0, 0, 0, 0.24);
  }

  .salaryHero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(300px, 0.85fr);
    gap: 24px;
    align-items: start;
    margin-bottom: 18px;
  }

  .eyebrow {
    margin: 0 0 8px;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(191, 219, 254, 0.72);
  }

  .heroHeadline {
    margin: 0;
    max-width: 760px;
    font-size: clamp(2.2rem, 3.6vw, 4.25rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    font-weight: 900;
    color: rgba(255, 248, 230, 0.98);
  }

  .heroNarrative {
    align-self: stretch;
    padding-top: 8px;
  }

  .heroNarrative p {
    margin: 0 0 12px;
    max-width: 430px;
    font-size: 0.96rem;
    line-height: 1.65;
    color: rgba(225, 225, 225, 0.72);
  }

  .heroStatGrid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .heroStatCard {
    padding: 16px 18px;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.14);
    background: linear-gradient(180deg, rgba(10, 16, 28, 0.9), rgba(6, 10, 18, 0.95));
  }

  .heroStatLabel {
    display: block;
    margin-bottom: 8px;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.82);
  }

  .heroStatValue {
    display: block;
    color: #f8fafc;
    font-size: clamp(18px, 1.6vw, 24px);
    line-height: 1.1;
    font-weight: 800;
  }

  .heroStatValueVerbose {
    font-size: 0.98rem;
    line-height: 1.3;
  }

  .activeFilterBar {
    margin-top: 16px;
    padding: 16px 18px;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.14);
    background: linear-gradient(180deg, rgba(10, 16, 28, 0.9), rgba(6, 10, 18, 0.95));
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: center;
  }

  .activeFilterSummaryLabel {
    display: block;
    margin-bottom: 6px;
    color: rgba(148, 163, 184, 0.8);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .activeFilterSummaryValue {
    color: #f8fafc;
    font-size: 0.96rem;
    font-weight: 800;
  }

  .activeChipRow {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .activeChip,
  .resetFiltersButton {
    border: 0;
    cursor: pointer;
    appearance: none;
    font: inherit;
  }

  .activeChip {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(59, 130, 246, 0.12);
    color: rgba(219, 234, 254, 0.96);
    font-size: 0.68rem;
    line-height: 1;
  }

  .activeChip.isEmpty {
    background: rgba(148, 163, 184, 0.1);
    color: rgba(226, 232, 240, 0.72);
  }

  .resetFiltersButton {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(239, 68, 68, 0.14);
    color: rgba(254, 226, 226, 0.96);
    font-size: 0.68rem;
    line-height: 1;
  }

  .salaryBoardLayout {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) 320px;
    gap: 12px;
    align-items: start;
  }

  .salaryBoardMain {
    padding: 16px 18px;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.14);
    background:
      radial-gradient(circle at top left, rgba(59, 130, 246, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(9, 14, 24, 0.95), rgba(4, 8, 15, 0.98));
  }

  .salaryBoardHead {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .salaryBoardTitle {
    margin: 0 0 4px;
    color: #f8fafc;
    font-size: 0.96rem;
    line-height: 1.1;
    font-weight: 800;
  }

  .salaryBoardSub {
    margin: 0;
    color: rgba(226, 232, 240, 0.78);
    font-size: 13px;
    line-height: 1.5;
    max-width: 56ch;
  }

  .salaryBoardMedian {
    min-width: 88px;
    text-align: right;
  }

  .salaryBoardMedian span {
    display: block;
    margin-bottom: 4px;
    color: rgba(148, 163, 184, 0.78);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .salaryBoardMedian strong {
    color: #f8fafc;
    font-size: 0.96rem;
    font-weight: 800;
  }

  .salaryBracket {
    position: relative;
    margin-bottom: 16px;
    padding-top: 12px;
  }

  .salaryBracketLine {
    height: 2px;
    margin-left: 31%;
    width: 43%;
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.12), rgba(59, 130, 246, 0.98), rgba(59, 130, 246, 0.12));
    position: relative;
    border-radius: 999px;
    box-shadow: 0 0 18px rgba(59, 130, 246, 0.22);
  }

  .salaryBracketLine::before,
  .salaryBracketLine::after {
    content: "";
    position: absolute;
    top: -8px;
    width: 2px;
    height: 16px;
    background: rgba(59, 130, 246, 0.96);
    border-radius: 999px;
    box-shadow: 0 0 12px rgba(59, 130, 246, 0.2);
  }

  .salaryBracketLine::before {
    left: 0;
  }

  .salaryBracketLine::after {
    right: 0;
  }

  .salaryBracketLabel {
    margin-top: 8px;
    text-align: center;
    color: rgba(219, 234, 254, 0.98);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
