    margin: 0;
    max-width: 760px;
    font-size: clamp(2.2rem, 3.6vw, 4.25rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    font-weight: 900;
    color: rgba(255, 248, 230, 0.98);
