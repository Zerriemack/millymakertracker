---
import ClassicReviewShell from "../../../../components/nfl/classic/ClassicReviewShell.astro";
import ClassicReviewDrawer from "../../../../components/nfl/classic/ClassicReviewDrawer.astro";
import {
  fetchClassicReviewRows,
  toNumber,
  pct,
} from "../../../../lib/nfl/classicReview";

const pageTitle = "NFL Classic Review | Patterns";

const rows = await fetchClassicReviewRows(Astro.url.origin);
const hasData = rows.length > 0;

type Row = {
  label: string;
  value: number;
  meta?: string;
};

const stackLabelFor = (row) => {
  const raw = String(row.qbStack ?? "").trim();
  if (raw) return raw;
  const count = toNumber(row.stackCount);
  if (count == null) return "Unknown";
  if (count === 0) return "Naked QB";
  return `QB+${count}`;
};

const bringBackLabelFor = (row) => {
  const count = toNumber(row.bringbackCount);
  if (count == null) {
    const flag = String(row.hasBringback ?? "").toUpperCase();
    return flag === "YES" ? "1 bring-back" : "No bring-back";
  }
  if (count === 0) return "No bring-back";
  if (count === 1) return "1 bring-back";
  if (count === 2) return "2 bring-backs";
  return "3+ bring-backs";
};

const buildDistribution = (values) => {
  const map = new Map();
  values.forEach((value) => {
    map.set(value, (map.get(value) || 0) + 1);
  });
  return Array.from(map.entries())
    .map(([label, count]) => ({ label, count }))
    .sort((a, b) => b.count - a.count);
};

const stackCounts = buildDistribution(rows.map((r) => stackLabelFor(r)));
const bringCounts = buildDistribution(rows.map((r) => bringBackLabelFor(r)));

const stackRows: Row[] = stackCounts.slice(0, 6).map((row) => ({
  label: row.label,
  value: Number.parseFloat(pct(row.count, rows.length).replace("%", "")) || 0,
}));

const bringBackRows: Row[] = bringCounts.slice(0, 6).map((row) => ({
  label: row.label,
  value: Number.parseFloat(pct(row.count, rows.length).replace("%", "")) || 0,
}));

const stackMax = Math.max(...stackRows.map((r) => r.value), 1);
const bringBackMax = Math.max(...bringBackRows.map((r) => r.value), 1);

const stackAverage =
  stackRows.length > 0
    ? Math.round(stackRows.reduce((sum, row) => sum + row.value, 0) / stackRows.length)
    : 0;

const bringBackAverage =
  bringBackRows.length > 0
    ? Math.round(bringBackRows.reduce((sum, row) => sum + row.value, 0) / bringBackRows.length)
    : 0;

const stackLeader = stackRows[0];
const stackRunnerUp = stackRows[1];
const bringBackLeader = bringBackRows[0];
const bringBackRunnerUp = bringBackRows[1];

const stackSummary =
  "Ranked patterns in Classic winners.";

const bringBackSummary =
  "Ranked by frequency across first-place Classic builds.";

const stackFooter = "Sorted by frequency across Classic winning lineups.";
const bringBackFooter = "Sorted by frequency across Classic winning lineups.";

const stackRefLeft = `${(stackAverage / stackMax) * 100}%`;
const bringBackRefLeft = `${(bringBackAverage / bringBackMax) * 100}%`;
---

<ClassicReviewShell
  title={pageTitle}
  headline="Winning Patterns"
  subtitle="The repeatable stack shapes and bring-back structures that keep resurfacing in Classic winners."
  accent="gold"
  class="with-drawer patternsEditorialShell"
>
  <ClassicReviewDrawer active="patterns" mode="hover" />

  {hasData ? (
  <section class="patternEditorialBoard">
    <section class="patternHeroModule">
      <div class="patternHero">
        <div class="heroTitleBlock">
          <p class="eyebrow">Classic Review</p>
          <h1 class="heroHeadline">
            WINNING PATTERNS
            <br />
            IN NFL CLASSIC
            <br />
            MILLY MAKER BUILDS
          </h1>
        </div>

        <div class="heroNarrative">
          <p>
            Which stack structures and opposing correlations keep showing up in first place
            builds.
          </p>
        </div>
      </div>
    </section>

    <section class="patternModule">
      <div class="vizSection">
        <div class="vizMain">
          <div class="vizTitleRow">
            <h2>QB Stack Shape Distribution</h2>
            <p>{stackSummary}</p>
          </div>

          <div class="rankedViz">
            <div class="rankedVizHeader">
              <div class="headerLabel">Pattern</div>
              <div class="headerMetric">Share of winning lineups</div>
            </div>

            <div class="rankedVizBody">
              <div class="referenceLine" style={`left:${stackRefLeft};`} />
              {stackRows.map((row) => (
                <div class="rankRow">
                  <div class="rankLabel">{row.label}</div>
                  <div class="barLane">
                    <div class="barTrack" />
                    <div
                      class="barFill gold"
                      style={`width:${(row.value / stackMax) * 100}%;`}
                    />
                    <div
                      class="barValue"
                      style={`left:${(row.value / stackMax) * 100}%;`}
                    >
                      {row.value}%
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div class="rankedVizFooter">
              <span>{stackFooter}</span>
              <span>Reference line = average pattern frequency ({stackAverage}%).</span>
            </div>
          </div>

          <div class="vizNotes">
            <div>
              <span>NOTES:</span> QB-led roster construction among first-place Classic winners.
            </div>
            <div>
              <span>SOURCE:</span> Milly Maker Tracker contest winner database.
            </div>
          </div>
        </div>

        <aside class="vizRail">
          <div class="railBlock">
            <h3>Pattern key</h3>
            <div class="legendList">
              <div class="legendItem">
                <span class="swatch gold"></span>
                <span>Primary stack family</span>
              </div>
              <div class="legendItem">
                <span class="swatch slate"></span>
                <span>Background frequency rail</span>
              </div>
              <div class="legendItem">
                <span class="swatch line"></span>
                <span>Average pattern line</span>
              </div>
            </div>
          </div>

          <div class="railBlock">
            <p class="railNoteKicker">Most common</p>
            <p class="railNoteValue">{stackLeader?.label ?? "N/A"}</p>
            <p class="railNoteText">
              {stackLeader?.value ?? 0}% of winners in the current sample.
            </p>
          </div>

          <div class="railBlock">
            <p class="railNoteKicker">Runner up</p>
            <p class="railNoteValue">{stackRunnerUp?.label ?? "N/A"}</p>
            <p class="railNoteText">
              {stackRunnerUp?.value ?? 0}% of winners in the current sample.
            </p>
          </div>

          <div class="railBlock railCallout">
            Default build unless slate conditions push elsewhere.
          </div>
        </aside>
      </div>
    </section>

    <section class="patternModule">
      <div class="vizSection second">
        <div class="vizMain">
          <div class="vizTitleRow">
            <h2>Bring Back Usage</h2>
            <p>{bringBackSummary}</p>
          </div>

          <div class="rankedViz greenTheme">
            <div class="rankedVizHeader">
              <div class="headerLabel">Bring-back pattern</div>
              <div class="headerMetric">Share of winning lineups</div>
            </div>

            <div class="rankedVizBody">
              <div class="referenceLine greenLine" style={`left:${bringBackRefLeft};`} />
              {bringBackRows.map((row) => (
                <div class="rankRow">
                  <div class="rankLabel">{row.label}</div>
                  <div class="barLane">
                    <div class="barTrack greenTrack" />
                    <div
                      class="barFill green"
                      style={`width:${(row.value / bringBackMax) * 100}%;`}
                    />
                    <div
                      class="barValue"
                      style={`left:${(row.value / bringBackMax) * 100}%;`}
                    >
                      {row.value}%
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <div class="rankedVizFooter">
              <span>{bringBackFooter}</span>
              <span>Reference line = average bring-back frequency ({bringBackAverage}%).</span>
            </div>
          </div>

          <div class="vizNotes">
            <div>
              <span>NOTES:</span> Opposing correlation among Classic winners.
            </div>
            <div>
              <span>SOURCE:</span> Milly Maker Tracker contest winner database.
            </div>
          </div>
        </div>

        <aside class="vizRail">
          <div class="railBlock">
            <h3>Bring-back read</h3>
            <div class="legendList">
              <div class="legendItem">
                <span class="swatch green"></span>
                <span>Bring-back frequency</span>
              </div>
              <div class="legendItem">
                <span class="swatch slate"></span>
                <span>Background comparison rail</span>
              </div>
              <div class="legendItem">
                <span class="swatch line greenLineSwatch"></span>
                <span>Average frequency line</span>
              </div>
            </div>
          </div>

          <div class="railBlock greenAccent">
            <p class="railNoteKicker">Most common</p>
            <p class="railNoteValue">{bringBackLeader?.label ?? "N/A"}</p>
            <p class="railNoteText">
              {bringBackLeader?.value ?? 0}% of winners in the current sample.
            </p>
          </div>

          <div class="railBlock">
            <p class="railNoteKicker">Runner up</p>
            <p class="railNoteValue">{bringBackRunnerUp?.label ?? "N/A"}</p>
            <p class="railNoteText">
              {bringBackRunnerUp?.value ?? 0}% of winners in the current sample.
            </p>
          </div>

          <div class="railBlock railCallout greenText">
            Use bring-backs as structure, not decoration.
          </div>
        </aside>
      </div>
    </section>
  </section>
  ) : (
    <section class="patternEditorialBoard">
      <div class="emptyState">No Classic review data available yet.</div>
    </section>
  )}
</ClassicReviewShell>

<style>
