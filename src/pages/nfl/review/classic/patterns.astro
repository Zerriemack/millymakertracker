    margin-top: 4px;
    width: min(1220px, calc(100vw - 128px));
    max-width: 1240px;
    margin-left: auto;
    margin-right: auto;
    margin-inline: auto;
    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    outline: 0 !important;
  }

  :global(.classic-frame.with-drawer.patternsEditorialShell),
  :global(.patternsEditorialShell .classic-shell) {
    background: transparent !important;
