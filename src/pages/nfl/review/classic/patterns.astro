      rgba(205, 216, 228, 0.12) 0%,
      rgba(205, 216, 228, 0.12) 1px,
      transparent 1px,
      transparent 10%
    );
  }

  .greenTrack {
    background: repeating-linear-gradient(
      90deg,
      rgba(179, 220, 209, 0.14) 0%,
      rgba(179, 220, 209, 0.14) 1px,
      transparent 1px,
      transparent 10%
