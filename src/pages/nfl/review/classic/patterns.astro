  .emptyState {
    border: 1px dashed rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 18px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
    font-weight: 700;
  }
</style>
