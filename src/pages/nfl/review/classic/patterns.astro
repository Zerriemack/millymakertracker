  :global(.classic-frame.with-drawer.patternsEditorialShell::after),
  :global(.patternsEditorialShell .classic-shell::before),
  :global(.patternsEditorialShell .classic-shell::after),
  :global(.patternsEditorialShell .content::before),
  :global(.patternsEditorialShell .content::after) {
    content: none !important;
  }

  .patternEditorialBoard {
