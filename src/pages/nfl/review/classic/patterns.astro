    line-height: 1.35;
    color: rgba(225, 225, 225, 0.72);
  }

  .vizNotes {
    margin-top: 8px;
    padding: 6px 2px 0;
    display: grid;
    gap: 4px;
    font-size: 0.7rem;
    color: rgba(225, 225, 225, 0.72);
  }

