    grid-template-columns: 260px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    min-height: 30px;
  }

  .rankLabel {
    padding-right: 10px;
    font-size: 0.84rem;
    line-height: 1.2;
    color: rgba(245, 245, 245, 0.96);
  }

