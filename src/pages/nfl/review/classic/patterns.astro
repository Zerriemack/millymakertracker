  }

  .greenAccent .railNoteValue {
    color: rgba(176, 243, 219, 0.98);
  }

  .railNoteText {
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.35;
    color: rgba(225, 225, 225, 0.72);
  }

