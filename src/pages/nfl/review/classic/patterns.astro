    gap: 18px;
    padding: 2px 0 26px;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .patternHeroModule {
    padding: 16px 20px 14px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(28, 28, 30, 0.92), rgba(20, 20, 22, 0.96));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.02),
      0 12px 22px rgba(0, 0, 0, 0.24);
  }

.patternModule {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

