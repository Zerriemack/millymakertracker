---
import ClassicReviewShell from "../../../../components/nfl/classic/ClassicReviewShell.astro";
import ClassicReviewDrawer from "../../../../components/nfl/classic/ClassicReviewDrawer.astro";
import {
  fetchClassicReviewRows,
  toNumber,
  mean,
  median,
  quantile,
  groupByYear,
  pct,
} from "../../../../lib/nfl/classicReview";

const pageTitle = "NFL Classic Review | Ownership";

const rows = await fetchClassicReviewRows(Astro.url.origin);
const baseSample = rows.length;
const hasData = baseSample > 0;

const fmtPct = (value) => (value == null ? "—" : `${value.toFixed(1)}%`);
const fmtNum = (value) => (value == null ? "—" : value.toLocaleString("en-US"));
const fmtRange = (minValue, maxValue) =>
  minValue == null || maxValue == null ? "—" : `${minValue.toFixed(1)}% to ${maxValue.toFixed(1)}%`;

const ownershipValues = rows.map((r) => toNumber(r.ownPct)).filter((v) => v !== null);
const highCounts = rows.map((r) => toNumber(r.own20p)).filter((v) => v !== null);
const midCounts = rows.map((r) => toNumber(r.own11_19)).filter((v) => v !== null);
const lowCounts = rows.map((r) => toNumber(r.own0_10)).filter((v) => v !== null);

const bandDefs = [
  { label: "<115%", min: 0, max: 114.9 },
  { label: "115–124.9%", min: 115, max: 124.9 },
  { label: "125–134.9%", min: 125, max: 134.9 },
  { label: "135–144.9%", min: 135, max: 144.9 },
  { label: "145–154.9%", min: 145, max: 154.9 },
  { label: "155%+", min: 155, max: 999 },
];

const bandForOwnership = (value) => {
  if (value == null) return "";
  const match = bandDefs.find((band) => value >= band.min && value <= band.max);
  return match ? match.label : "";
};

const countMap = (values) => {
  const map = new Map();
  values.forEach((value) => {
    if (typeof value !== "number") return;
    map.set(value, (map.get(value) || 0) + 1);
  });
  return map;
};

const buildCountBars = (values, maxVisible = 5) => {
  const map = countMap(values);
  const total = values.length || 1;
  let maxCount = 0;
  const bars = [];

  for (let i = 0; i <= maxVisible; i += 1) {
    const count = map.get(i) || 0;
    maxCount = Math.max(maxCount, count);
    bars.push({ label: String(i), count });
  }

  let overflow = 0;
  map.forEach((count, key) => {
    if (key > maxVisible) overflow += count;
  });

  if (overflow > 0) {
    maxCount = Math.max(maxCount, overflow);
    bars.push({ label: `${maxVisible + 1}+`, count: overflow });
  }

  const ranked = [...bars].sort((a, b) => b.count - a.count);
  const coreLabels = new Set(ranked.slice(0, 2).map((row) => row.label));
  const secondaryLabels = new Set(ranked.slice(2, 4).map((row) => row.label));

  const mostCommon = ranked[0]?.label ?? "—";
  const topRange = ranked.slice(0, 2).map((row) => Number.parseInt(row.label, 10)).filter((v) => !Number.isNaN(v));
  const rangeMin = topRange.length ? Math.min(...topRange) : null;
  const rangeMax = topRange.length ? Math.max(...topRange) : null;

  const insideBand = values.filter((value) => {
    if (rangeMin == null || rangeMax == null || typeof value !== "number") return false;
    return value >= rangeMin && value <= rangeMax;
  }).length;

  return {
    mostCommon,
    trustedRange: rangeMin == null || rangeMax == null ? "—" : `${rangeMin} to ${rangeMax}`,
    insideBand,
    insidePct: pct(insideBand, values.length),
    bars: bars.map((row) => ({
      label: row.label,
      count: row.count,
      pct: pct(row.count, total),
      width: maxCount ? Math.round((row.count / maxCount) * 100) : 0,
      state: coreLabels.has(row.label)
        ? "core"
        : secondaryLabels.has(row.label)
          ? "secondary"
          : "rare",
    })),
  };
};

const makePocketPanel = (key, bucket, values) => {
  const panel = buildCountBars(values);
  return {
    key,
    bucket,
    mostCommon: panel.mostCommon,
    trustedRange: panel.trustedRange,
    insideBand: `${panel.insideBand} winners`,
    insidePct: panel.insidePct,
    bars: panel.bars,
    rangeMin: panel.trustedRange.split(" to ")[0],
    rangeMax: panel.trustedRange.split(" to ")[1],
  };
};

const pocketPanels = [
  makePocketPanel("high", "20%+ Pocket", highCounts),
  makePocketPanel("mid", "10 to 19% Pocket", midCounts),
  makePocketPanel("low", "0 to 9% Pocket", lowCounts),
];

const rangeCards = pocketPanels.map((panel) => ({
  bucket: panel.bucket,
  key: panel.key,
  atLeast: panel.rangeMin ?? "—",
  atMost: panel.rangeMax ?? "—",
  winners: panel.insideBand,
  pct: `${panel.insidePct} of sample`,
}));

const heroStats = [];

const shapeMap = new Map();
rows.forEach((row) => {
  const high = toNumber(row.own20p);
  const mid = toNumber(row.own11_19);
  const low = toNumber(row.own0_10);
  if (high == null || mid == null || low == null) return;
  const shape = `${high}H / ${mid}M / ${low}L`;
  if (!shapeMap.has(shape)) {
    shapeMap.set(shape, {
      shape,
      count: 0,
      years: new Set(),
      ownership: [],
      score: [],
      bandCounts: new Map(),
      high,
      mid,
      low,
      season: row.year ?? "",
    });
  }
  const entry = shapeMap.get(shape);
  entry.count += 1;
  if (row.year != null) entry.years.add(String(row.year));
  entry.ownership.push(toNumber(row.ownPct));
  entry.score.push(toNumber(row.pts));
  const band = bandForOwnership(toNumber(row.ownPct));
  if (band) entry.bandCounts.set(band, (entry.bandCounts.get(band) || 0) + 1);
});

const shapeRows = Array.from(shapeMap.values())
  .sort((a, b) => b.count - a.count)
  .slice(0, 6)
  .map((entry) => {
    const sortedBands = Array.from(entry.bandCounts.entries()).sort((a, b) => b[1] - a[1]);
    const band = sortedBands[0]?.[0] ?? "";
    const share = baseSample ? (entry.count / baseSample) * 100 : 0;
    let tag = "Secondary";
    if (share >= 10) tag = "Core";
    if (share < 3) tag = "Outlier";
    return {
      shape: entry.shape,
      winners: entry.count,
      pct: pct(entry.count, baseSample),
      seasons: `${entry.years.size} seasons`,
      ownership: fmtPct(mean(entry.ownership)),
      score: fmtNum(mean(entry.score)),
      tag,
      high: String(entry.high),
      mid: String(entry.mid),
      low: String(entry.low),
      band,
      season: entry.season ? String(entry.season) : "",
    };
  });

const totalOwnershipBins = bandDefs.map((band) => {
  const count = ownershipValues.filter((v) => v >= band.min && v <= band.max).length;
  return { label: band.label, count };
});

const maxBin = Math.max(...totalOwnershipBins.map((b) => b.count), 1);
const totalOwnershipBinsStyled = totalOwnershipBins.map((bin) => ({
  ...bin,
  pct: pct(bin.count, baseSample),
  width: Math.round((bin.count / maxBin) * 100),
  state: bin.count >= maxBin * 0.66 ? "core" : bin.count >= maxBin * 0.33 ? "secondary" : "rare",
}));

const totalOwnershipBinsDisplay = totalOwnershipBinsStyled;

const q10 = quantile(ownershipValues, 0.1);
const q90 = quantile(ownershipValues, 0.9);
const q30 = quantile(ownershipValues, 0.3);
const q70 = quantile(ownershipValues, 0.7);
const ownershipMedian = median(ownershipValues);
const recommendedRange = fmtRange(q10, q90);
const coreRange = fmtRange(q30, q70);
const medianBand = bandForOwnership(ownershipMedian);
const lowCount = q10 == null ? 0 : ownershipValues.filter((v) => v < q10).length;
const highCount = q90 == null ? 0 : ownershipValues.filter((v) => v > q90).length;
const keptCount = baseSample - lowCount - highCount;

heroStats.push(
  { label: "Sample", value: `${baseSample} winners` },
  {
    label: "Most common exact build",
    value: pocketPanels.length
      ? `${pocketPanels[0].mostCommon} high-owned, ${pocketPanels[1].mostCommon} mid-owned, ${pocketPanels[2].mostCommon} low-owned players`
      : "—",
  },
  {
    label: "Trusted range",
    value: pocketPanels.length
      ? `At least ${pocketPanels[0].rangeMin} and at most ${pocketPanels[0].rangeMax} high-owned players, at least ${pocketPanels[1].rangeMin} and at most ${pocketPanels[1].rangeMax} mid-owned players, and at least ${pocketPanels[2].rangeMin} and at most ${pocketPanels[2].rangeMax} low-owned players`
      : "—",
  },
  {
    label: "Outlier filter",
    value: q10 == null || q90 == null ? "—" : `Min total ownership: ${q10.toFixed(1)}% • Max total ownership: ${q90.toFixed(1)}%`,
  },
);

const totalOwnershipSummary = [
  { label: "Recommended range", value: recommendedRange },
  { label: "Core concentration", value: coreRange },
  { label: "Median", value: fmtPct(ownershipMedian) },
  { label: "Trim rule", value: q10 == null || q90 == null ? "—" : `Exclude <${q10.toFixed(1)}% and >${q90.toFixed(1)}%` },
];

const yearsBy = groupByYear(rows);
const overallSpread = (quantile(ownershipValues, 0.9) ?? 0) - (quantile(ownershipValues, 0.1) ?? 0);

const seasonShapeDriftRows = Object.keys(yearsBy)
  .filter((key) => key !== "Unknown")
  .sort((a, b) => Number(a) - Number(b))
  .map((season) => {
    const seasonRows = yearsBy[season];
    const seasonOwn = seasonRows.map((r) => toNumber(r.ownPct)).filter((v) => v !== null);
    const seasonMedian = median(seasonOwn);
    const seasonSpread = (quantile(seasonOwn, 0.9) ?? 0) - (quantile(seasonOwn, 0.1) ?? 0);

    const modeValue = (values) => {
      const map = countMap(values);
      let top = { value: "—", count: 0 };
      map.forEach((count, value) => {
        if (count > top.count) top = { value, count };
      });
      return String(top.value);
    };

    const highMode = modeValue(seasonRows.map((r) => toNumber(r.own20p)));
    const midMode = modeValue(seasonRows.map((r) => toNumber(r.own11_19)));
    const lowMode = modeValue(seasonRows.map((r) => toNumber(r.own0_10)));
    const shapeMode = `${highMode}H / ${midMode}M / ${lowMode}L`;

    let stability = "Stable";
    let note = "Stable ownership profile.";
    if (seasonMedian != null && ownershipMedian != null && seasonMedian > ownershipMedian + 5) {
      stability = "Chalk heavier";
      note = "Ownership tilted higher than the full sample.";
    } else if (seasonMedian != null && ownershipMedian != null && seasonMedian < ownershipMedian - 5) {
      stability = "Leverage heavier";
      note = "Ownership dipped below the median band.";
    } else if (seasonSpread > overallSpread * 1.1) {
      stability = "Wider";
      note = "Wider distribution of ownership outcomes.";
    }

    return {
      season,
      highMode,
      midMode,
      lowMode,
      topShape: shapeMode,
      medianOwn: fmtPct(seasonMedian),
      note,
      stability,
    };
  });

const seasonDriftSummary = ["Stable", "Wider", "Chalk heavier", "Leverage heavier"].map((label) => ({
  label,
  value: `${seasonShapeDriftRows.filter((row) => row.stability === label).length} seasons`,
}));

const methodology = [
  "Ownership buckets are fixed at 20%+, 10–19.9%, and 0–9.9%.",
  "This page is Classic only. No captain versus flex split applies here.",
  "Rare shape cut is defined as fewer than 3 appearances in the sample.",
  "Pocket counts use player level ownership and lineup level bucket totals.",
  "Percentages are shown against the full sample and re-computed against the filtered sample when a selection is active.",
];
---

<ClassicReviewShell
  title={pageTitle}
  headline="Ownership Balance"
  subtitle="How often each ownership pocket count shows up, the range you can trust, and the full shapes those counts create."
  accent="green"
  class="with-drawer ownership-compact"
  hideHero
>
  <ClassicReviewDrawer active="ownership" mode="hover" />

  <section class="sectionPanel ownershipHeroPanel">
    <div class="patternHero">
      <div class="heroTitleBlock">
        <p class="eyebrow">Classic Review</p>
        <h1 class="heroHeadline">
          WINNING OWNERSHIP SHAPES
        </h1>
      </div>

      <div class="heroNarrative">
        <p>Which ownership structures keep showing up in first place builds.</p>
      </div>
    </div>

    <div class="heroStatGrid">
      {heroStats.map((item) => (
        <article class="heroStatCard">
          <span class="heroStatLabel">{item.label}</span>
          <strong class:list={["heroStatValue", item.label !== "Sample" && "heroStatValueVerbose"]}>{item.value}</strong>
        </article>
      ))}
    </div>

    <div class="activeFilterBar" id="active-filter-bar">
      <div class="activeFilterSummary">
        <span class="activeFilterSummaryLabel">Live sample</span>
        <strong class="activeFilterSummaryValue"><span id="live-sample-count">{baseSample}</span> winners</strong>
      </div>

      <div class="activeChipRow" id="active-chip-row">
        <button class="activeChip isEmpty" type="button" data-chip="high">High pocket: any</button>
        <button class="activeChip isEmpty" type="button" data-chip="mid">Mid pocket: any</button>
        <button class="activeChip isEmpty" type="button" data-chip="low">Low pocket: any</button>
        <button class="activeChip isEmpty" type="button" data-chip="band">Total own: any</button>
        <button class="activeChip isEmpty" type="button" data-chip="shape">Shape: any</button>
        <button class="activeChip isEmpty" type="button" data-chip="season">Season: any</button>
      </div>

      <button class="resetFiltersButton" type="button" id="reset-ownership-filters">Reset all</button>
    </div>
  </section>

  <section class="sectionPanel methodologyPanel">
    <details class="methodologyDetails">
      <summary class="methodologySummary">
        <span>Methodology</span>
        <span class="methodologySummaryMeta">Definitions, sample rules, and filter logic</span>
      </summary>
      <div class="methodologyBody">
        <ul class="methodologyList">
          {methodology.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </details>
  </section>

  {hasData ? (
  <>
  <section class="sectionPanel">
    <div class="sectionHeader">
      <div>
        <h2 class="sectionTitle">Pocket frequency map</h2>
        <p class="sectionSub">First glance should answer how many times each count shows up inside each ownership bucket.</p>
      </div>
      <div class="sectionPill">Counts</div>
    </div>

    <div class="pocketGrid">
      {pocketPanels.map((panel) => (
        <article class="pocketCard" data-panel={panel.key}>
          <div class="pocketCardTop">
            <div>
              <div class="pocketBucket">{panel.bucket}</div>
              <div class="pocketMetaLine">
                <span>Mode {panel.mostCommon}</span>
                <span>Trusted range {panel.trustedRange}</span>
              </div>
            </div>
            <div class="pocketInsideBand">
              <span>{panel.insideBand}</span>
              <strong>{panel.insidePct}</strong>
            </div>
          </div>

          <div class="pocketBars">
            {panel.bars.map((bar) => (
              <button
                type="button"
                class={`pocketBarRow state-${bar.state} filterControl`}
                data-filter-kind={panel.key}
                data-filter-value={bar.label}
                data-high={panel.key === "high" ? bar.label : ""}
                data-mid={panel.key === "mid" ? bar.label : ""}
                data-low={panel.key === "low" ? bar.label : ""}
                aria-pressed="false"
              >
                <div class="pocketBarLeft">
                  <span class="pocketBarLabel">{bar.label}</span>
                  <span class="pocketBarCount">{bar.count}</span>
                </div>
                <div class="pocketBarTrack">
                  <div class="pocketBarFill" style={`width:${bar.width}%`}></div>
                </div>
                <div class="pocketBarPct">{bar.pct}</div>
              </button>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="sectionPanel rangePanel">
    <div class="sectionHeader">
      <div>
        <h2 class="sectionTitle">At least / at most</h2>
        <p class="sectionSub">The minimum and maximum counts that show up often enough to anchor the macro baseline.</p>
      </div>
      <div class="sectionPill">Range</div>
    </div>

    <div class="rangeGrid">
      {rangeCards.map((card) => (
        <article
          class="rangeCard filterControl"
          data-filter-kind={card.key}
          data-filter-value={`${card.atLeast}-${card.atMost}`}
          data-range-min={card.atLeast}
          data-range-max={card.atMost}
          aria-pressed="false"
        >
          <div class="rangeBucket">{card.bucket}</div>
          <div class="rangeBand">
            <div class="rangeBound">
              <span class="rangeLabel">At least</span>
              <strong class="rangeValue">{card.atLeast}</strong>
            </div>
            <div class="rangeDivider"></div>
            <div class="rangeBound">
              <span class="rangeLabel">At most</span>
              <strong class="rangeValue">{card.atMost}</strong>
            </div>
          </div>
          <div class="rangeFoot">
            <span>{card.winners}</span>
            <strong>{card.pct}</strong>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="sectionPanel">
    <div class="sectionHeader">
      <div>
        <h2 class="sectionTitle">Winning shape counts</h2>
        <p class="sectionSub">A small set of full ownership combinations does most of the work.</p>
      </div>
      <div class="sectionPill">Shapes</div>
    </div>

    <div class="shapeTable">
      <div class="shapeTableHead">
        <span>Shape</span>
        <span>Winners</span>
        <span>Share</span>
        <span>Season spread</span>
        <span>Median own</span>
        <span>Median pts</span>
      </div>

      {shapeRows.map((row) => (
        <button
          type="button"
          class={`shapeTableRow tag-${row.tag.toLowerCase()} filterControl`}
          data-filter-kind="shape"
          data-filter-value={row.shape}
          data-shape={row.shape}
          data-high={row.high}
          data-mid={row.mid}
          data-low={row.low}
          data-band={row.band}
          data-season={row.season}
          aria-pressed="false"
        >
          <div class="shapeCell shapeCellMain">
            <div class="shapeCode">{row.shape}</div>
            <span class="shapeTag">{row.tag}</span>
          </div>
          <div class="shapeCell"><span class="valueFull">{row.winners}</span><span class="valueFiltered" data-base={row.winners}>{row.winners}</span></div>
          <div class="shapeCell"><span class="valueFull">{row.pct}</span><span class="valueFiltered" data-base-pct={row.pct}>{row.pct}</span></div>
          <div class="shapeCell">{row.seasons}</div>
          <div class="shapeCell">{row.ownership}</div>
          <div class="shapeCell">{row.score}</div>
        </button>
      ))}
    </div>
  </section>

  <section class="sectionPanel">
    <div class="sectionHeader">
      <div>
        <h2 class="sectionTitle">Total Ownership Range Map</h2>
        <p class="sectionSub">Where winning total ownership clusters once the pocket counts are established.</p>
      </div>
      <div class="sectionPill">Range Map</div>
    </div>

    <div class="ownershipRangeLayout">
      <div class="ownershipRangeMain">
        <div class="ownershipRangeHead">
          <div>
            <h3 class="ownershipRangeTitle">Winning total ownership bands</h3>
            <p class="ownershipRangeSub">Show the true floor and ceiling, then separate the usable ownership range from the extreme tails.</p>
          </div>
          <div class="ownershipRangeMedian">
            <span>Median</span>
            <strong>{fmtPct(ownershipMedian)}</strong>
          </div>
        </div>

        <div class="ownershipBandBracket">
          <div class="ownershipBandBracketLine"></div>
          <div class="ownershipBandBracketLabel">Core band {coreRange}</div>
        </div>

        <div class="ownershipTrimStrip">
          <article class="ownershipTrimCard">
            <span class="ownershipTrimLabel">Raw floor</span>
            <strong class="ownershipTrimValue">{q10 == null ? "—" : `<${q10.toFixed(1)}%`}</strong>
            <span class="ownershipTrimNote">{lowCount} winners · {pct(lowCount, baseSample)}</span>
          </article>
          <article class="ownershipTrimCard ownershipTrimCardCore">
            <span class="ownershipTrimLabel">Trimmed range kept</span>
            <strong class="ownershipTrimValue">{recommendedRange}</strong>
            <span class="ownershipTrimNote">{keptCount} winners · {pct(keptCount, baseSample)}</span>
          </article>
          <article class="ownershipTrimCard">
            <span class="ownershipTrimLabel">Raw ceiling</span>
            <strong class="ownershipTrimValue">{q90 == null ? "—" : `>${q90.toFixed(1)}%`}</strong>
            <span class="ownershipTrimNote">{highCount} winners · {pct(highCount, baseSample)}</span>
          </article>
        </div>

        <div class="ownershipRangeCalloutRow">
          <article class="ownershipRangeCallout ownershipRangeCalloutPrimary">
            <span class="ownershipRangeCalloutLabel">Recommended working range</span>
            <strong class="ownershipRangeCalloutValue">{recommendedRange}</strong>
          </article>
          <article class="ownershipRangeCallout">
            <span class="ownershipRangeCalloutLabel">Core concentration</span>
            <strong class="ownershipRangeCalloutValue">{coreRange}</strong>
          </article>
        </div>

        <p class="ownershipTrimExplain">
          Extreme low and extreme high total ownership results are retained for reference but removed from the default research range because they are too thin to anchor weekly construction rules.
        </p>

        <div class="ownershipBandChart">
          {totalOwnershipBinsDisplay.map((bin) => (
            <button
              type="button"
              class={`ownershipBandCard state-${bin.state} filterControl`}
              data-filter-kind="band"
              data-filter-value={bin.label}
              data-band={bin.label}
              aria-pressed="false"
            >
              <div class="ownershipBandTop">
                <span class="ownershipBandLabel">{bin.label}</span>
                <span class="ownershipBandPct">{bin.pct}</span>
              </div>
              <div class="ownershipBandTrack">
                <div class="ownershipBandFill" style={`width:${bin.width}%`}></div>
                {medianBand && bin.label === medianBand ? <div class="ownershipMedianMarker"></div> : null}
              </div>
              <div class="ownershipBandFoot">
                <strong>{bin.count}</strong>
                <span>winners</span>
              </div>
            </button>
          ))}
        </div>
      </div>

      <aside class="ownershipRangeRail">
        {totalOwnershipSummary.map((item) => (
          <article class="ownershipRangeStat">
            <span class="ownershipRangeStatLabel">{item.label}</span>
            <strong class="ownershipRangeStatValue">{item.value}</strong>
          </article>
        ))}
      </aside>
    </div>
  </section>

  <section class="sectionPanel">
    <div class="sectionHeader">
      <div>
        <h2 class="sectionTitle">Ownership Shape Drift by Season</h2>
        <p class="sectionSub">Season level view of whether the macro ownership shape stayed stable or shifted.</p>
      </div>
      <div class="sectionPill">Season Matrix</div>
    </div>

    <div class="seasonSummaryStrip">
      {seasonDriftSummary.map((item) => (
        <article class="seasonSummaryCard">
          <span class="seasonSummaryLabel">{item.label}</span>
          <strong class="seasonSummaryValue">{item.value}</strong>
        </article>
      ))}
    </div>

    <div class="seasonDriftTable">
      <div class="seasonDriftHead">
        <span>Season</span>
        <span>High mode</span>
        <span>Mid mode</span>
        <span>Low mode</span>
        <span>Top shape</span>
        <span>Median own</span>
        <span>Stability</span>
        <span>Notes</span>
      </div>

      {seasonShapeDriftRows.map((row) => (
        <button
          type="button"
          class="seasonDriftRow filterControl"
          data-filter-kind="season"
          data-filter-value={row.season}
          data-season={row.season}
          data-high={row.highMode}
          data-mid={row.midMode}
          data-low={row.lowMode}
          data-shape={row.topShape}
          aria-pressed="false"
        >
          <div class="seasonDriftCell seasonDriftSeason">{row.season}</div>
          <div class="seasonDriftCell">{row.highMode}</div>
          <div class="seasonDriftCell">{row.midMode}</div>
          <div class="seasonDriftCell">{row.lowMode}</div>
          <div class="seasonDriftCell seasonDriftShape">{row.topShape}</div>
          <div class="seasonDriftCell">{row.medianOwn}</div>
          <div class="seasonDriftCell">
            <span class={`seasonStabilityBadge badge-${row.stability.toLowerCase().replaceAll(" ", "-")}`}>{row.stability}</span>
          </div>
          <div class="seasonDriftCell seasonDriftNote">{row.note}</div>
        </button>
      ))}
    </div>
  </section>
  </>
  ) : (
    <section class="sectionPanel emptyState">No Classic review data available yet.</section>
  )}
</ClassicReviewShell>

<script is:inline>
  (() => {
    const root = document.querySelector(".ownership-compact");
    if (!root) return;

    const baseSample = {baseSample};
    const state = {
      high: null,
      mid: null,
      low: null,
      band: null,
      shape: null,
      season: null,
    };

    const chips = {
      high: root.querySelector('[data-chip="high"]'),
      mid: root.querySelector('[data-chip="mid"]'),
      low: root.querySelector('[data-chip="low"]'),
      band: root.querySelector('[data-chip="band"]'),
      shape: root.querySelector('[data-chip="shape"]'),
      season: root.querySelector('[data-chip="season"]'),
    };

    const controls = Array.from(root.querySelectorAll(".filterControl"));
    const liveSampleCount = root.querySelector("#live-sample-count");
    const resetButton = root.querySelector("#reset-ownership-filters");
    const shapeRows = Array.from(root.querySelectorAll(".shapeTableRow"));
    const seasonRows = Array.from(root.querySelectorAll(".seasonDriftRow"));
    const pocketRows = Array.from(root.querySelectorAll(".pocketBarRow"));
    const rangeRows = Array.from(root.querySelectorAll(".rangeCard"));
    const bandRows = Array.from(root.querySelectorAll(".ownershipBandCard"));

    const matchesShape = (shapeRow) => {
      const ds = shapeRow.dataset;
      if (state.high && ds.high !== state.high) return false;
      if (state.mid && ds.mid !== state.mid) return false;
      if (state.low && ds.low !== state.low) return false;
      if (state.band && ds.band !== state.band) return false;
      if (state.shape && ds.shape !== state.shape) return false;
      if (state.season && ds.season !== state.season) return false;
      return true;
    };

    const matchesSeason = (seasonRow) => {
      const ds = seasonRow.dataset;
      if (state.high && ds.high !== state.high) return false;
      if (state.mid && ds.mid !== state.mid) return false;
      if (state.low && ds.low !== state.low) return false;
      if (state.shape && ds.shape !== state.shape) return false;
      if (state.season && ds.season !== state.season) return false;
      return true;
    };

    const inRange = (value, min, max) => {
      if (!value || !min || !max) return false;
      const numeric = Number.parseInt(value, 10);
      const low = Number.parseInt(min, 10);
      const high = Number.parseInt(max, 10);
      if (Number.isNaN(numeric) || Number.isNaN(low) || Number.isNaN(high)) return false;
      return numeric >= low && numeric <= high;
    };

    const updateChips = () => {
      const labels = {
        high: state.high ? `High pocket: ${state.high}` : "High pocket: any",
        mid: state.mid ? `Mid pocket: ${state.mid}` : "Mid pocket: any",
        low: state.low ? `Low pocket: ${state.low}` : "Low pocket: any",
        band: state.band ? `Total own: ${state.band}` : "Total own: any",
        shape: state.shape ? `Shape: ${state.shape}` : "Shape: any",
        season: state.season ? `Season: ${state.season}` : "Season: any",
      };

      Object.entries(chips).forEach(([key, el]) => {
        if (!el) return;
        el.textContent = labels[key];
        el.classList.toggle("isEmpty", !state[key]);
      });
    };

    const filteredShapeRows = () => shapeRows.filter(matchesShape);
    const filteredSeasons = () => seasonRows.filter(matchesSeason);

    const updateSample = () => {
      const hasActiveFilter = Object.values(state).some(Boolean);
      if (!hasActiveFilter) {
        if (liveSampleCount) liveSampleCount.textContent = String(baseSample);
        return;
      }

      const count = filteredShapeRows().reduce((sum, row) => {
        const winnersText = row.querySelector(".valueFull")?.textContent || "0";
        return sum + Number.parseInt(winnersText, 10);
      }, 0);
      if (liveSampleCount) liveSampleCount.textContent = String(count || 0);
    };

    const updateActiveStates = () => {
      controls.forEach((control) => {
        const kind = control.dataset.filterKind;
        const value = control.dataset.filterValue;
        const active = Boolean(kind && state[kind] && state[kind] === value);
        control.classList.toggle("isActive", active);
        control.setAttribute("aria-pressed", active ? "true" : "false");
      });
    };

    const updateVisibility = () => {
      const shapeCount = filteredShapeRows().length;
      shapeRows.forEach((row) => {
        const match = matchesShape(row);
        row.classList.toggle("isDimmed", !match && shapeCount > 0);
      });

      const seasonCount = filteredSeasons().length;
      seasonRows.forEach((row) => {
        const match = matchesSeason(row);
        row.classList.toggle("isDimmed", !match && seasonCount > 0);
      });

      pocketRows.forEach((row) => {
        const kind = row.dataset.filterKind;
        const value = row.dataset.filterValue;
        const active = state[kind] === value;
        const aligned =
          (!state.high || !row.dataset.high || row.dataset.high === state.high) &&
          (!state.mid || !row.dataset.mid || row.dataset.mid === state.mid) &&
          (!state.low || !row.dataset.low || row.dataset.low === state.low);
        row.classList.toggle("isDimmed", !active && !aligned && (state.high || state.mid || state.low));
      });

      rangeRows.forEach((row) => {
        const kind = row.dataset.filterKind;
        const min = row.dataset.rangeMin;
        const max = row.dataset.rangeMax;
        const selectedValue = state[kind];
        const aligned = selectedValue ? inRange(selectedValue, min, max) : false;
        const active = selectedValue && row.dataset.filterValue === selectedValue;
        row.classList.toggle("isActiveRange", Boolean(aligned));
        row.classList.toggle("isDimmed", Boolean(selectedValue) && !aligned && !active);
      });

      bandRows.forEach((row) => {
        const active = Boolean(state.band && row.dataset.band === state.band);
        row.classList.toggle("isDimmed", Boolean(state.band) && !active);
      });
    };

    const updateFilteredNumbers = () => {
      const hasActiveFilter = Object.values(state).some(Boolean);
      const currentDenominator = Number.parseInt(liveSampleCount?.textContent || String(baseSample), 10) || baseSample;

      shapeRows.forEach((row) => {
        const fullWinners = Number.parseInt(row.querySelector(".valueFull")?.textContent || "0", 10) || 0;
        const filteredWinners = matchesShape(row) ? fullWinners : 0;
        const winnersEl = row.querySelector('.valueFiltered[data-base]');
        const pctEl = row.querySelector('.valueFiltered[data-base-pct]');
        row.classList.toggle("showFilteredValues", hasActiveFilter);
        if (winnersEl) winnersEl.textContent = `${filteredWinners}`;
        if (pctEl) {
          const pct = currentDenominator > 0 ? ((filteredWinners / currentDenominator) * 100).toFixed(1) : "0.0";
          pctEl.textContent = `${pct}%`;
        }
      });
    };

    const render = () => {
      updateChips();
      updateSample();
      updateActiveStates();
      updateVisibility();
      updateFilteredNumbers();
    };

    controls.forEach((control) => {
      control.addEventListener("click", () => {
        const kind = control.dataset.filterKind;
        const value = control.dataset.filterValue;
        if (!kind || !value) return;
        state[kind] = state[kind] === value ? null : value;
        render();
      });
    });

    Object.entries(chips).forEach(([kind, chip]) => {
      chip?.addEventListener("click", () => {
        state[kind] = null;
        render();
      });
    });

    resetButton?.addEventListener("click", () => {
      state.high = null;
      state.mid = null;
      state.low = null;
      state.band = null;
      state.shape = null;
      state.season = null;
      render();
    });

    render();
  })();
</script>

