---
import ClassicReviewShell from "../../../../components/nfl/classic/ClassicReviewShell.astro";
import ClassicReviewDrawer from "../../../../components/nfl/classic/ClassicReviewDrawer.astro";
import {
  fetchClassicReviewRows,
  toNumber,
  bucketByStep,
  groupByYear,
  median,
  pct,
} from "../../../../lib/nfl/classicReview";

const pageTitle = "NFL Classic Review | Game Environment";

const rows = await fetchClassicReviewRows(Astro.url.origin);
const hasData = rows.length > 0;

const totals = rows.map((r) => toNumber(r.pts)).filter((v) => v !== null);
const spreads = rows.map((r) => toNumber(r.ownPct)).filter((v) => v !== null);

const totalBands = bucketByStep(totals, 10);
const spreadBands = bucketByStep(spreads, 10, { unit: "%" });

const topTotal = [...totalBands].sort((a, b) => b.count - a.count)[0];
const topSpread = [...spreadBands].sort((a, b) => b.count - a.count)[0];

const heroCards = [
  {
    label: "Primary read",
    value: "Winner points",
    note: "Best single read on scoring pressure in the live sample.",
  },
  {
    label: "Second read",
    value: "Total ownership",
    note: "Ownership pressure pairs with score to define the sample pockets.",
  },
  {
    label: "Working rule",
    value: topTotal?.label ?? "—",
    note: "Most of the usable environment sample should live here first.",
  },
  {
    label: "Ownership guardrail",
    value: topSpread?.label ?? "—",
    note: "Balance ownership pressure to keep both sides live longer.",
  },
];

const gridMax = Math.max(1, ...totalBands.flatMap((t) => spreadBands.map((s) => 0)));
const mapNodes = [];
const xStart = 16;
const xEnd = 90;
const yStart = 18;
const yEnd = 69;
const xStep = totalBands.length > 1 ? (xEnd - xStart) / (totalBands.length - 1) : 0;
const yStep = spreadBands.length > 1 ? (yEnd - yStart) / (spreadBands.length - 1) : 0;

let maxWinners = 1;
totalBands.forEach((tBand, tIndex) => {
  spreadBands.forEach((sBand, sIndex) => {
    const winners = rows.filter((row) => {
      const total = toNumber(row.pts);
      const spread = toNumber(row.ownPct);
      return (
        total != null &&
        spread != null &&
        total >= tBand.min &&
        total <= tBand.max &&
        spread >= sBand.min &&
        spread <= sBand.max
      );
    }).length;
    maxWinners = Math.max(maxWinners, winners);
    mapNodes.push({
      total: tBand.label,
      spread: sBand.label,
      winners,
      x: xStart + tIndex * xStep,
      y: yStart + sIndex * yStep,
    });
  });
});

const marketMap = mapNodes.map((node) => ({
  ...node,
  size: 12 + (node.winners / maxWinners) * 18,
  tone: node.winners >= maxWinners * 0.66 ? "core" : node.winners >= maxWinners * 0.33 ? "secondary" : "thin",
}));

const decisionBoard = [...marketMap]
  .sort((a, b) => b.winners - a.winners)
  .slice(0, 4)
  .map((node, index) => ({
    title: ["Core lane", "Score-first lane", "Closer-than-expected lane", "Thin lane"][index] ?? "Lane",
    total: node.total,
    spread: node.spread,
    share: pct(node.winners, rows.length),
    tone: node.tone,
    note: "Derived from the most frequent score/ownership pockets in the sample.",
  }));

const yearsBy = groupByYear(rows);
const totalMedian = median(totals) ?? 0;

const seasonLanes = Object.keys(yearsBy)
  .filter((key) => key !== "Unknown")
  .sort((a, b) => Number(a) - Number(b))
  .map((season, index) => {
    const seasonRows = yearsBy[season];
    const seasonTotals = seasonRows.map((r) => toNumber(r.pts)).filter((v) => v !== null);
    const seasonSpreads = seasonRows.map((r) => toNumber(r.ownPct)).filter((v) => v !== null);
    const totalBand = bucketByStep(seasonTotals, 10)[0]?.label ?? "—";
    const spreadBand = bucketByStep(seasonSpreads, 10, { unit: "%" })[0]?.label ?? "—";
    const seasonMedian = median(seasonTotals) ?? 0;
    let drift = "Balanced";
    let note = "Stayed near the long term center.";
    if (seasonMedian > totalMedian + 5) {
      drift = "Higher total";
      note = "Scoring pressure lifted in this season.";
    } else if (seasonMedian < totalMedian - 5) {
      drift = "Lower total";
      note = "Scoring pressure dipped lower than the long-term median.";
    }
    return {
      season,
      totalMode: totalBand,
      spreadMode: spreadBand,
      drift,
      xpos: 16 + (totalBands.length > 1 ? (index / Math.max(Object.keys(yearsBy).length - 1, 1)) * 74 : 0),
      note,
    };
  });

const pipelineSteps = [
  {
    step: "01",
    title: "Get the historical market numbers",
    note: "Capture winner points and total ownership for every slate. Use those as the baseline pockets first.",
  },
  {
    step: "02",
    title: "Store environment on the game record",
    note: "Do not place environment numbers on lineup rows. Attach them to each game once, then join them into winner analysis from there.",
  },
  {
    step: "03",
    title: "Anchor each winner to its main game",
    note: "Use the quarterback game as the default anchor. If your lineup analysis already tags a different primary game stack, allow the page to follow that tag.",
  },
  {
    step: "04",
    title: "Reduce the page to two first reads",
    note: "Lead with points and ownership. Keep weather, roof, pace, and injuries in a secondary layer after the core pockets are stable.",
  },
];

const buildRules = [
  "Start weekly research inside the dominant winner points band.",
  "Prefer ownership bands that match the core pocket until the slate gives strong reason to move.",
  "Treat extreme score tails as thinner paths than the center pockets.",
  "Use betting market data as a secondary check, not the lead sorting field.",
];

const filterChips = [`Sample: ${rows.length} winners`, "Score band: any", "Ownership band: any", "Season: any", "Roof: any", "Weather: any"];
---

<ClassicReviewShell
  title={pageTitle}
  headline="Game Environment"
  subtitle="Where winning NFL Classic lineups came from once market context is reduced to the two numbers that carry most of the page."
  accent="blue"
  class="with-drawer gameenv-page"
  hideHero
>
  <ClassicReviewDrawer active="game-environment" mode="hover" />

  {hasData ? (
  <>
  <section class="sectionPanel gameHeroPanel">
    <div class="gameHeroTop">
      <div class="gameHeroCopy">
        <p class="eyebrow">Classic Review</p>
        <h1 class="gameHeroHeadline">WINNING GAME ENVIRONMENTS</h1>
      </div>

      <div class="gameHeroText">
        <p>
          This page tracks where winning NFL Classic lineups came from when the game is reduced to scoring pressure and game tension.
        </p>
      </div>
    </div>

    <div class="heroCards">
      {heroCards.map((card) => (
        <article class="heroCard">
          <span class="heroCardLabel">{card.label}</span>
          <strong class="heroCardValue">{card.value}</strong>
          <p class="heroCardNote">{card.note}</p>
        </article>
      ))}
    </div>

    <div class="filterRail">
      {filterChips.map((chip, index) => (
        <span class:list={["filterChip", index === 0 && "filterChipStrong"]}>{chip}</span>
      ))}
      <button type="button" class="filterReset">Reset all</button>
    </div>
  </section>

  <section class="sectionPanel">
    <div class="splitHeader">
      <div>
        <p class="sectionEyebrow">Decision board</p>
        <h2 class="sectionTitle">Where the page should start</h2>
      </div>
      <p class="sectionSub">
        The goal here is not to chase every input. It is to find the center of the winner sample, separate the usable lanes from the thin ones, and give the page a rule set.
      </p>
    </div>

    <div class="decisionGrid">
      {decisionBoard.map((row) => (
        <article class={`decisionCard tone-${row.tone}`}>
          <div class="decisionTop">
            <span class="decisionTitle">{row.title}</span>
            <strong class="decisionShare">{row.share}</strong>
          </div>
          <div class="decisionStats">
            <div>
              <span>Winner points</span>
              <strong>{row.total}</strong>
            </div>
            <div>
              <span>Total ownership</span>
              <strong>{row.spread}</strong>
            </div>
          </div>
          <p class="decisionNote">{row.note}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="sectionPanel marketMapPanel">
    <div class="splitHeader">
      <div>
        <p class="sectionEyebrow">Market map</p>
        <h2 class="sectionTitle">Winner environment field</h2>
      </div>
      <p class="sectionSub">
        Each node is a pocket. Position shows winner points and total ownership. Size shows how many winners landed there.
      </p>
    </div>

    <div class="marketMapWrap">
      <div class="spreadLabels">
        {spreadBands.map((band) => (
          <span>{band.label}</span>
        ))}
      </div>

      <div class="marketMap">
        <div class="marketGrid"></div>

        {marketMap.map((node) => (
          <div
            class={`marketNode tone-${node.tone}`}
            style={`left:${node.x}%; top:${node.y}%; width:${node.size}px; height:${node.size}px;`}
            title={`${node.total} winner points • ${node.spread} total ownership • ${node.winners} winners`}
          >
            <span>{node.winners}</span>
          </div>
        ))}

        <div class="totalAxis">
          {totalBands.map((band) => (
            <span>{band.label}</span>
          ))}
        </div>
      </div>

      <div class="marketLegend">
        <article class="legendCard">
          <span class="legendDot legendCore"></span>
          <div>
            <strong>Core field</strong>
            <p>Main center of the sample.</p>
          </div>
        </article>

        <article class="legendCard">
          <span class="legendDot legendSecondary"></span>
          <div>
            <strong>Secondary field</strong>
            <p>Still live, but thinner.</p>
          </div>
        </article>

        <article class="legendCard">
          <span class="legendDot legendThin"></span>
          <div>
            <strong>Thin field</strong>
            <p>Keep for reference, not for default weekly rules.</p>
          </div>
        </article>
      </div>
    </div>
  </section>
  </>
  ) : (
    <section class="sectionPanel emptyState">No Classic review data available yet.</section>
  )}

  <section class="sectionPanel seasonPanel">
    <div class="splitHeader">
      <div>
        <p class="sectionEyebrow">Season movement</p>
        <h2 class="sectionTitle">Where the center moved by year</h2>
      </div>
      <p class="sectionSub">
        This is the year by year check on whether the strongest environment stayed near the same center or drifted.
      </p>
    </div>

    <div class="seasonLaneWrap">
      {seasonLanes.map((row) => (
        <article class="seasonLane">
          <div class="seasonMeta">
            <strong>{row.season}</strong>
            <span>{row.drift}</span>
          </div>

          <div class="seasonTrack">
            <div class="seasonTrackFill"></div>
            <div class="seasonMarker" style={`left:${row.xpos}%`}>
              <span></span>
            </div>
          </div>

          <div class="seasonRead">
            <div class="seasonReadTop">
              <strong>{row.totalMode}</strong>
              <span>{row.spreadMode}</span>
            </div>
            <p>{row.note}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="sectionPanel">
    <div class="splitHeader">
      <div>
        <p class="sectionEyebrow">Data flow</p>
        <h2 class="sectionTitle">How to wire this into imported winners</h2>
      </div>
      <p class="sectionSub">
        The page stays clean once environment belongs to games first and winner analysis joins into it second.
      </p>
    </div>

    <div class="pipelineGrid">
      {pipelineSteps.map((step) => (
        <article class="pipeCard">
          <span class="pipeStep">{step.step}</span>
          <h3 class="pipeTitle">{step.title}</h3>
          <p class="pipeNote">{step.note}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="sectionPanel rulePanel">
    <div class="ruleHeader">
      <div>
        <p class="sectionEyebrow">Build rules</p>
        <h2 class="sectionTitle">What the page should tell a player</h2>
      </div>

      <div class="ruleBadge">2 lead metrics</div>
    </div>

    <div class="ruleBody">
      <div class="ruleList">
        {buildRules.map((rule, index) => (
          <article class="ruleCard">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <p>{rule}</p>
          </article>
        ))}
      </div>

      <aside class="ruleAside">
        <span class="ruleAsideLabel">Best first schema add</span>
        <strong class="ruleAsideValue">games.closingTotal</strong>
        <strong class="ruleAsideValue">games.closingSpread</strong>
        <p class="ruleAsideNote">
          Add actualCombinedPoints after the market layer is stable.
        </p>
      </aside>
    </div>
  </section>
</ClassicReviewShell>

<style>
  :global(.classic-frame.with-drawer.gameenv-page) {
    padding-left: calc(clamp(18px, 2vw, 26px) + 54px);
    padding-right: clamp(20px, 3vw, 36px);
  }

  :global(.classic-frame.with-drawer.gameenv-page .content) {
    gap: 18px;
    margin-top: 4px;
    width: min(1220px, calc(100vw - 128px));
    max-width: 1240px;
    margin-left: auto;
    margin-right: auto;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  :global(.classic-frame.with-drawer.gameenv-page .hero) {
    display: none;
  }

  :global(.gameenv-page .sectionPanel) {
    padding: 22px;
    border-radius: 22px;
  }

  .gameHeroPanel {
    padding: 18px 20px 16px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(circle at 18% 0%, rgba(59, 130, 246, 0.24), transparent 34%),
      radial-gradient(circle at 85% 20%, rgba(16, 185, 129, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(28, 28, 30, 0.92), rgba(20, 20, 22, 0.96));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.02),
      0 12px 22px rgba(0, 0, 0, 0.24);
  }

  .gameHeroTop {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
    gap: 24px;
    align-items: start;
    margin-bottom: 18px;
  }

  .eyebrow,
  .sectionEyebrow {
    margin: 0 0 8px;
    font-size: 0.72rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(191, 219, 254, 0.72);
  }

  .gameHeroHeadline {
    margin: 0;
    max-width: 760px;
    font-size: clamp(2.2rem, 3.7vw, 4.35rem);
    line-height: 0.94;
    letter-spacing: -0.045em;
    font-weight: 900;
    color: rgba(248, 250, 252, 0.98);
  }

  .gameHeroText p,
  .sectionSub,
  .heroCardNote,
  .decisionNote,
  .pipeNote,
  .seasonRead p,
  .ruleCard p,
  .ruleAsideNote,
  .legendCard p {
    margin: 0;
    color: rgba(226, 232, 240, 0.76);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  .heroCards {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 14px;
  }

  .heroCard,
  .decisionCard,
  .legendCard,
  .pipeCard,
  .ruleCard,
  .ruleAside,
  .seasonLane {
    border-radius: 18px;
    border: 1px solid rgba(148, 163, 184, 0.14);
    background: linear-gradient(180deg, rgba(10, 16, 28, 0.9), rgba(6, 10, 18, 0.95));
  }

  .heroCard {
    padding: 16px 16px 14px;
    min-height: 126px;
  }

  .heroCardLabel,
  .ruleAsideLabel {
    display: block;
    margin-bottom: 8px;
    color: rgba(148, 163, 184, 0.82);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .heroCardValue {
    display: block;
    margin-bottom: 8px;
    color: #f8fafc;
    font-size: clamp(1.05rem, 1.7vw, 1.45rem);
    line-height: 1.05;
    font-weight: 800;
  }

  .filterRail {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .filterChip,
  .filterReset {
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.14);
    padding: 8px 10px;
    font-size: 0.72rem;
    line-height: 1;
    color: rgba(226, 232, 240, 0.82);
    background: rgba(255, 255, 255, 0.03);
  }

  .filterChipStrong {
    color: #f8fafc;
    background: rgba(59, 130, 246, 0.14);
    border-color: rgba(59, 130, 246, 0.22);
  }

  .filterReset {
    margin-left: auto;
    cursor: pointer;
  }

  .splitHeader,
  .ruleHeader {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: 18px;
    align-items: end;
    margin-bottom: 14px;
  }

  .sectionTitle {
    margin: 0;
    color: #f8fafc;
    font-size: clamp(1.45rem, 2vw, 2.1rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 850;
  }

  .decisionGrid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .decisionCard {
    padding: 14px;
    min-height: 190px;
  }

  .decisionTop {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 16px;
  }

  .decisionTitle {
    color: #f8fafc;
    font-size: 0.95rem;
    font-weight: 800;
  }

  .decisionShare {
    color: #f8fafc;
    font-size: 1.1rem;
    font-weight: 900;
  }

  .decisionStats {
    display: grid;
    gap: 10px;
    margin-bottom: 12px;
  }

  .decisionStats div {
    padding: 10px 12px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.03);
  }

  .decisionStats span {
    display: block;
    margin-bottom: 4px;
    color: rgba(148, 163, 184, 0.82);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .decisionStats strong {
    color: #f8fafc;
    font-size: 0.96rem;
    font-weight: 800;
  }

  .tone-core {
    box-shadow: inset 0 0 0 1px rgba(59, 130, 246, 0.2);
  }

  .tone-secondary {
    box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.16);
  }

  .tone-thin {
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.1);
  }

  .marketMapPanel {
    overflow: hidden;
  }

  .marketMapWrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 230px;
    gap: 16px;
    align-items: start;
  }

  .spreadLabels {
    display: grid;
    grid-template-rows: repeat(4, minmax(0, 1fr));
    position: absolute;
    left: 8px;
    top: 20px;
    bottom: 44px;
    width: 90px;
    pointer-events: none;
  }

  .spreadLabels span {
    align-self: center;
    color: rgba(148, 163, 184, 0.8);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .marketMap {
    position: relative;
    min-height: 430px;
    padding: 26px 20px 48px 96px;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.14);
    background:
      linear-gradient(180deg, rgba(10, 16, 28, 0.9), rgba(6, 10, 18, 0.95)),
      radial-gradient(circle at center, rgba(59, 130, 246, 0.08), transparent 55%);
    overflow: hidden;
  }

  .marketGrid {
    position: absolute;
    inset: 20px 20px 44px 96px;
    background-image:
      linear-gradient(to right, rgba(148, 163, 184, 0.08) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(148, 163, 184, 0.08) 1px, transparent 1px);
    background-size: calc(100% / 5) calc(100% / 4);
    border-radius: 14px;
  }

  .marketNode {
    position: absolute;
    display: grid;
    place-items: center;
    border-radius: 999px;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.6), 0 0 24px rgba(59, 130, 246, 0.14);
  }

  .marketNode span {
    color: #f8fafc;
    font-size: 0.7rem;
    font-weight: 800;
  }

  .marketNode.tone-core {
    background: radial-gradient(circle at 30% 30%, rgba(96, 165, 250, 1), rgba(37, 99, 235, 0.98));
  }

  .marketNode.tone-secondary {
    background: radial-gradient(circle at 30% 30%, rgba(52, 211, 153, 1), rgba(5, 150, 105, 0.98));
  }

  .marketNode.tone-thin {
    background: radial-gradient(circle at 30% 30%, rgba(100, 116, 139, 0.9), rgba(51, 65, 85, 0.95));
  }

  .totalAxis {
    position: absolute;
    left: 96px;
    right: 20px;
    bottom: 10px;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 6px;
  }

  .totalAxis span {
    text-align: center;
    color: rgba(148, 163, 184, 0.82);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .marketLegend {
    display: grid;
    gap: 10px;
  }

  .legendCard {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 12px;
    padding: 14px;
    align-items: start;
  }

  .legendDot {
    width: 14px;
    height: 14px;
    margin-top: 3px;
    border-radius: 999px;
  }

  .legendCore {
    background: rgba(59, 130, 246, 0.96);
  }

  .legendSecondary {
    background: rgba(16, 185, 129, 0.96);
  }

  .legendThin {
    background: rgba(100, 116, 139, 0.9);
  }

  .legendCard strong {
    display: block;
    margin-bottom: 4px;
    color: #f8fafc;
    font-size: 0.95rem;
  }

  .seasonLaneWrap {
    display: grid;
    gap: 12px;
  }

  .seasonLane {
    padding: 14px;
    display: grid;
    grid-template-columns: 100px minmax(0, 1fr) minmax(260px, 0.9fr);
    gap: 14px;
    align-items: center;
  }

  .seasonMeta strong,
  .seasonReadTop strong,
  .pipeTitle,
  .ruleAsideValue {
    color: #f8fafc;
  }

  .seasonMeta strong {
    display: block;
    margin-bottom: 4px;
    font-size: 1rem;
    font-weight: 800;
  }

  .seasonMeta span,
  .seasonReadTop span,
  .pipeStep,
  .ruleBadge {
    color: rgba(148, 163, 184, 0.84);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .seasonTrack {
    position: relative;
    height: 22px;
    display: flex;
    align-items: center;
  }

  .seasonTrackFill {
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background:
      linear-gradient(
