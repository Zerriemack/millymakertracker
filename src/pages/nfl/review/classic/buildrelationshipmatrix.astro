---
import ClassicReviewShell from "../../../../components/nfl/classic/ClassicReviewShell.astro";
import ClassicReviewDrawer from "../../../../components/nfl/classic/ClassicReviewDrawer.astro";
import { fetchClassicReviewRows, toNumber } from "../../../../lib/nfl/classicReview";

const pageTitle = "NFL Classic Review | Build Relationship Matrix";

const rows = await fetchClassicReviewRows(Astro.url.origin);
const hasData = rows.length > 1;

const stackCountFor = (row) => {
  const raw = String(row.qbStack ?? "").toUpperCase();
  const count = toNumber(row.stackCount);
  if (count != null) return count;
  if (raw.includes("NAKED")) return 0;
  const match = raw.match(/QB\+(\d+)/);
  if (match) return Number(match[1]);
  return null;
};

const corr = (a: number[], b: number[]) => {
  const pairs = a
    .map((v, i) => [v, b[i]] as const)
    .filter(([x, y]) => Number.isFinite(x) && Number.isFinite(y));
  if (pairs.length < 2) return 0;
  const xs = pairs.map((p) => p[0]);
  const ys = pairs.map((p) => p[1]);
  const meanX = xs.reduce((s, v) => s + v, 0) / xs.length;
  const meanY = ys.reduce((s, v) => s + v, 0) / ys.length;
  let num = 0;
  let denX = 0;
  let denY = 0;
  pairs.forEach(([x, y]) => {
    const dx = x - meanX;
    const dy = y - meanY;
    num += dx * dy;
    denX += dx * dx;
    denY += dy * dy;
  });
  const denom = Math.sqrt(denX * denY);
  return denom === 0 ? 0 : num / denom;
};

const metricDefs = [
  { label: "QB Naked", values: rows.map((r) => (stackCountFor(r) === 0 ? 1 : stackCountFor(r) == null ? null : 0)) },
  { label: "QB+1", values: rows.map((r) => (stackCountFor(r) === 1 ? 1 : stackCountFor(r) == null ? null : 0)) },
  { label: "QB+2", values: rows.map((r) => (stackCountFor(r) === 2 ? 1 : stackCountFor(r) == null ? null : 0)) },
  { label: "Double Stack", values: rows.map((r) => (stackCountFor(r) != null ? (stackCountFor(r) >= 3 ? 1 : 0) : null)) },
  { label: "Bring Back", values: rows.map((r) => {
      const value = toNumber(r.bringbackCount);
      if (value == null) {
        const flag = String(r.hasBringback).toUpperCase();
        return flag ? (flag === "YES" ? 1 : 0) : null;
      }
      return value >= 1 ? 1 : 0;
    }) },
  { label: "Double Bring Back", values: rows.map((r) => {
      const value = toNumber(r.bringbackCount);
      return value == null ? null : value >= 2 ? 1 : 0;
    }) },
  { label: "Onslaught", values: rows.map((r) => {
      const value = toNumber(r.maxFromTeam);
      return value == null ? null : value >= 5 ? 1 : 0;
    }) },
  { label: "Max From Team", values: rows.map((r) => toNumber(r.maxFromTeam)) },
  { label: "Max From Game", values: rows.map((r) => toNumber(r.maxFromGame)) },
  { label: "Early Players", values: rows.map((r) => toNumber(r.earlyCount)) },
  { label: "Late Players", values: rows.map((r) => toNumber(r.lateCount)) },
  { label: "Salary Left", values: rows.map((r) => toNumber(r.salaryLeft)) },
  { label: "Total Own", values: rows.map((r) => toNumber(r.ownPct)) },
  { label: "Own 0-10", values: rows.map((r) => toNumber(r.own0_10)) },
  { label: "Own 11-19", values: rows.map((r) => toNumber(r.own11_19)) },
  { label: "Own 20+", values: rows.map((r) => toNumber(r.own20p)) },
  { label: "Winner Pts", values: rows.map((r) => toNumber(r.pts)) },
];

const metrics = metricDefs.map((m) => m.label);
const matrix = metricDefs.map((row, i) =>
  metricDefs.map((col, j) => (i === j ? 1 : Number(corr(row.values, col.values).toFixed(2))))
);

const correlations = [];
matrix.forEach((row, i) => {
  row.forEach((value, j) => {
    if (i >= j) return;
    correlations.push({ i, j, value });
  });
});

const topSignals = correlations
  .sort((a, b) => Math.abs(b.value) - Math.abs(a.value))
  .slice(0, 6);

const headlineSignals = topSignals.map((signal, index) => {
  const value = signal.value;
  const tone = value >= 0 ? "pos" : "neg";
  return {
    title: index === 0 ? "Strongest relationship" : `Top signal ${index + 1}`,
    pair: `${metrics[signal.i]} × ${metrics[signal.j]}`,
    value: `${value >= 0 ? "+" : ""}${value.toFixed(2)}`,
    tone,
    note: value >= 0 ? "These variables tend to rise together in the winner sample." : "As one rises, the other tends to fall in the winner sample.",
  };
});

const faqs = [
  {
    q: "What does this page measure?",
    a: "It measures how winner level build variables move together across DraftKings NFL Classic Milly Maker lineups. The goal is to separate real structural pairings from simple tradeoffs or one off noise.",
  },
  {
    q: "What does a positive number mean?",
    a: "A positive value means two variables tend to rise together across the winner sample. The stronger the value, the more often those traits show up in the same type of build.",
  },
  {
    q: "What does a negative number mean?",
    a: "A negative value means one variable usually rises as the other falls. Some negative relationships reflect real strategic tension, while others come from fixed lineup tradeoffs.",
  },
  {
    q: "How should this be used with the matrix?",
    a: "Start with the cells that stand out most, then ask whether the relationship is structural, contextual, or automatic. Strong values matter most when they reveal a usable build tendency rather than a simple constraint.",
  },
  {
    q: "What should this become later?",
    a: "A filterable research surface where any metric can be isolated by year, week, slate type, salary band, ownership pocket, tag cluster, and lineup family.",
  },
];
---

<ClassicReviewShell
  title={pageTitle}
  accent="green"
  class="with-drawer build-relationship-lab"
  hideHero
>
  <ClassicReviewDrawer active="construction" mode="hover" />

  {hasData ? (
  <div class="labPage">
    <section class="topBand">
      <section class="patternHeroModule">
        <div class="patternHero">
          <div class="heroTitleBlock">
            <p class="eyebrow">Classic Review</p>
            <h1 class="heroHeadline">Build Relationship Matrix</h1>
          </div>

          <div class="heroNarrative">
            <p>
              A research surface for how winner-level build variables align, trade off, and cluster across first-place Classic Milly Maker lineups.
            </p>
          </div>
        </div>
      </section>

      <div class="topBandHeader">
        <div class="topBandSearch">
          <div class="searchMock">Search: 2018, WK 2, MAIN, QB+2, YES, max 4, early 6, TAG, GROUP</div>
          <button type="button" class="resetBtn">Reset all</button>
        </div>
      </div>
      <div class="topInsightGrid">
        <article class="signalPanel">
          <div class="signalPanelHead">
            <h3>Headline relationships</h3>
            <span>Top reads</span>
          </div>

          <div class="signalGrid">
            {headlineSignals.map((item) => (
              <div class="signalCard">
                <div class="signalTop">
                  <span class="signalLabel">{item.title}</span>
                  <span class:list={["pairValue", item.tone === "pos" ? "positive" : "negative"]}>
                    {item.value}
                  </span>
                </div>
                <strong class="signalPair">{item.pair}</strong>
                <p>{item.note}</p>
              </div>
            ))}
          </div>
        </article>

        <div class="guideStack">
          <article class="guideCard scaleGuideCard">
            <div class="scaleHead">MMT Relationship Scale</div>
            <div class="legendBar"></div>
            <div class="legendLabels">
              <span>Negative</span>
              <span>Neutral</span>
              <span>Positive</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="matrixSection">
      <div class="sectionHeader">
        <div>
          <span class="eyebrow">Core Matrix</span>
          <h3>Winner build relationship matrix</h3>
          <p>
            This is the main surface. It should be able to hold any random tracked variable that helps explain how first place builds are actually assembled.
          </p>
        </div>
      </div>

      <div class="matrixFrame">
        <div class="matrixGrid">
          {metrics.map((metric, metricIndex) => (
            <div
              class="axisCell axisTop"
              title={metric}
              style={`grid-column:${metricIndex + 2}; grid-row:1;`}
            >
              <span>{metric}</span>
            </div>
          ))}

          {metrics.map((rowLabel, rowIndex) => (
            <>
              <div
                class="axisCell axisLeft"
                title={rowLabel}
                style={`grid-column:1; grid-row:${rowIndex + 2};`}
              >
                <span>{rowLabel}</span>
              </div>

              {matrix[rowIndex].map((value, colIndex) => {
                const abs = Math.abs(value);
                const positive = value >= 0;
                const diagonal = rowIndex === colIndex;

                return (
                  <div
                    class:list={[
                      "matrixCell",
                      positive ? "isPositive" : "isNegative",
                      diagonal && "isDiagonal",
                    ]}
                    style={`--intensity:${abs}; grid-column:${colIndex + 2}; grid-row:${rowIndex + 2};`}
                    title={`${rowLabel} × ${metrics[colIndex]} = ${value.toFixed(2)}`}
                  >
                    <span>{value.toFixed(2)}</span>
                  </div>
                );
              })}
            </>
          ))}
        </div>
      </div>
    </section>

    <section class="faqSection">
      <div class="sectionHeader">
        <div>
          <span class="eyebrow">FAQ</span>
          <h3>Matrix notes</h3>
        </div>
      </div>

      <div class="faqGrid">
        {faqs.map((item) => (
          <article class="faqCard">
            <h4>{item.q}</h4>
            <p>{item.a}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
  ) : (
    <div class="labPage">
      <div class="emptyState">No Classic review data available yet.</div>
    </div>
  )}
</ClassicReviewShell>

