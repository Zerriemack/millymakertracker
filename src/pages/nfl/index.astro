---
import Layout from "../../layouts/Layout.astro";
import { prisma } from "../../lib/prisma";

const seasons = await prisma.season.findMany({
  where: { sport: "NFL" },
  select: { year: true },
  orderBy: { year: "desc" },
});

const existing = new Set(seasons.map((s) => s.year));

const startYear = 2016;
const endYear = 2026;
const years: number[] = [];
for (let y = endYear; y >= startYear; y--) years.push(y);

const cards = [
  { title: "All", href: "/nfl/all", note: "Every slate across every season" },
  ...years.map((y) => ({
    title: String(y),
    href: `/nfl/${y}`,
    note: existing.has(y) ? "" : "Not loaded",
  })),
];
---

<Layout title="NFL">
  <main class="page">
    <header class="hero">
      <h1 class="title">NFL</h1>
      <p class="sub">Select a season</p>
    </header>

    <section class="grid" aria-label="NFL seasons">
      {cards.map((c) => (
        <a class="card" href={c.href} aria-label={c.title}>
          <div class="cardRow">
            <h2 class="card-title">{c.title}</h2>
            {c.note ? <span class="note">{c.note}</span> : null}
          </div>
        </a>
      ))}
    </section>
  </main>
</Layout>

<style>
  :root{
    --surface:#1f1f1f;
    --surface2:#181818;
    --surface3:#141414;
    --border:rgba(255,255,255,.10);
    --border2:rgba(255,255,255,.12);
    --text:rgba(255,255,255,.92);
    --muted:rgba(255,255,255,.70);
    --muted2:rgba(255,255,255,.62);
    --shadow:0 18px 55px rgba(0,0,0,.55);
    --shadowSoft:0 12px 30px rgba(0,0,0,.40);
  }

  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 26px 16px 70px;
    color: var(--text);
  }

  .hero { margin: 10px 0 18px; text-align: center; }
  .title { margin: 0; font-size: 92px; letter-spacing: -0.02em; line-height: 1; font-weight: 950; }
  .sub { margin: 12px 0 0; color: var(--muted); line-height: 1.65; font-weight: 650; }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 18px;
  }

  @media (min-width: 900px) {
    .grid { grid-template-columns: 1fr 1fr; }
  }

  .card {
    display: block;
    text-decoration: none;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px;
    background: var(--surface);
    box-shadow: var(--shadowSoft);
    transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease, background 120ms ease;
  }

  .card:hover {
    transform: translateY(-1px);
    border-color: rgba(255,255,255,.16);
    background: #232323;
    box-shadow: var(--shadow);
  }

  .cardRow{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
  }

  .card-title { margin: 0; font-size: 18px; font-weight: 950; letter-spacing: -0.01em; }

  .note{
    font-size:12px;
    font-weight:850;
    padding:6px 10px;
    border-radius:999px;
    border:1px solid var(--border);
    background: rgba(255,255,255,.06);
    color: rgba(255,255,255,.78);
    white-space:nowrap;
  }

  @media (max-width: 720px){
    .title{ font-size: 64px; }
  }

  @media (prefers-reduced-motion: reduce){
    .card{ transition: none; }
  }
</style>