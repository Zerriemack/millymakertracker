---
const { label, value, note, pill, accent = "slate", class: className = "" } = Astro.props;
---

<div class={`stat ${className}`} data-accent={accent}>
  <div class="label">{label}</div>
  <div class="value">{value}</div>
  {note ? <div class="note">{note}</div> : null}
  {pill ? <div class="pill">{pill}</div> : null}
</div>

<style>
  .stat {
    border: 0;
    border-radius: 16px;
    padding: 12px;
    background: linear-gradient(180deg, rgba(24, 24, 24, 0.95), rgba(16, 16, 16, 0.98));
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.55);
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-height: 88px;
    position: relative;
    overflow: hidden;
  }

  .label {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.55);
  }

  .value {
    font-size: 22px;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: -0.01em;
  }

  .note {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.4;
    font-weight: 650;
  }

  .pill {
    align-self: flex-start;
    padding: 2px 8px;
    border-radius: 999px;
    border: 0;
    background: #151515;
    color: rgba(255, 255, 255, 0.78);
    font-weight: 900;
    font-size: 9px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .stat::before {
    content: none;
  }

  .stat[data-accent="blue"] { --accent: var(--accent-blue, #3c6eff); }
  .stat[data-accent="gold"] { --accent: var(--accent-gold, #d8b566); }
  .stat[data-accent="green"] { --accent: var(--accent-green, #3fb77a); }
  .stat[data-accent="red"] { --accent: var(--accent-red, #d26b6b); }
  .stat[data-accent="slate"] { --accent: var(--accent-slate, #8c93a1); }

  .stat[data-accent="gold"] .value,
  .stat[data-accent="green"] .value,
  .stat[data-accent="blue"] .value {
    color: color-mix(in srgb, var(--accent) 55%, #fff 45%);
  }
</style>
