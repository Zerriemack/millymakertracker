---
const { active = "overview" } = Astro.props;

const groups = [
  {
    label: "Start",
    items: [
      { key: "overview", label: "Overview", href: "/nfl/review/classic/overview" },
      { key: "distribution", label: "Distribution Index", href: "/nfl/review/classic/distribution" },
    ],
  },
  {
    label: "Patterns",
    items: [
      { key: "patterns", label: "Patterns", href: "/nfl/review/classic/patterns" },
      { key: "construction", label: "Build Relationship Matrix", href: "/nfl/review/classic/buildrelationshipmatrix" },
    ],
  },
  {
    label: "Market",
    items: [
      { key: "ownership", label: "Ownership", href: "/nfl/review/classic/ownership" },
      { key: "salary", label: "Salary", href: "/nfl/review/classic/salary" },
      { key: "environment", label: "Game Environment", href: "/nfl/review/classic/game-environment" },
    ],
  },
  {
    label: "Time",
    items: [
      { key: "trends", label: "Trends", href: "/nfl/review/classic/trends" },
    ],
  },
  {
    label: "Research",
    items: [
      { key: "raw", label: "Raw Review", href: "/nfl/review/classic" },
    ],
  },
];
---

<nav class="subnav" aria-label="Classic Review">
  {groups.map((group) => (
    <div class="group">
      <div class="groupLabel">{group.label}</div>
      <div class="groupTabs">
        {group.items.map((t) => (
          <a
            class={`tab ${active === t.key ? "tabActive" : ""}`}
            href={t.href}
            aria-current={active === t.key ? "page" : undefined}
          >{t.label}</a>
        ))}
      </div>
    </div>
  ))}
</nav>

<style>
  .subnav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    align-items: start;
  }

  .group {
    display: grid;
    gap: 6px;
  }

  .groupLabel {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.32);
    font-weight: 800;
  }

  .groupTabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 9px;
    border-radius: 999px;
    border: 0;
    background: rgba(255, 255, 255, 0.02);
    color: rgba(255, 255, 255, 0.52);
    text-decoration: none;
    font-weight: 800;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 120ms ease, color 120ms ease;
  }

  .tab:hover {
    color: rgba(255, 255, 255, 0.82);
    background: rgba(255, 255, 255, 0.06);
  }

  .tabActive {
    color: rgba(255, 255, 255, 0.92);
    background: color-mix(in srgb, var(--accent, #3c6eff) 18%, rgba(255, 255, 255, 0.04));
  }

  @media (max-width: 700px) {
    .subnav {
      grid-template-columns: 1fr;
    }
    .tab {
      font-size: 9px;
      padding: 6px 8px;
    }
  }
</style>
