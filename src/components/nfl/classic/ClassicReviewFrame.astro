---
import Layout from "../../../layouts/Layout.astro";

const {
  title,
  accent = "blue",
  class: className = "",
} = Astro.props;

const accentVar = `var(--accent-${accent})`;
---

<Layout title={title || "NFL Classic Review"}>
  <div class={`classic-frame ${className}`} style={`--accent:${accentVar};`}>
    <slot />
  </div>
</Layout>

<style>
  :global(main.shell) {
    width: 100%;
    max-width: 100%;
    padding: 0;
    margin: 0;
  }

  .classic-frame {
    width: 100%;
    min-height: 100%;
    padding: 18px clamp(16px, 2.2vw, 44px) 72px;
    color: rgba(255, 255, 255, 0.92);
    position: relative;
    box-sizing: border-box;
    --accent-blue: #3c6eff;
    --accent-gold: #d8b566;
    --accent-green: #3fb77a;
    --accent-red: #d26b6b;
    --accent-slate: #8c93a1;
    --surface: #1a1a1a;
    --surface-2: #131313;
    --surface-3: #0d0d0d;
    --border: rgba(255, 255, 255, 0.09);
    --border-strong: rgba(255, 255, 255, 0.18);
    --text: rgba(255, 255, 255, 0.94);
    --text-2: rgba(255, 255, 255, 0.78);
    --muted: rgba(255, 255, 255, 0.62);
    --muted-2: rgba(255, 255, 255, 0.42);
    --shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
    --shadow-soft: 0 16px 34px rgba(0, 0, 0, 0.45);
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    box-shadow: none !important;
    border: 0 !important;
  }

  .classic-frame :global(*) {
    box-sizing: border-box;
  }

  @media (max-width: 1200px) {
    .classic-frame {
      padding: 20px 18px 72px;
    }
  }
</style>
