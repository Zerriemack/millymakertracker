---
// src/components/WinnerFinder.astro
const defaultSport = "NFL";
---

<section class="wf">
  <div class="wf__hero">
    <h1 class="wf__title">Milly Maker Tracker</h1>
    <p class="wf__sub">Search Milly Maker winning lineups.</p>
  </div>

  <form class="wf__form" id="winnerFinderForm">
    <div class="wf__row">
      <label class="wf__label">
        Sport
        <select name="sport" class="wf__select">
          <option value="NFL" selected={defaultSport === "NFL"}>NFL</option>
          <option value="CFB" selected={defaultSport === "CFB"}>CFB</option>
        </select>
      </label>

      <label class="wf__label">
        Season
        <input name="year" class="wf__input" inputmode="numeric" placeholder="2025" />
      </label>

      <label class="wf__label">
        Week
        <input name="week" class="wf__input" inputmode="numeric" placeholder="7" />
      </label>

      <label class="wf__label">
        Filter
        <select name="slateType" class="wf__select">
          <option value="ANY">Any</option>
          <option value="CLASSIC">Classic</option>
          <option value="SHOWDOWN">Showdown</option>
          <option value="MAIN">Main</option>
          <option value="TNF">TNF</option>
          <option value="SNF">SNF</option>
          <option value="MNF">MNF</option>
          <option value="SUPER_BOWL">Super Bowl</option>
          <option value="OTHER">Other</option>
        </select>
      </label>
    </div>

    <div class="wf__row">
      <label class="wf__label wf__grow">
        Search
        <input
          name="q"
          class="wf__input"
          placeholder="username, contest name, siteContestId"
          autocomplete="off"
        />
      </label>

      <button class="wf__btn" type="submit">Search</button>
    </div>

    <div class="wf__row wf__small">
      <button class="wf__linkBtn" type="button" data-preset="latest">Latest</button>
      <button class="wf__linkBtn" type="button" data-preset="nflClassic">NFL Classic</button>
      <button class="wf__linkBtn" type="button" data-preset="nflShowdown">NFL Showdown</button>
      <button class="wf__linkBtn" type="button" data-preset="winners">All Winners</button>
    </div>
  </form>

  <div class="wf__results" id="winnerFinderResults" hidden>
    <div class="wf__resultsHeader">
      <div id="winnerFinderMeta" class="wf__meta"></div>
      <a id="winnerFinderOpen" class="wf__open" href="/winners">Open page</a>
    </div>

    <div id="winnerFinderList" class="wf__list"></div>

    <div id="winnerFinderEmpty" class="wf__empty" hidden>
      <div class="wf__emptyTitle">No results</div>
      <div class="wf__emptySub">Try removing a filter or searching fewer words.</div>
    </div>
  </div>

  <div class="wf__hint">Tip: Searches update the URL so users can share a link to the exact filters.</div>
</section>

<script type="module">
  const form = document.getElementById("winnerFinderForm");
  const resultsWrap = document.getElementById("winnerFinderResults");
  const list = document.getElementById("winnerFinderList");
  const meta = document.getElementById("winnerFinderMeta");
  const openLink = document.getElementById("winnerFinderOpen");
  const empty = document.getElementById("winnerFinderEmpty");

  function buildParams(values) {
    const p = new URLSearchParams();
    for (const [k, v] of Object.entries(values)) {
      const val = String(v ?? "").trim();
      if (val) p.set(k, val);
    }
    return p;
  }

  function setFormFromUrl() {
    const url = new URL(window.location.href);
    const p = url.searchParams;
    for (const el of form.elements) {
      if (!el.name) continue;
      if (p.has(el.name)) el.value = p.get(el.name);
    }
  }

  function setUrl(params) {
    const url = new URL(window.location.href);
    url.search = params.toString();
    window.history.replaceState({}, "", url.toString());
  }

  function esc(s) {
    return String(s ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function cleanDupWords(s) {
    const parts = String(s ?? "").trim().split(/\s+/).filter(Boolean);
    const out = [];
    for (const p of parts) {
      if (out.length && out[out.length - 1].toUpperCase() === p.toUpperCase()) continue;
      out.push(p);
    }
    return out.join(" ");
  }

  function parseRight(right) {
    const raw = String(right ?? "").trim();
    if (!raw) return { prize: "", pts: "" };
    const parts = raw.split("•").map((x) => x.trim()).filter(Boolean);
    const prize = parts[0] && parts[0].startsWith("$") ? parts[0] : "";
    const pts = parts.find((p) => p.toLowerCase().includes("pts")) || "";
    return { prize, pts };
  }

  function parseLine1(line1) {
    const raw = String(line1 ?? "").trim();
    const out = { sport: "", year: "", week: "", slateType: "" };
    if (!raw) return out;

    const mSport = raw.match(/^(NFL|CFB)\b/i);
    if (mSport) out.sport = mSport[1].toUpperCase();

    const mYear = raw.match(/\b(20\d{2})\b/);
    if (mYear) out.year = mYear[1];

    const mWeek = raw.match(/\bWeek\s+(\d+)\b/i);
    if (mWeek) out.week = mWeek[1];

    const toks = raw.split(/\s+/);
    const last = toks[toks.length - 1] || "";
    out.slateType = last.toUpperCase();

    return out;
  }

  function normalizeToRows(data) {
    if (data && Array.isArray(data.items)) return data.items;
    if (data && Array.isArray(data.rows)) return data.rows;
    return [];
  }

  function renderSkeleton(n = 8) {
    list.innerHTML = "";
    const frag = document.createDocumentFragment();
    for (let i = 0; i < n; i++) {
      const d = document.createElement("div");
      d.className = "wf__card wf__card--skeleton";
      d.innerHTML = `
        <div class="wf__skTop">
          <div class="wf__skTitle wf__sk"></div>
          <div class="wf__skMeta wf__sk"></div>
        </div>
        <div class="wf__skBadges">
          <div class="wf__skPill wf__sk"></div>
          <div class="wf__skPill wf__sk"></div>
          <div class="wf__skPill wf__sk"></div>
        </div>
        <div class="wf__skBot">
          <div class="wf__skSub wf__sk"></div>
        </div>
      `;
      frag.appendChild(d);
    }
    list.appendChild(frag);
  }

  function renderRows(rows) {
    list.innerHTML = "";
    const frag = document.createDocumentFragment();

    for (const r of rows) {
      const a = document.createElement("a");
      a.className = "wf__card";
      a.href = r.href || "/winners";

      const title = cleanDupWords(r.title || "Contest");
      const line2 = cleanDupWords(r.line2 || "");
      const { prize, pts } = parseRight(r.right || "");
      const p = parseLine1(r.line1 || "");

      const badge1 = [p.sport, p.year].filter(Boolean).join(" ");
      const badge2 = p.week ? `Week ${p.week}` : "";
      const badge3 = p.slateType ? p.slateType : "";

      a.innerHTML = `
        <div class="wf__cardGrid">
          <div class="wf__main">
            <div class="wf__hrow">
              <div class="wf__cardTitle">${esc(title)}</div>
              <div class="wf__right">
                ${prize ? `<span class="wf__money">${esc(prize)}</span>` : ""}
                ${pts ? `<span class="wf__pts">${esc(pts)}</span>` : ""}
              </div>
            </div>

            <div class="wf__badges">
              ${badge1 ? `<span class="wf__badge">${esc(badge1)}</span>` : ""}
              ${badge2 ? `<span class="wf__badge">${esc(badge2)}</span>` : ""}
              ${badge3 ? `<span class="wf__badge wf__badge--strong">${esc(badge3)}</span>` : ""}
            </div>

            ${line2 ? `<div class="wf__winner">${esc(line2)}</div>` : ""}
          </div>

          <div class="wf__chev" aria-hidden="true">›</div>
        </div>
      `;

      frag.appendChild(a);
    }

    list.appendChild(frag);
  }

  function setOpenLink(values) {
    const sport = String(values.sport || "NFL").toUpperCase();
    const year = String(values.year || "").trim();
    const sp = new URLSearchParams();
    if (sport) sp.set("sport", sport);
    if (year) sp.set("year", year);
    openLink.href = `/winners?${sp.toString()}`;
  }

  async function runSearch(values) {
    const params = buildParams(values);
    setUrl(params);
    setOpenLink(values);

    resultsWrap.hidden = false;
    empty.hidden = true;
    meta.textContent = "Searching…";
    renderSkeleton(8);

    const apiUrl = `/api/winner-search?${params.toString()}`;

    const res = await fetch(apiUrl, { headers: { accept: "application/json" } });
    if (!res.ok) {
      list.innerHTML = "";
      empty.hidden = true;
      meta.textContent = `Search failed (${res.status}). Check /api/winner-search.`;
      return;
    }

    const data = await res.json();
    const rows = normalizeToRows(data);

    const count =
      typeof data?.count === "number"
        ? data.count
        : Array.isArray(rows)
          ? rows.length
          : 0;

    meta.textContent = `${count} result(s)`;

    if (!rows.length) {
      list.innerHTML = "";
      empty.hidden = false;
      return;
    }

    empty.hidden = true;
    renderRows(rows);
  }

  function readValues() {
    const fd = new FormData(form);
    return {
      sport: fd.get("sport") || "NFL",
      year: fd.get("year") || "",
      week: fd.get("week") || "",
      slateType: fd.get("slateType") || "ANY",
      q: fd.get("q") || "",
      limit: "25",
    };
  }

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    runSearch(readValues());
  });

  form.querySelectorAll("[data-preset]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const preset = btn.getAttribute("data-preset");
      const base = { sport: "NFL", year: "", week: "", slateType: "ANY", q: "", limit: "25" };

      if (preset === "latest") return runSearch({ ...base });
      if (preset === "nflClassic") return runSearch({ ...base, sport: "NFL", slateType: "CLASSIC" });
      if (preset === "nflShowdown") return runSearch({ ...base, sport: "NFL", slateType: "SHOWDOWN" });
      if (preset === "winners") window.location.href = "/winners";
    });
  });

  setFormFromUrl();
  const hasAny = new URL(window.location.href).searchParams.toString().length > 0;
  if (hasAny) runSearch(readValues());
</script>

<style is:global>
  .wf {
    max-width: 1075px;
    margin: 22px auto 0;
    padding: 55px 20px 80px;
    position: relative;
    background: transparent;
    background-color: transparent;
    background-image: none;
    border: 0;
    outline: 0;
    box-shadow: none;
    border-radius: 0;
  }

  /* subtle section break under the header */
  .wf::before {
    content: none;
  }
  .wf__hero {
    margin-bottom: 24px;
  }

  .wf__title {
    font-size: 70px;
    margin: 0 0 10px;
    letter-spacing: -0.03em;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.96);
  }

  .wf__sub {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-weight: 650;
    font-size: 20px;
  }

  .wf__form {
    background: #1f1f1f;
    border: 0;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.55);
    margin: 0 auto;
  }

  .wf__row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: end;
  }

  .wf__label {
    display: flex;
    flex-direction: column;
    gap: 7px;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.78);
    font-weight: 650;
  }

  .wf__grow {
    flex: 1;
    min-width: 260px;
  }

  .wf__input,
  .wf__select {
    height: 48px;
    border-radius: 10px;
    border: 0;
    padding: 0 12px;
    font-size: 17px;
    background: #141414;
    color: rgba(255, 255, 255, 0.92);
    outline: none;
    font-weight: 600;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 8px 18px rgba(0, 0, 0, 0.35);
  }

  .wf__input::placeholder {
    color: rgba(255, 255, 255, 0.52);
  }

  .wf__input:focus,
  .wf__select:focus {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 0 0 3px rgba(255, 255, 255, 0.08),
      0 8px 18px rgba(0, 0, 0, 0.35);
  }

  .wf__btn {
    height: 48px;
    border-radius: 10px;
    border: 0;
    padding: 0 18px;
    font-size: 17px;
    cursor: pointer;
    background: #1b1b1b;
    color: rgba(255, 255, 255, 0.92);
    transition: background 120ms ease, transform 120ms ease, box-shadow 120ms ease;
    font-weight: 750;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 10px 24px rgba(0, 0, 0, 0.4);
  }

  .wf__btn:hover {
    background: #232323;
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 14px 30px rgba(0, 0, 0, 0.45);
  }

  .wf__small {
    margin-top: 12px;
  }

  .wf__linkBtn {
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.82);
    transition: background 120ms ease, color 120ms ease;
    font-weight: 650;
  }

  .wf__linkBtn:hover {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.92);
  }

  .wf__results {
    max-width: 860px;
    margin: 22px auto 0;
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    padding: 0;
  }

  .wf__resultsHeader {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 12px 0;
  }

  .wf__meta {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.70);
  }

  .wf__open {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.84);
    text-decoration: none;
  }

  .wf__open:hover {
    color: rgba(255, 255, 255, 0.96);
  }

  .wf__list {
    display: grid;
    gap: 16px;
    margin-top: 16px;
  }

  a.wf__card,
  .wf__card--skeleton {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 0;
    border-radius: 18px;
    padding: 18px 20px;
    background: #1f1f1f;
    box-shadow: 0 12px 28px rgba(0,0,0,0.34);
    transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease,
      background 120ms ease;
  }

  a.wf__card:hover {
    transform: translateY(-1px);
    background: #232323;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.50);
  }

  .wf__cardGrid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 14px;
    align-items: center;
  }

  .wf__hrow {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: baseline;
  }

  .wf__cardTitle {
    font-weight: 800;
    font-size: 19px;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.94);
  }

  .wf__right {
    display: inline-flex;
    gap: 12px;
    align-items: baseline;
    white-space: nowrap;
  }

  .wf__money {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.86);
    font-weight: 650;
  }

  .wf__pts {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.68);
    font-weight: 650;
  }

  .wf__badges {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .wf__badge {
    display: inline-flex;
    align-items: center;
    padding: 8px 12px;
    border-radius: 999px;
    border: 0;
    background: rgba(255, 255, 255, 0.06);
    font-size: 15px;
    color: rgba(255, 255, 255, 0.82);
    font-weight: 700;
  }

  .wf__badge--strong {
    background: rgba(255, 255, 255, 0.10);
    color: rgba(255, 255, 255, 0.90);
  }

  .wf__winner {
    margin-top: 12px;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.70);
    line-height: 1.35;
    font-weight: 650;
  }

  .wf__chev {
    font-size: 26px;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1;
    transform: translateY(-1px);
  }

  .wf__empty {
    margin-top: 12px;
    padding: 18px 6px;
  }

  .wf__emptyTitle {
    font-weight: 900;
    color: rgba(255, 255, 255, 0.92);
    font-size: 18px;
  }

  .wf__emptySub {
    color: rgba(255, 255, 255, 0.70);
    margin-top: 6px;
    font-weight: 650;
    font-size: 15px;
  }

  .wf__hint {
    margin-top: 16px;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.60);
    font-weight: 650;
  }

  /* Skeleton */
  .wf__card--skeleton {
    pointer-events: none;
    background: #1b1b1b;
  }

  .wf__sk {
    background: rgba(255, 255, 255, 0.10);
    border-radius: 999px;
  }

  .wf__skTop {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  .wf__skTitle {
    width: 60%;
    height: 12px;
  }

  .wf__skMeta {
    width: 26%;
    height: 12px;
  }

  .wf__skBadges {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .wf__skPill {
    width: 92px;
    height: 22px;
  }

  .wf__skBot {
    margin-top: 12px;
  }

  .wf__skSub {
    width: 78%;
    height: 10px;
  }
</style>
