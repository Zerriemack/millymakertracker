---
// src/components/WinnerFinder.astro
const defaultSport = "NFL";
---

<section class="wf">
  <h1 class="wf__title">Milly Maker Tracker</h1>
  <p class="wf__sub">Search Milly Maker winning lineups.</p>

  <form class="wf__form" id="winnerFinderForm">
    <div class="wf__row">
      <label class="wf__label">
        Sport
        <select name="sport" class="wf__select">
          <option value="NFL" selected={defaultSport === "NFL"}>NFL</option>
          <option value="CFB" selected={defaultSport === "CFB"}>CFB</option>
        </select>
      </label>

      <label class="wf__label">
        Season
        <input name="year" class="wf__input" inputmode="numeric" placeholder="2025" />
      </label>

      <label class="wf__label">
        Week
        <input name="week" class="wf__input" inputmode="numeric" placeholder="7" />
      </label>

      <label class="wf__label">
        Slate type
        <select name="slateType" class="wf__select">
          <option value="">Any</option>
          <option value="CLASSIC">Classic</option>
          <option value="SHOWDOWN">Showdown</option>
        </select>
      </label>
    </div>

    <div class="wf__row">
      <label class="wf__label wf__grow">
        Search
        <input
          name="q"
          class="wf__input"
          placeholder="username, player name, team, contest name"
          autocomplete="off"
        />
      </label>

      <button class="wf__btn" type="submit">Search</button>
    </div>

    <div class="wf__row wf__small">
      <button class="wf__linkBtn" type="button" data-preset="latest">Latest</button>
      <button class="wf__linkBtn" type="button" data-preset="nflClassic">NFL Classic</button>
      <button class="wf__linkBtn" type="button" data-preset="nflShowdown">NFL Showdown</button>
      <button class="wf__linkBtn" type="button" data-preset="winners">All Winners</button>
    </div>
  </form>

  <div class="wf__results" id="winnerFinderResults" hidden>
    <div class="wf__resultsHeader">
      <div id="winnerFinderMeta" class="wf__meta"></div>
      <a id="winnerFinderOpen" class="wf__open" href="/winners">Open page</a>
    </div>
    <div id="winnerFinderList" class="wf__list"></div>
  </div>

  <div class="wf__hint">Tip: Searches update the URL so users can share a link to the exact filters.</div>
</section>

<script type="module">
  const form = document.getElementById("winnerFinderForm");
  const resultsWrap = document.getElementById("winnerFinderResults");
  const list = document.getElementById("winnerFinderList");
  const meta = document.getElementById("winnerFinderMeta");
  const openLink = document.getElementById("winnerFinderOpen");

  function buildParams(values) {
    const p = new URLSearchParams();
    for (const [k, v] of Object.entries(values)) {
      const val = String(v ?? "").trim();
      if (val) p.set(k, val);
    }
    return p;
  }

  function setFormFromUrl() {
    const url = new URL(window.location.href);
    const p = url.searchParams;
    for (const el of form.elements) {
      if (!el.name) continue;
      if (p.has(el.name)) el.value = p.get(el.name);
    }
  }

  function setUrl(params) {
    const url = new URL(window.location.href);
    url.search = params.toString();
    window.history.replaceState({}, "", url.toString());
  }

  function esc(s) {
    return String(s ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function cleanDupWords(s) {
    const parts = String(s ?? "").trim().split(/\s+/).filter(Boolean);
    const out = [];
    for (const p of parts) {
      if (out.length && out[out.length - 1].toUpperCase() === p.toUpperCase()) continue;
      out.push(p);
    }
    return out.join(" ");
  }

  function pickYear(valuesYear, s) {
    const y1 = String(valuesYear || "").trim();
    if (y1) return y1;

    const y2 = String(s?.season?.year ?? "").trim();
    if (y2) return y2;

    const y3 = String(s?.year ?? "").trim();
    if (y3) return y3;

    const y4 = String(s?.seasonYear ?? "").trim();
    if (y4) return y4;

    return "";
  }

  function normalizeToRows(data, values) {
    if (data && Array.isArray(data.items) && data.items.length && data.items[0].href) {
      return data.items;
    }

    const slates = data?.slates || data?.items || data?.data || [];
    if (!Array.isArray(slates)) return [];

    const sport = String(values.sport || "NFL").toUpperCase();

    return slates.map((s) => {
      const id = s.id || s.slateId || s.slug || s.slateKey;
      const year = pickYear(values.year, s);

      const base = sport === "CFB" ? `/cfb/${year}/slate` : `/nfl/${year}/slate`;
      const href = year && id ? `${base}/${id}` : sport === "CFB" ? "/cfb" : "/nfl";

      const contestName = s.contestName || s.contest?.contestName || s.name || "Slate";
      const week = s.week ?? s.seasonWeek ?? "";
      const slateType = s.slateType || s.type || "";
      const slateTag = s.slateTag || "";
      const winner = s.winnerUsername || s.winner?.username || "";
      const points = s.points || s.winnerPoints || s.winner?.points || "";
      const topPrize = s.topPrizeCents || s.contest?.topPrizeCents || s.topPrize || null;

      const prizeText =
        typeof topPrize === "number" ? `$${Math.round(topPrize / 100).toLocaleString()}` : "";

      const right = [prizeText, points ? `${Number(points).toFixed(2)} pts` : ""]
        .filter(Boolean)
        .join(" • ");

      const line1 = [sport, year ? year : "", week !== "" ? `Week ${week}` : ""]
        .filter(Boolean)
        .join(" ");

      const line2Parts = [];
      if (slateType) line2Parts.push(String(slateType).toUpperCase());
      if (slateTag) line2Parts.push(String(slateTag).toUpperCase());
      if (winner) line2Parts.push(`Winner: ${winner}`);
      const line2 = line2Parts.join(" ");

      return { href, title: contestName, right, line1, line2 };
    });
  }

  function renderRows(rows) {
    list.innerHTML = "";
    const frag = document.createDocumentFragment();

    for (const r of rows) {
      const a = document.createElement("a");
      a.className = "wf__card";
      a.href = r.href;

      const title = cleanDupWords(r.title);
      const right = cleanDupWords(r.right ?? "");
      const line1 = cleanDupWords(r.line1 ?? "");
      const line2 = cleanDupWords(r.line2 ?? "");

      a.innerHTML = `
        <div class="wf__cardTop">
          <div class="wf__cardTitle">${esc(title)}</div>
          <div class="wf__cardMeta">${esc(right)}</div>
        </div>
        <div class="wf__cardMid">
          <div class="wf__pill">${esc(line1)}</div>
        </div>
        <div class="wf__cardBot">
          <div class="wf__subLine">${esc(line2)}</div>
        </div>
      `;

      frag.appendChild(a);
    }

    list.appendChild(frag);
  }

  function setOpenLink(values) {
    const sport = String(values.sport || "NFL").toUpperCase();
    const year = String(values.year || "").trim();

    const sp = new URLSearchParams();
    sp.set("view", "LIST");

    const st = String(values.slateType || "").toUpperCase();
    if (st === "CLASSIC" || st === "SHOWDOWN") sp.set("lineupType", st);

    if (sport === "CFB") {
      openLink.href = year ? `/cfb/${year}/slate?${sp.toString()}` : `/cfb?${sp.toString()}`;
    } else {
      openLink.href = year ? `/nfl/${year}/slate?${sp.toString()}` : `/nfl?${sp.toString()}`;
    }
  }

  async function runSearch(values) {
    const params = buildParams(values);
    setUrl(params);

    const apiUrl = `/api/slates?${params.toString()}`;

    setOpenLink(values);

    const res = await fetch(apiUrl, { headers: { accept: "application/json" } });
    if (!res.ok) {
      resultsWrap.hidden = false;
      meta.textContent = `Search failed (${res.status}). Check /api/slates.`;
      list.innerHTML = "";
      return;
    }

    const data = await res.json();
    const rows = normalizeToRows(data, values);

    resultsWrap.hidden = false;

    const count =
      typeof data?.count === "number"
        ? data.count
        : Array.isArray(data?.slates)
          ? data.slates.length
          : rows.length;

    meta.textContent = `${count} result(s)`;
    renderRows(rows);
  }

  function readValues() {
    const fd = new FormData(form);
    return {
      sport: fd.get("sport") || "",
      year: fd.get("year") || "",
      week: fd.get("week") || "",
      slateType: fd.get("slateType") || "",
      q: fd.get("q") || "",
      limit: "25",
    };
  }

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    runSearch(readValues());
  });

  form.querySelectorAll("[data-preset]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const preset = btn.getAttribute("data-preset");
      const base = { sport: "NFL", year: "", week: "", slateType: "", q: "", limit: "25" };

      if (preset === "latest") return runSearch({ ...base });
      if (preset === "nflClassic") return runSearch({ ...base, sport: "NFL", slateType: "CLASSIC" });
      if (preset === "nflShowdown") return runSearch({ ...base, sport: "NFL", slateType: "SHOWDOWN" });
      if (preset === "winners") window.location.href = "/winners";
    });
  });

  setFormFromUrl();
  const hasAny = new URL(window.location.href).searchParams.toString().length > 0;
  if (hasAny) runSearch(readValues());
</script>

<style>
  .wf { max-width: 980px; margin: 0 auto; padding: 48px 16px 64px; }
  .wf__title { font-size: 42px; margin: 0 0 8px; letter-spacing: -0.02em; }
  .wf__sub { margin: 0 0 24px; opacity: 0.75; }

  .wf__form { background: white; border: 1px solid rgba(0,0,0,0.08); border-radius: 14px; padding: 16px; }
  .wf__row { display: flex; gap: 12px; flex-wrap: wrap; align-items: end; }
  .wf__label { display: flex; flex-direction: column; gap: 6px; font-size: 12px; opacity: 0.85; }
  .wf__grow { flex: 1; min-width: 260px; }

  .wf__input, .wf__select {
    height: 40px; border-radius: 10px; border: 1px solid rgba(0,0,0,0.12);
    padding: 0 12px; font-size: 14px; background: white;
  }

  .wf__btn {
    height: 40px; border-radius: 10px; border: 1px solid rgba(0,0,0,0.12);
    padding: 0 14px; font-size: 14px; cursor: pointer; background: rgba(0,0,0,0.04);
  }

  .wf__small { margin-top: 10px; }
  .wf__linkBtn {
    border: 0; background: transparent; cursor: pointer; padding: 6px 10px;
    border-radius: 10px; font-size: 13px; opacity: 0.85;
  }
  .wf__linkBtn:hover { background: rgba(0,0,0,0.04); }

  .wf__results { margin-top: 18px; }
  .wf__resultsHeader { display: flex; justify-content: space-between; align-items: center; margin: 10px 0; }
  .wf__meta { font-size: 13px; opacity: 0.75; }
  .wf__open { font-size: 13px; }

  .wf__list { display: grid; gap: 12px; margin-top: 12px; }

  a.wf__card {
    display: block !important;
    text-decoration: none !important;
    color: inherit !important;
    border: 1px solid rgba(0,0,0,0.08) !important;
    border-radius: 16px !important;
    padding: 14px 16px !important;
    background: white !important;
    transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease !important;
  }

  a.wf__card * {
    color: inherit !important;
    text-decoration: none !important;
  }

  a.wf__card:hover {
    transform: translateY(-1px) !important;
    border-color: rgba(0,0,0,0.14) !important;
    box-shadow: 0 10px 24px rgba(0,0,0,0.08) !important;
  }

  .wf__cardTop { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .wf__cardTitle { font-weight: 700; font-size: 15px; letter-spacing: -0.01em; }
  .wf__cardMeta { font-size: 13px; opacity: 0.75; white-space: nowrap; }

  .wf__cardMid { margin-top: 10px; }
  .wf__pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,0.08);
    background: rgba(0,0,0,0.03);
    font-size: 12.5px;
    opacity: 0.9;
  }

  .wf__cardBot { margin-top: 8px; }
  .wf__subLine { font-size: 13px; opacity: 0.7; line-height: 1.35; }

  .wf__hint { margin-top: 12px; font-size: 12px; opacity: 0.65; }
</style>
